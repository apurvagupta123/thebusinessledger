---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="India Economic Calendar">
  <section class="content-section" style="margin-top:48px">

    <div class="section-head">
      <h2 class="section-title">🏛️ India Economic Calendar</h2>
      <span class="section-live">2026</span>
    </div>
    <p style="color:var(--text-muted);font-size:13px;margin-bottom:20px">
      Key India macro events — RBI policy, inflation data, GDP, F&O expiry, and more.
    </p>

    <!-- Controls row -->
    <div class="ec-controls">
      <div class="econ-filters">
        <button class="econ-filter active" data-filter="all">All</button>
        <button class="econ-filter" data-filter="high">🔴 High Impact</button>
        <button class="econ-filter" data-filter="rbi">🏦 RBI Policy</button>
        <button class="econ-filter" data-filter="inflation">📊 Inflation</button>
        <button class="econ-filter" data-filter="market">📅 F&O</button>
      </div>
      <label class="legend-toggle">
        <input type="checkbox" id="showPast"> Show past
      </label>
    </div>

    <!-- Table -->
    <div class="ec-table-wrap">
      <table class="ec-table">
        <thead>
          <tr>
            <th style="width:100px">Date</th>
            <th>Event</th>
            <th style="width:110px">Category</th>
            <th style="width:90px">Impact</th>
            <th style="width:90px">When</th>
          </tr>
        </thead>
        <tbody id="econTableBody"></tbody>
      </table>
    </div>

    <!-- Expandable detail panel -->
    <div id="econDetail" class="ec-detail-panel" style="display:none"></div>

    <div id="econEmpty" style="display:none;text-align:center;padding:40px;color:var(--text-muted);font-size:13px">
      No upcoming events match this filter. Try "All" or enable "Show past".
    </div>

  </section>
</BaseLayout>

<script>
const EVENTS = [
  // ── June 2026 ──
  { date:'2026-06-12', event:'India CPI Inflation',    subtitle:'May 2026 data',      category:'Inflation',  impact:'high',   tag:'inflation',
    what:'Consumer Price Index — measures retail inflation across food, fuel, and core categories.',
    why:'RBI\'s primary target is 4% CPI. Above 5% → may delay rate cuts. Directly affects home loan EMIs, grocery bills.',
    market:'CPI > 5% → Nifty dips, Bank Nifty falls. CPI ~4% → rate cut hopes, banking stocks rally.' },
  { date:'2026-06-14', event:'India WPI Inflation',    subtitle:'May 2026 data',      category:'Inflation',  impact:'medium', tag:'inflation',
    what:'Wholesale Price Index — tracks inflation at the factory level, 2 months before consumers feel it.',
    why:'High WPI feeds into CPI in 4–8 weeks. Key for manufacturing and commodity-linked sectors.',
    market:'High WPI → margin squeeze for FMCG, cement, autos. Low WPI → relief for input-cost-sensitive sectors.' },
  { date:'2026-06-25', event:'NSE F&O Monthly Expiry', subtitle:'June 2026',           category:'F&O Market', impact:'medium', tag:'market',
    what:'All June 2026 Futures & Options contracts expire. Expect heavy volumes in the last hour.',
    why:'Traders square off or roll positions — sharp intraday volatility. Index moves of 0.5–1.5% near close are common.',
    market:'Heavy put OI → support tested. Heavy call OI → resistance capping. Watch for short-covering rallies.' },

  // ── July 2026 ──
  { date:'2026-07-10', event:'India IIP',              subtitle:'May 2026 data',      category:'Economy',    impact:'medium', tag:'economy',
    what:'Index of Industrial Production — measures output growth across mining, manufacturing, and electricity.',
    why:'Gauge of industrial health. Strong IIP means factories are busy, supporting employment and corporate earnings.',
    market:'IIP > 5% → capital goods, auto, power stocks positive. Miss → infra stocks under pressure.' },
  { date:'2026-07-14', event:'India CPI Inflation',    subtitle:'June 2026 data',     category:'Inflation',  impact:'high',   tag:'inflation',
    what:'Consumer Price Index for June 2026 — tracks retail price changes across urban and rural India.',
    why:'RBI\'s 4% target determines rate decisions → affects home, auto, and personal loan EMIs.',
    market:'CPI > 5% → rate cuts pushed out, Nifty dips. CPI < 4% → rate cut likely, broader market rally.' },
  { date:'2026-07-14', event:'India WPI Inflation',    subtitle:'June 2026 data',     category:'Inflation',  impact:'medium', tag:'inflation',
    what:'Wholesale Price Index for June 2026 — factory-gate price inflation.',
    why:'Persistently high WPI feeds into CPI 4–8 weeks later.',
    market:'Rising WPI → margin pressure for consumer companies. Falling WPI → positive for auto, FMCG, packaging.' },
  { date:'2026-07-30', event:'NSE F&O Monthly Expiry', subtitle:'July 2026',           category:'F&O Market', impact:'medium', tag:'market',
    what:'All July 2026 F&O contracts expire. High volatility expected in the final session.',
    why:'Positions worth thousands of crores roll over or get squared off, creating price swings.',
    market:'Watch Bank Nifty and Nifty 50 open interest the week before for likely support/resistance.' },

  // ── August 2026 ──
  { date:'2026-08-07', event:'RBI MPC Policy Decision',subtitle:'August 2026 meeting', category:'RBI Policy', impact:'high',   tag:'rbi',
    what:'RBI\'s Monetary Policy Committee announces the repo rate after a 3-day meeting.',
    why:'Single most important India market event. Rate cut = cheaper home, auto, business loans. Rate hike = tighter liquidity.',
    market:'Rate cut → Bank Nifty +1–3%, real estate surges, bond yields fall. Hold → defensives outperform, NBFCs fall.' },
  { date:'2026-08-12', event:'India CPI Inflation',    subtitle:'July 2026 data',     category:'Inflation',  impact:'high',   tag:'inflation',
    what:'July CPI — monsoon progress directly affects food prices (vegetables, pulses, cereals).',
    why:'Good monsoon → vegetable prices low. Deficit monsoon → food inflation spikes. RBI watches for October MPC.',
    market:'Food CPI surprise → RBI stays hawkish. Core CPI (ex food+fuel) = watch for "sticky inflation".' },
  { date:'2026-08-14', event:'India WPI Inflation',    subtitle:'July 2026 data',     category:'Inflation',  impact:'medium', tag:'inflation',
    what:'WPI for July — monsoon-sensitive commodities + crude oil price trends.',
    why:'Energy component tracks Brent crude. Reflects pass-through of monsoon into farm-gate prices.',
    market:'Rising WPI fuel → margin concerns for BPCL, IOC, HPCL, IndiGo.' },
  { date:'2026-08-27', event:'NSE F&O Monthly Expiry', subtitle:'August 2026',         category:'F&O Market', impact:'medium', tag:'market',
    what:'August 2026 F&O expiry. August historically sees higher volatility — the "August effect".',
    why:'Monsoon uncertainty + global risk-off events tend to coincide. VIX often elevated.',
    market:'VIX > 15 → elevated hedging. Watch Nifty options chain for large OI buildup 3–4 days before.' },
  { date:'2026-08-31', event:'India GDP Q1 FY27',      subtitle:'April–June 2026',    category:'GDP',        impact:'high',   tag:'gdp',
    what:'India\'s Q1 GDP growth rate for FY2026–27 — announced by Ministry of Statistics.',
    why:'Sets the tone for the entire fiscal year. India targeting 7%+ growth. Impacts FII flows and sovereign outlook.',
    market:'GDP > 7% → FII inflows, Nifty bullish, rupee strengthens. < 6.5% → growth stocks correct.' },

  // ── September 2026 ──
  { date:'2026-09-12', event:'India IIP',              subtitle:'July 2026 data',     category:'Economy',    impact:'medium', tag:'economy',
    what:'Industrial Production for July — post-monsoon industrial rebound.',
    why:'Strong auto + capital goods IIP confirms recovery after seasonal monsoon slowdown.',
    market:'Strong print → positive for Nifty Auto, L&T, ABB, Siemens. Weak → infra stocks under pressure.' },
  { date:'2026-09-14', event:'India CPI Inflation',    subtitle:'August 2026 data',   category:'Inflation',  impact:'high',   tag:'inflation',
    what:'August CPI — kharif harvest season means vegetable prices usually start easing.',
    why:'If food prices don\'t cool as expected, it\'s a red flag for RBI heading into October MPC.',
    market:'Easing food inflation → December rate cut window opens. Sticky food CPI → rate cut delayed to Feb 2027.' },
  { date:'2026-09-14', event:'India WPI Inflation',    subtitle:'August 2026 data',   category:'Inflation',  impact:'medium', tag:'inflation',
    what:'WPI for August — reflects post-monsoon commodity price trends.',
    why:'Fuel WPI tracks global crude with a lag. Manufactured goods reflect input cost trends.',
    market:'Crude > $90/bbl → WPI fuel elevated → OMCs, aviation under pressure.' },
  { date:'2026-09-24', event:'NSE F&O Monthly Expiry', subtitle:'September 2026 · Quarter End', category:'F&O Market', impact:'medium', tag:'market',
    what:'September F&O expiry — also end of Q2 FY27. Portfolio rebalancing by institutions.',
    why:'Quarter-end: mutual funds and insurance companies rebalance, creating above-average volumes.',
    market:'Quarter-end flows can push large-caps up (window dressing). Small-caps may lag.' },

  // ── October 2026 ──
  { date:'2026-10-10', event:'RBI MPC Policy Decision',subtitle:'October 2026 meeting', category:'RBI Policy', impact:'high',  tag:'rbi',
    what:'October MPC — RBI has full visibility: monsoon outcome, Q1 GDP, 6 months of inflation data.',
    why:'Rate cuts here take effect by Diwali — key for consumer sentiment. Most likely meeting for a cut.',
    market:'Rate cut → Diwali rally amplified, auto + housing surge. Hold → markets react to MPC tone.' },
  { date:'2026-10-12', event:'India IIP',              subtitle:'August 2026 data',   category:'Economy',    impact:'medium', tag:'economy',
    what:'Industrial production for August — festive season advance stocking and consumer goods production.',
    why:'Consumer durables sub-index = proxy for Diwali demand outlook.',
    market:'Strong consumer durables IIP → positive for FMCG, white goods, auto stocks.' },
  { date:'2026-10-13', event:'India CPI Inflation',    subtitle:'September 2026 · Pre-MPC', category:'Inflation',  impact:'high',   tag:'inflation',
    what:'September CPI — published just before October MPC. Most critical data point RBI uses for rate decision.',
    why:'This single number can swing the rate decision. September CPI captures post-monsoon food prices.',
    market:'CPI < 4.5% before MPC → near-certain rate cut. CPI > 5% → rate cut probability drops, bond yields spike.' },
  { date:'2026-10-14', event:'India WPI Inflation',    subtitle:'September 2026 data', category:'Inflation',  impact:'medium', tag:'inflation',
    what:'WPI for September — captures full monsoon pass-through into farm-gate prices.',
    why:'Fuel and manufactured products track global commodity cycles.',
    market:'Commodity prices in WPI affect input costs for auto, cement, steel, paints.' },
  { date:'2026-10-29', event:'NSE F&O Monthly Expiry', subtitle:'October 2026 · Diwali Season', category:'F&O Market', impact:'medium', tag:'market',
    what:'October F&O expiry. Typically coincides with Diwali — historically India\'s most bullish month.',
    why:'Festive sentiment + retail buying + Q2 result season can create a "Diwali rally".',
    market:'Watch for "Muhurat trading" — a special 1-hour session on Diwali day itself.' },

  // ── November 2026 ──
  { date:'2026-11-12', event:'India IIP',              subtitle:'September 2026 data', category:'Economy',    impact:'medium', tag:'economy',
    what:'Industrial Production for September — last data before Q2 GDP announcement.',
    why:'Strong September IIP often confirms Q2 GDP beat. Capital goods sub-index is key.',
    market:'Capital goods + consumer durables IIP → proxy for overall economic momentum.' },
  { date:'2026-11-12', event:'India CPI Inflation',    subtitle:'October 2026 data',  category:'Inflation',  impact:'high',   tag:'inflation',
    what:'October CPI — post-festive. Vegetable prices are highly seasonal in Oct-Nov.',
    why:'October CPI often surprises on upside due to vegetable spikes. RBI usually "looks through" seasonal food inflation.',
    market:'Core CPI (ex food + fuel) is the key watch metric for December MPC stance.' },
  { date:'2026-11-16', event:'India WPI Inflation',    subtitle:'October 2026 data',  category:'Inflation',  impact:'medium', tag:'inflation',
    what:'WPI for October — post-monsoon commodities, crude oil, manufactured goods inflation.',
    why:'Crude oil above $85 → inflation pressure on India (net importer), rupee weakens.',
    market:'Fuel WPI is the most volatile component. Watch Brent crude trend.' },
  { date:'2026-11-26', event:'NSE F&O Monthly Expiry', subtitle:'November 2026',       category:'F&O Market', impact:'medium', tag:'market',
    what:'November F&O expiry. Q2 earnings season wraps up around this time.',
    why:'FII selling ahead of US year-end vs. DII buying creates large divergence and volatility.',
    market:'Net FII selling > ₹5,000 Cr/week in November = caution signal.' },
  { date:'2026-11-30', event:'India GDP Q2 FY27',      subtitle:'July–September 2026', category:'GDP',        impact:'high',   tag:'gdp',
    what:'Q2 GDP for FY2026–27 — captures peak kharif harvest, festive demand, post-monsoon activity.',
    why:'Strong Q2 (>7%) raises chances of full-year 7%+ growth — major positive for FII flows.',
    market:'GDP beat → India macro narrative strengthens. GDP miss → govt capex expected to compensate.' },

  // ── December 2026 ──
  { date:'2026-12-05', event:'RBI MPC Policy Decision',subtitle:'December 2026 · Last MPC of 2026', category:'RBI Policy', impact:'high', tag:'rbi',
    what:'December MPC — last policy meeting of 2026. Sets rate environment for the new year.',
    why:'With Q2 GDP and October CPI in hand, RBI has full visibility. Rate cut here triggers year-end FII inflows.',
    market:'Dec rate cut → year-end rally, banking surges, real estate re-rates. Hold → markets look to Feb budget.' },
  { date:'2026-12-12', event:'India IIP',              subtitle:'October 2026 data',  category:'Economy',    impact:'medium', tag:'economy',
    what:'Industrial Production for October — Diwali demand and production burst captured here.',
    why:'High October IIP confirms festive season momentum: auto dispatches, electronics, steel.',
    market:'Strong IIP → positive for auto, consumer durables, capital goods.' },
  { date:'2026-12-14', event:'India CPI Inflation',    subtitle:'November 2026 data', category:'Inflation',  impact:'high',   tag:'inflation',
    what:'November CPI — post-festive, pre-winter. Rabi sowing begins, food prices start stabilising.',
    why:'If core CPI is falling, RBI gets room for cuts in 2027.',
    market:'Nov CPI < 4.5% → Feb 2027 rate cut near-certain. Markets may pre-price cuts.' },
  { date:'2026-12-14', event:'India WPI Inflation',    subtitle:'November 2026 data', category:'Inflation',  impact:'medium', tag:'inflation',
    what:'WPI for November — winter months usually see lower vegetable WPI.',
    why:'Global crude trends dominate the fuel component — key for India\'s import bill.',
    market:'WPI fuel deflation → positive for OMCs and aviation.' },
  { date:'2026-12-31', event:'NSE F&O Monthly Expiry', subtitle:'December 2026 · Year End', category:'F&O Market', impact:'high', tag:'market',
    what:'December F&O expiry — last trading session of the year. Coincides with Nifty 50 annual review.',
    why:'Year-end: FII book closure, mutual fund window dressing, position squaring. Most volatile expiry.',
    market:'January effect: fresh money flows first week of Jan — small and mid-caps often lead.' },
];

// ── State ─────────────────────────────────────────────────────────────────────
let activeFilter  = 'all';
let showPast      = false;
let expandedDate  = null;
const today       = new Date().toISOString().split('T')[0];

function isPast(d)  { return d < today; }
function isToday(d) { return d === today; }

function daysUntil(d) {
  return Math.round((new Date(d) - new Date(today)) / 86400000);
}

const IMPACT_COLOR = { high:'#ef4444', medium:'#f59e0b', low:'#22c55e' };
const IMPACT_BG    = { high:'rgba(239,68,68,0.12)', medium:'rgba(245,158,11,0.12)', low:'rgba(34,197,94,0.12)' };
const CAT_ICON     = { 'RBI Policy':'🏦', 'Inflation':'📊', 'GDP':'📈', 'F&O Market':'📅', 'Economy':'🏭' };

function impactPill(impact) {
  const c  = IMPACT_COLOR[impact] || '#7a8899';
  const bg = IMPACT_BG[impact]    || 'rgba(122,136,153,0.1)';
  return `<span style="background:${bg};color:${c};border:1px solid ${c}44;font-size:9px;font-weight:800;letter-spacing:0.6px;padding:3px 8px;border-radius:20px;white-space:nowrap">${impact.toUpperCase()}</span>`;
}

function whenBadge(dateStr) {
  if (isToday(dateStr)) return `<span style="background:rgba(212,169,64,0.15);color:var(--gold);border:1px solid rgba(212,169,64,0.4);font-size:9px;font-weight:800;padding:3px 8px;border-radius:20px">TODAY</span>`;
  if (isPast(dateStr))  return `<span style="color:var(--text-muted);font-size:11px">${Math.abs(daysUntil(dateStr))}d ago</span>`;
  const d = daysUntil(dateStr);
  if (d <= 7)  return `<span style="background:rgba(239,68,68,0.1);color:#ef4444;border:1px solid rgba(239,68,68,0.3);font-size:9px;font-weight:800;padding:3px 8px;border-radius:20px">In ${d}d</span>`;
  if (d <= 30) return `<span style="background:rgba(245,158,11,0.1);color:#f59e0b;border:1px solid rgba(245,158,11,0.3);font-size:9px;font-weight:800;padding:3px 8px;border-radius:20px">In ${d}d</span>`;
  return `<span style="color:var(--text-muted);font-size:11px">In ${d}d</span>`;
}

function render() {
  let filtered = activeFilter === 'all'
    ? EVENTS
    : EVENTS.filter(e => e.impact === activeFilter || e.tag === activeFilter);

  if (!showPast) filtered = filtered.filter(e => !isPast(e.date) || isToday(e.date));

  const tbody  = document.getElementById('econTableBody');
  const empty  = document.getElementById('econEmpty');
  const detail = document.getElementById('econDetail');

  if (!filtered.length) {
    tbody.innerHTML = '';
    empty.style.display  = 'block';
    detail.style.display = 'none';
    return;
  }
  empty.style.display = 'none';

  // Group by month for section rows
  let lastMonth = '';
  tbody.innerHTML = filtered.map(e => {
    const d        = new Date(e.date + 'T00:00:00');
    const month    = d.toLocaleDateString('en-IN', { month:'long', year:'numeric' });
    const dayNum   = d.getDate();
    const monShort = d.toLocaleDateString('en-IN', { month:'short' });
    const wday     = d.toLocaleDateString('en-IN', { weekday:'short' });
    const past     = isPast(e.date);
    const todayEvt = isToday(e.date);
    const isExp    = expandedDate === e.date + '::' + e.event;
    const icon     = CAT_ICON[e.category] || '📌';
    const borderColor = IMPACT_COLOR[e.impact] || '#7a8899';

    let monthRow = '';
    if (month !== lastMonth) {
      lastMonth = month;
      monthRow = `<tr class="ec-month-row"><td colspan="5">${month}</td></tr>`;
    }

    return monthRow + `
      <tr class="ec-row ${past ? 'ec-past' : ''} ${todayEvt ? 'ec-today' : ''} ${isExp ? 'ec-expanded' : ''}"
          style="border-left:3px solid ${borderColor}"
          onclick="toggleRow('${e.date}::${e.event.replace(/'/g,"\\'")}')">
        <td class="ec-td-date">
          <span class="ec-day">${dayNum}</span>
          <span class="ec-mon">${monShort}</span>
          <span class="ec-wday">${wday}</span>
        </td>
        <td class="ec-td-event">
          <div class="ec-event-name">${e.event}</div>
          <div class="ec-event-sub">${e.subtitle}</div>
        </td>
        <td class="ec-td-cat">
          <span class="ec-cat-chip">${icon} ${e.category}</span>
        </td>
        <td class="ec-td-impact">${impactPill(e.impact)}</td>
        <td class="ec-td-when">
          ${whenBadge(e.date)}
          <span class="ec-chevron ${isExp ? 'open' : ''}">›</span>
        </td>
      </tr>
      ${isExp ? `
      <tr class="ec-detail-row">
        <td colspan="5">
          <div class="ec-detail-inner">
            <div class="ec-detail-block">
              <div class="ec-detail-lbl">📌 What is it?</div>
              <div class="ec-detail-txt">${e.what}</div>
            </div>
            <div class="ec-detail-block">
              <div class="ec-detail-lbl">💡 Why it matters</div>
              <div class="ec-detail-txt">${e.why}</div>
            </div>
            <div class="ec-detail-block">
              <div class="ec-detail-lbl">📈 Market impact</div>
              <div class="ec-detail-txt">${e.market}</div>
            </div>
          </div>
        </td>
      </tr>` : ''}`;
  }).join('');

  // Hide the old standalone detail panel (not used anymore)
  detail.style.display = 'none';
}

function toggleRow(key) {
  expandedDate = expandedDate === key ? null : key;
  render();
}
window.toggleRow = toggleRow;

document.querySelectorAll('.econ-filter').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.econ-filter').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeFilter = btn.dataset.filter;
    expandedDate = null;
    render();
  });
});

document.getElementById('showPast').addEventListener('change', e => {
  showPast = (e.target as HTMLInputElement).checked;
  render();
});

render();
</script>

<style>
/* Controls */
.ec-controls {
  display:flex; justify-content:space-between; align-items:center;
  gap:12px; flex-wrap:wrap; margin-bottom:20px;
}
.econ-filters { display:flex; gap:6px; flex-wrap:wrap; }
.econ-filter  {
  padding:5px 13px; border-radius:20px; border:1px solid var(--border);
  background:transparent; color:var(--text-muted); font-size:11px; font-weight:600;
  cursor:pointer; transition:all 0.2s; white-space:nowrap;
}
.econ-filter.active, .econ-filter:hover {
  background:var(--gold); color:#000; border-color:var(--gold);
}
.legend-toggle {
  display:flex; align-items:center; gap:6px; cursor:pointer;
  font-size:12px; color:var(--text-muted); white-space:nowrap;
}
.legend-toggle input { cursor:pointer; accent-color:var(--gold); }

/* Table */
.ec-table-wrap { overflow-x:auto; border-radius:12px; border:1px solid var(--border); }
.ec-table { width:100%; border-collapse:collapse; }

/* Month header rows */
.ec-month-row td {
  background:rgba(212,169,64,0.06); color:var(--gold);
  font-size:10px; font-weight:800; letter-spacing:1px; text-transform:uppercase;
  padding:10px 16px; border-bottom:1px solid var(--border); border-top:1px solid var(--border);
}

/* Table header */
.ec-table thead th {
  background:rgba(255,255,255,0.03); color:var(--text-muted);
  font-size:10px; font-weight:700; letter-spacing:0.5px; text-transform:uppercase;
  padding:10px 14px; text-align:left; border-bottom:1px solid var(--border);
}

/* Data rows */
.ec-row {
  cursor:pointer; border-bottom:1px solid rgba(255,255,255,0.04);
  transition:background 0.15s;
}
.ec-row:hover    { background:rgba(212,169,64,0.04); }
.ec-row.ec-past  { opacity:0.4; }
.ec-row.ec-today { background:rgba(212,169,64,0.05); }
.ec-row.ec-expanded { background:rgba(212,169,64,0.04); border-bottom:none; }

/* Date cell */
.ec-td-date {
  padding:12px 14px; white-space:nowrap; vertical-align:middle;
  border-left-width:3px; border-left-style:solid;
}
.ec-row td:first-child { border-left:inherit; }
.ec-day   { font-size:16px; font-weight:800; color:#fff; display:block; line-height:1.1; }
.ec-mon   { font-size:10px; color:var(--gold); font-weight:700; display:block; text-transform:uppercase; }
.ec-wday  { font-size:9px; color:var(--text-muted); display:block; }

/* Event cell */
.ec-td-event    { padding:12px 14px; vertical-align:middle; }
.ec-event-name  { font-size:13px; font-weight:700; color:#fff; margin-bottom:2px; }
.ec-event-sub   { font-size:11px; color:var(--text-muted); }

/* Category cell */
.ec-td-cat { padding:12px 14px; vertical-align:middle; }
.ec-cat-chip {
  font-size:10px; font-weight:600; color:var(--text-muted);
  background:rgba(255,255,255,0.05); border:1px solid var(--border);
  padding:3px 8px; border-radius:20px; white-space:nowrap;
}

/* Impact cell */
.ec-td-impact { padding:12px 14px; vertical-align:middle; }

/* When cell */
.ec-td-when {
  padding:12px 14px; vertical-align:middle;
  display:flex; align-items:center; gap:8px; white-space:nowrap;
}
.ec-chevron {
  font-size:18px; color:var(--text-muted); transition:transform 0.2s; flex-shrink:0;
}
.ec-chevron.open { transform:rotate(90deg); color:var(--gold); }

/* Detail row */
.ec-detail-row td { padding:0 16px 16px 16px; border-bottom:1px solid var(--border); }
.ec-detail-inner {
