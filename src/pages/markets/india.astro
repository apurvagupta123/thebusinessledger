---
import BaseLayout from '../../layouts/BaseLayout.astro';

const NSE_STOCKS = [
  { sym: 'RELIANCE.NS',    name: 'Reliance Industries' },
  { sym: 'TCS.NS',         name: 'Tata Consultancy Services' },
  { sym: 'HDFCBANK.NS',    name: 'HDFC Bank' },
  { sym: 'INFY.NS',        name: 'Infosys' },
  { sym: 'ICICIBANK.NS',   name: 'ICICI Bank' },
  { sym: 'HINDUNILVR.NS',  name: 'Hindustan Unilever' },
  { sym: 'BAJFINANCE.NS',  name: 'Bajaj Finance' },
  { sym: 'KOTAKBANK.NS',   name: 'Kotak Mahindra Bank' },
  { sym: 'LT.NS',          name: 'Larsen & Toubro' },
  { sym: 'SBIN.NS',        name: 'State Bank of India' },
  { sym: 'WIPRO.NS',       name: 'Wipro' },
  { sym: 'TMCV.NS',        name: 'Tata Motors (CV)' },
  { sym: 'BHARTIARTL.NS',  name: 'Bharti Airtel' },
  { sym: 'MARUTI.NS',      name: 'Maruti Suzuki' },
  { sym: 'ADANIENT.NS',    name: 'Adani Enterprises' },
];

const BSE_STOCKS = [
  { sym: 'RELIANCE.BO',   name: 'Reliance Industries' },
  { sym: 'TCS.BO',        name: 'Tata Consultancy Services' },
  { sym: 'HDFCBANK.BO',   name: 'HDFC Bank' },
  { sym: 'INFY.BO',       name: 'Infosys' },
  { sym: 'ICICIBANK.BO',  name: 'ICICI Bank' },
  { sym: 'TATASTEEL.BO',  name: 'Tata Steel' },
  { sym: 'SUNPHARMA.BO',  name: 'Sun Pharmaceutical' },
  { sym: 'ONGC.BO',       name: 'ONGC' },
  { sym: 'BAJAJFINSV.BO', name: 'Bajaj Finserv' },
  { sym: 'POWERGRID.BO',  name: 'Power Grid Corp' },
];
---
<BaseLayout title="India Markets — NSE & BSE">

  <section class="content-section" style="margin-top:48px">
    <div class="sector-hero" style="background:linear-gradient(135deg,rgba(255,153,0,0.12),rgba(19,136,8,0.10))">
      <div class="sh-icon">🇮🇳</div>
      <div>
        <h1 class="sh-title">India Markets</h1>
        <p class="sh-sub">NSE & BSE — live data via Yahoo Finance</p>
      </div>
      <div class="sh-perf">
        <span class="shp-label">NIFTY 50 TODAY</span>
        <span class="shp-val" id="niftyChg">Loading…</span>
        <span style="font-size:10px;color:var(--text-muted);margin-top:4px" id="dataAge"></span>
      </div>
    </div>

    <!-- Indices Bar -->
    <div class="indices-grid" style="margin-top:24px" id="indiaIndices">
      <div class="idx-card skeleton" id="idx-NSEI">
        <span class="idx-name">NIFTY 50</span>
        <span class="idx-price" id="nsei-price">—</span>
        <span class="idx-chg"   id="nsei-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="idx-BSESN">
        <span class="idx-name">SENSEX</span>
        <span class="idx-price" id="bsesn-price">—</span>
        <span class="idx-chg"   id="bsesn-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="idx-NSEBANK">
        <span class="idx-name">NIFTY BANK</span>
        <span class="idx-price" id="nsebank-price">—</span>
        <span class="idx-chg"   id="nsebank-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="idx-NIFTYMIDCAP">
        <span class="idx-name">NIFTY MIDCAP</span>
        <span class="idx-price" id="mid-price">—</span>
        <span class="idx-chg"   id="mid-chg">—</span>
      </div>
    </div>
  </section>

  <!-- NSE Stocks -->
  <section class="content-section" style="margin-top:32px">
    <div class="section-head">
      <h2 class="section-title">NSE Top Stocks</h2>
      <span class="section-live">NSE</span>
    </div>
    <div class="in-table-head">
      <span>Stock</span>
      <span style="text-align:right">Price</span>
      <span style="text-align:right">Change</span>
      <span style="text-align:right">% Change</span>
    </div>
    <div class="in-table" id="nseGrid">
      {NSE_STOCKS.map(s => (
        <a class="in-row" id={`sc-${s.sym}`} href={`/company/${s.sym.toLowerCase().replace('.','_')}`}>
          <div class="in-row-sym">
            <span class="in-sym">{s.sym.replace('.NS','')}</span>
            <span class="in-name">{s.name}</span>
          </div>
          <div class="in-price" id={`scp-${s.sym}`}>—</div>
          <div class="in-chg"   id={`scc-${s.sym}`}>—</div>
          <div class="in-pct">
            <span class="mkt-badge" id={`scb-${s.sym}`}>—</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- BSE Stocks -->
  <section class="content-section" style="margin-top:32px">
    <div class="section-head">
      <h2 class="section-title">BSE Top Stocks</h2>
      <span class="section-live">BSE</span>
    </div>
    <div class="in-table-head">
      <span>Stock</span>
      <span style="text-align:right">Price</span>
      <span style="text-align:right">Change</span>
      <span style="text-align:right">% Change</span>
    </div>
    <div class="in-table" id="bseGrid">
      {BSE_STOCKS.map(s => (
        <a class="in-row" id={`sc-${s.sym}`} href={`/company/${s.sym.toLowerCase().replace('.','_')}`}>
          <div class="in-row-sym">
            <span class="in-sym">{s.sym.replace('.BO','')}</span>
            <span class="in-name">{s.name}</span>
          </div>
          <div class="in-price" id={`scp-${s.sym}`}>—</div>
          <div class="in-chg"   id={`scc-${s.sym}`}>—</div>
          <div class="in-pct">
            <span class="mkt-badge" id={`scb-${s.sym}`}>—</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Other Markets -->
  <section class="content-section" style="margin-top:48px">
    <div class="section-head">
      <h2 class="section-title">Other Markets</h2>
    </div>
    <div class="sector-pills">
      <a href="/markets/tech"    class="sector-pill">💻 US Tech</a>
      <a href="/markets/finance" class="sector-pill">💰 US Finance</a>
    </div>
  </section>

</BaseLayout>

<script>
  // ── Load from pre-fetched JSON (updated daily by GitHub Actions) ──
  async function loadData() {
    try {
      const [stocksRes, idxRes] = await Promise.all([
        fetch('/data/india-stocks.json'),
        fetch('/data/india-indices.json'),
      ]);
      const stocks = await stocksRes.json();
      const idxData = await idxRes.json();

      // Show last-updated time
      if (stocks.lastUpdated) {
        const d = new Date(stocks.lastUpdated);
        const timeStr = d.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Kolkata' });
        const dateStr = d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', timeZone: 'Asia/Kolkata' });
        const el = document.getElementById('dataAge');
        if (el) el.textContent = `Data as of ${timeStr} IST, ${dateStr}`;
      }

      // Render indices
      const idxKeyMap = {'^NSEI':'nsei','^BSESN':'bsesn','^NSEBANK':'nsebank','^CNXMIDCAP':'mid'};
      idxData.indices.forEach(q => {
        if (!q.regularMarketPrice) return;
        const chg = q.regularMarketChange ?? 0;
        const pct = q.regularMarketChangePercent ?? 0;
        const up  = chg >= 0;
        const key = idxKeyMap[q.symbol];
        if (!key) return;
        const card = document.getElementById(`idx-${q.symbol.replace('^','')}`);
        if (card) { card.classList.remove('skeleton'); card.classList.add(up ? 'up' : 'dn'); }
        const pEl = document.getElementById(`${key}-price`);
        if (pEl) pEl.textContent = q.regularMarketPrice.toLocaleString('en-IN', { maximumFractionDigits: 2 });
        const cEl = document.getElementById(`${key}-chg`);
        if (cEl) { cEl.textContent = `${up?'▲':'▼'} ${Math.abs(pct).toFixed(2)}%`; cEl.style.color = up ? '#22c55e' : '#ef4444'; }
      });

      // NIFTY hero badge
      const nifty = idxData.indices.find(q => q.symbol === '^NSEI');
      if (nifty) {
        const pct = nifty.regularMarketChangePercent ?? 0;
        const up  = pct >= 0;
        const el  = document.getElementById('niftyChg');
        if (el) { el.textContent = `${up?'+':''}${pct.toFixed(2)}%`; el.style.color = up ? '#22c55e' : '#ef4444'; }
      }

      // Render stock rows (NSE + BSE combined)
      const allStocks = [...(stocks.nse || []), ...(stocks.bse || [])];
      allStocks.forEach(q => {
        if (!q.regularMarketPrice) return;
        const chg = q.regularMarketChange ?? 0;
        const pct = q.regularMarketChangePercent ?? 0;
        const up  = chg >= 0;
        const color = up ? '#22c55e' : '#ef4444';
        const row = document.getElementById(`sc-${q.symbol}`);
        if (row) row.classList.add(up ? 'up' : 'dn');
        const bEl = document.getElementById(`scb-${q.symbol}`);
        if (bEl) { bEl.textContent = `${up?'+':''}${pct.toFixed(2)}%`; bEl.classList.add(up ? 'badge-up' : 'badge-dn'); }
        const pEl = document.getElementById(`scp-${q.symbol}`);
        if (pEl) pEl.textContent = `₹${q.regularMarketPrice.toFixed(2)}`;
        const cEl = document.getElementById(`scc-${q.symbol}`);
        if (cEl) { cEl.textContent = `${up?'▲':'▼'} ₹${Math.abs(chg).toFixed(2)}`; (cEl as HTMLElement).style.color = color; }
      });

    } catch (e) {
      console.error('Failed to load market data:', e);
    }
  }

  loadData();
</script>

<style is:global>
/* ── India markets row table ──────────────────────────── */
.in-table-head {
  display: grid;
  grid-template-columns: 2fr 110px 150px 80px;
  gap: 0 16px;
  padding: 6px 16px;
  font-size: 10px;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.8px;
}
.in-table {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.in-row {
  display: grid;
  grid-template-columns: 2fr 110px 150px 80px;
  gap: 0 16px;
  align-items: center;
  padding: 12px 16px;
  background: var(--navy-2);
  border: 1px solid var(--border);
  border-left: 3px solid transparent;
  border-radius: 8px;
  text-decoration: none;
  transition: background 0.15s, border-color 0.15s;
}
.in-row:hover { background: var(--navy-3); border-color: rgba(201,168,76,0.3); }
.in-row.up { border-left-color: #22c55e; }
.in-row.dn { border-left-color: #ef4444; }
.in-row-sym { display: flex; align-items: baseline; gap: 10px; min-width: 0; }
.in-sym { font-size: 14px; font-weight: 800; color: #fff; flex-shrink: 0; letter-spacing: 0.3px; }
.in-name { font-size: 12px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.in-price { font-size: 14px; font-weight: 700; color: #fff; text-align: right; }
.in-chg { font-size: 12px; font-weight: 600; text-align: right; }
.in-pct { text-align: right; }
/* Shimmer while loading */
.in-row:not(.up):not(.dn) .in-price,
.in-row:not(.up):not(.dn) .in-chg,
.in-row:not(.up):not(.dn) .mkt-badge {
  background: linear-gradient(90deg,rgba(255,255,255,.05) 25%,rgba(255,255,255,.12) 50%,rgba(255,255,255,.05) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 4px;
  color: transparent !important;
  min-width: 50px;
  min-height: 13px;
  display: inline-block;
}
@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
.mkt-badge { font-size: 10px; font-weight: 700; padding: 3px 7px; border-radius: 5px; display: inline-block; }
.badge-up { background: rgba(34,197,94,0.15); color: #22c55e; }
.badge-dn { background: rgba(239,68,68,0.15); color: #ef4444; }
@media (max-width: 700px) {
  .in-table-head { grid-template-columns: 2fr 90px 90px; }
  .in-table-head span:last-child { display: none; }
  .in-row { grid-template-columns: 2fr 90px 90px; }
  .in-pct { display: none; }
}
</style>
