---
import BaseLayout from '../../layouts/BaseLayout.astro';

const NSE_STOCKS = [
  // ── Large Cap ──────────────────────────────────────────
  { sym: 'RELIANCE.NS',    name: 'Reliance Industries' },
  { sym: 'TCS.NS',         name: 'Tata Consultancy Services' },
  { sym: 'HDFCBANK.NS',    name: 'HDFC Bank' },
  { sym: 'INFY.NS',        name: 'Infosys' },
  { sym: 'ICICIBANK.NS',   name: 'ICICI Bank' },
  { sym: 'HINDUNILVR.NS',  name: 'Hindustan Unilever' },
  { sym: 'BAJFINANCE.NS',  name: 'Bajaj Finance' },
  { sym: 'KOTAKBANK.NS',   name: 'Kotak Mahindra Bank' },
  { sym: 'LT.NS',          name: 'Larsen & Toubro' },
  { sym: 'SBIN.NS',        name: 'State Bank of India' },
  { sym: 'WIPRO.NS',       name: 'Wipro' },
  { sym: 'TECHM.NS',       name: 'Tech Mahindra' },
  { sym: 'BHARTIARTL.NS',  name: 'Bharti Airtel' },
  { sym: 'MARUTI.NS',      name: 'Maruti Suzuki' },
  { sym: 'ADANIENT.NS',    name: 'Adani Enterprises' },
  { sym: 'HCLTECH.NS',     name: 'HCL Technologies' },
  { sym: 'TITAN.NS',       name: 'Titan Company' },
  { sym: 'ASIANPAINT.NS',  name: 'Asian Paints' },
  // ── Mid Cap ────────────────────────────────────────────
  { sym: 'PERSISTENT.NS',  name: 'Persistent Systems' },
  { sym: 'POLYCAB.NS',     name: 'Polycab India' },
  { sym: 'MPHASIS.NS',     name: 'Mphasis' },
  { sym: 'DIXON.NS',       name: 'Dixon Technologies' },
  { sym: 'COFORGE.NS',     name: 'Coforge' },
  // ── Small Cap ──────────────────────────────────────────
  { sym: 'LATENTVIEW.NS',  name: 'LatentView Analytics' },
  { sym: 'KAYNES.NS',      name: 'Kaynes Technology' },
  { sym: 'BIKAJI.NS',      name: 'Bikaji Foods' },
  { sym: 'IRCTC.NS',       name: 'IRCTC' },
  { sym: 'CAMPUS.NS',      name: 'Campus Activewear' },
];

const BSE_STOCKS = [
  { sym: 'RELIANCE.BO',   name: 'Reliance Industries' },
  { sym: 'TCS.BO',        name: 'Tata Consultancy Services' },
  { sym: 'HDFCBANK.BO',   name: 'HDFC Bank' },
  { sym: 'INFY.BO',       name: 'Infosys' },
  { sym: 'ICICIBANK.BO',  name: 'ICICI Bank' },
  { sym: 'TATASTEEL.BO',  name: 'Tata Steel' },
  { sym: 'SUNPHARMA.BO',  name: 'Sun Pharmaceutical' },
  { sym: 'ONGC.BO',       name: 'ONGC' },
  { sym: 'BAJAJFINSV.BO', name: 'Bajaj Finserv' },
  { sym: 'POWERGRID.BO',  name: 'Power Grid Corp' },
];
---
<BaseLayout title="India Markets — NSE & BSE">

  <section class="content-section" style="margin-top:48px">
    <div class="sector-hero" style="background:linear-gradient(135deg,rgba(255,153,0,0.12),rgba(19,136,8,0.10))">
      <div class="sh-icon">🇮🇳</div>
      <div>
        <h1 class="sh-title">India Markets</h1>
        <p class="sh-sub">NSE & BSE — updated twice daily via Yahoo Finance</p>
      </div>
      <div class="sh-perf">
        <span class="shp-label">NIFTY 50 TODAY</span>
        <span class="shp-val" id="niftyChg">Loading…</span>
        <span style="font-size:10px;color:var(--text-muted);margin-top:4px" id="dataAge"></span>
      </div>
    </div>

    <!-- Indices Bar -->
    <div class="indices-grid" style="margin-top:24px" id="indiaIndices">
      <div class="idx-card skeleton idx-clickable" id="idx-NSEI" data-idx="NSEI">
        <span class="idx-name">NIFTY 50</span>
        <span class="idx-price" id="nsei-price">—</span>
        <span class="idx-chg"   id="nsei-chg">—</span>
        <span class="idx-tap-hint">tap for details</span>
      </div>
      <div class="idx-card skeleton idx-clickable" id="idx-BSESN" data-idx="BSESN">
        <span class="idx-name">SENSEX</span>
        <span class="idx-price" id="bsesn-price">—</span>
        <span class="idx-chg"   id="bsesn-chg">—</span>
        <span class="idx-tap-hint">tap for details</span>
      </div>
      <div class="idx-card skeleton idx-clickable" id="idx-NSEBANK" data-idx="NSEBANK">
        <span class="idx-name">NIFTY BANK</span>
        <span class="idx-price" id="nsebank-price">—</span>
        <span class="idx-chg"   id="nsebank-chg">—</span>
        <span class="idx-tap-hint">tap for details</span>
      </div>
      <div class="idx-card skeleton idx-clickable" id="idx-NIFTYMIDCAP" data-idx="NIFTYMIDCAP">
        <span class="idx-name">SMALLCAP</span>
        <span class="idx-price" id="mid-price">—</span>
        <span class="idx-chg"   id="mid-chg">—</span>
        <span class="idx-tap-hint">tap for details</span>
      </div>
    </div>
  </section>

  <!-- Index Detail Modal -->
  <div id="idxModal" style="display:none;position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px);padding:20px;overflow-y:auto" onclick="if(event.target===this)this.style.display='none'">
    <div id="idxModalBox" style="max-width:640px;margin:60px auto;background:linear-gradient(135deg,rgba(212,169,64,0.13) 0%,rgba(26,21,9,0.98) 60%);border:1px solid rgba(212,169,64,0.35);border-radius:18px;padding:32px 36px;position:relative">
      <button onclick="document.getElementById('idxModal').style.display='none'" style="position:absolute;top:16px;right:18px;background:rgba(212,169,64,0.12);border:1px solid rgba(212,169,64,0.25);color:var(--gold);border-radius:8px;padding:4px 12px;font-size:13px;cursor:pointer">✕ Close</button>
      <div id="idxModalContent"></div>
    </div>
  </div>

  <!-- NSE Stocks -->
  <section class="content-section" style="margin-top:32px">
    <div class="section-head">
      <h2 class="section-title">NSE Top Stocks</h2>
      <span class="section-live">NSE</span>
    </div>
    <div class="in-table-head">
      <span>Stock</span>
      <span style="text-align:right">Price</span>
      <span style="text-align:right">Change</span>
      <span style="text-align:right">% Change</span>
    </div>
    <div class="in-table" id="nseGrid">
      {NSE_STOCKS.map(s => (
        <a class="in-row" id={`sc-${s.sym}`} href={`/company/${s.sym.toLowerCase().replace('.','_')}`}>
          <div class="in-row-sym">
            <span class="in-sym">{s.sym.replace('.NS','')}</span>
            <span class="in-name">{s.name}</span>
          </div>
          <div class="in-price" id={`scp-${s.sym}`}>—</div>
          <div class="in-chg"   id={`scc-${s.sym}`}>—</div>
          <div class="in-pct">
            <span class="mkt-badge" id={`scb-${s.sym}`}>—</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- BSE Stocks -->
  <section class="content-section" style="margin-top:32px">
    <div class="section-head">
      <h2 class="section-title">BSE Top Stocks</h2>
      <span class="section-live">BSE</span>
    </div>
    <div class="in-table-head">
      <span>Stock</span>
      <span style="text-align:right">Price</span>
      <span style="text-align:right">Change</span>
      <span style="text-align:right">% Change</span>
    </div>
    <div class="in-table" id="bseGrid">
      {BSE_STOCKS.map(s => (
        <a class="in-row" id={`sc-${s.sym}`} href={`/company/${s.sym.toLowerCase().replace('.','_')}`}>
          <div class="in-row-sym">
            <span class="in-sym">{s.sym.replace('.BO','')}</span>
            <span class="in-name">{s.name}</span>
          </div>
          <div class="in-price" id={`scp-${s.sym}`}>—</div>
          <div class="in-chg"   id={`scc-${s.sym}`}>—</div>
          <div class="in-pct">
            <span class="mkt-badge" id={`scb-${s.sym}`}>—</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Other Markets -->
  <section class="content-section" style="margin-top:48px">
    <div class="section-head">
      <h2 class="section-title">Other Markets</h2>
    </div>
    <div class="sector-pills">
      <a href="/markets/tech"    class="sector-pill">💻 US Tech</a>
      <a href="/markets/finance" class="sector-pill">💰 US Finance</a>
    </div>
  </section>

</BaseLayout>

<script>
  // ── Load from pre-fetched JSON (updated daily by GitHub Actions) ──
  async function loadData() {
    try {
      const [stocksRes, idxRes] = await Promise.all([
        fetch('/data/india-stocks.json'),
        fetch('/data/india-indices.json'),
      ]);
      const stocks = await stocksRes.json();
      const idxData = await idxRes.json();

      // Show last-updated time
      if (stocks.lastUpdated) {
        const d = new Date(stocks.lastUpdated);
        const timeStr = d.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Kolkata' });
        const dateStr = d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', timeZone: 'Asia/Kolkata' });
        const el = document.getElementById('dataAge');
        if (el) el.textContent = `Data as of ${timeStr} IST, ${dateStr}`;
      }

      // Render indices
      const idxKeyMap = {'^NSEI':'nsei','^BSESN':'bsesn','^NSEBANK':'nsebank','^CNXMIDCAP':'mid'};
      idxData.indices.forEach(q => {
        if (!q.regularMarketPrice) return;
        const chg = q.regularMarketChange ?? 0;
        const pct = q.regularMarketChangePercent ?? 0;
        const up  = chg >= 0;
        const key = idxKeyMap[q.symbol];
        if (!key) return;
        const idxKey = q.symbol.replace('^','');
        _idxLiveData[idxKey] = {price: q.regularMarketPrice, chg, pct, high52: q.fiftyTwoWeekHigh, low52: q.fiftyTwoWeekLow};
        const card = document.getElementById(`idx-${idxKey}`);
        if (card) { card.classList.remove('skeleton'); card.classList.add(up ? 'up' : 'dn'); }
        const pEl = document.getElementById(`${key}-price`);
        if (pEl) pEl.textContent = q.regularMarketPrice.toLocaleString('en-IN', { maximumFractionDigits: 2 });
        const cEl = document.getElementById(`${key}-chg`);
        if (cEl) { cEl.textContent = `${up?'▲':'▼'} ${Math.abs(pct).toFixed(2)}%`; cEl.style.color = up ? '#22c55e' : '#ef4444'; }
      });

      // NIFTY hero badge
      const nifty = idxData.indices.find(q => q.symbol === '^NSEI');
      if (nifty) {
        const pct = nifty.regularMarketChangePercent ?? 0;
        const up  = pct >= 0;
        const el  = document.getElementById('niftyChg');
        if (el) { el.textContent = `${up?'+':''}${pct.toFixed(2)}%`; el.style.color = up ? '#22c55e' : '#ef4444'; }
      }

      // Render stock rows (NSE + BSE combined)
      const allStocks = [...(stocks.nse || []), ...(stocks.bse || [])];
      allStocks.forEach(q => {
        if (!q.regularMarketPrice) return;
        const chg = q.regularMarketChange ?? 0;
        const pct = q.regularMarketChangePercent ?? 0;
        const up  = chg >= 0;
        const color = up ? '#22c55e' : '#ef4444';
        const row = document.getElementById(`sc-${q.symbol}`);
        if (row) row.classList.add(up ? 'up' : 'dn');
        const bEl = document.getElementById(`scb-${q.symbol}`);
        if (bEl) { bEl.textContent = `${up?'+':''}${pct.toFixed(2)}%`; bEl.classList.add(up ? 'badge-up' : 'badge-dn'); }
        const pEl = document.getElementById(`scp-${q.symbol}`);
        if (pEl) pEl.textContent = `₹${q.regularMarketPrice.toFixed(2)}`;
        const cEl = document.getElementById(`scc-${q.symbol}`);
        if (cEl) { cEl.textContent = `${up?'▲':'▼'} ₹${Math.abs(chg).toFixed(2)}`; (cEl as HTMLElement).style.color = color; }
      });

    } catch (e) {
      console.error('Failed to load market data:', e);
    }
  }

  // ── Index detail explainer data ───────────────────────
  const IDX_INFO: Record<string,{title:string,icon:string,what:string,who:string,why:string,movers:string,sip:string}> = {
    NSEI: {
      title:'NIFTY 50',icon:'📊',
      what:'NIFTY 50 is India\'s most-watched stock index. It tracks the 50 largest and most liquid companies listed on the NSE (National Stock Exchange). Think of it as a report card for India\'s biggest businesses — from Reliance and TCS to HDFC Bank and Infosys.',
      who:'Top sectors: Financial Services (~33%), IT (~13%), Oil & Gas (~12%), Consumer Goods (~9%), Auto (~6%). Heavyweights include Reliance Industries, HDFC Bank, Infosys, ICICI Bank, and TCS.',
      why:'When NIFTY 50 goes up, it usually means: the economy is healthy, earnings are growing, and investors are optimistic about India\'s future. When it falls, it signals caution — either globally or in specific sectors.',
      movers:'Global cues (US markets, FII flows), RBI interest rate decisions, quarterly earnings results, USD/INR exchange rate, crude oil prices, and major government policy announcements.',
      sip:'Your mutual fund SIP likely benchmarks against NIFTY 50. A rising NIFTY means your equity funds are probably doing well. A dip means your SIP is buying more units at a lower price — which is actually good for long-term wealth building.'
    },
    BSESN: {
      title:'SENSEX',icon:'🏛️',
      what:'SENSEX (Sensitive Index) is India\'s oldest stock index, launched in 1986 by BSE (Bombay Stock Exchange). It tracks the top 30 companies by market cap and trading volume. While NIFTY covers 50 stocks, SENSEX is more concentrated — making it slightly more volatile but faster to react to news.',
      who:'Top companies: Reliance, HDFC Bank, Infosys, ICICI Bank, TCS, L&T, Bajaj Finance, Kotak Mahindra Bank. Together just these 8 stocks make up nearly 50% of the index weight.',
      why:'SENSEX is the "face" of Indian markets internationally. When foreign media or investors talk about Indian markets, they almost always quote SENSEX. It\'s the oldest benchmark, so it captures India\'s entire economic history since the 1980s.',
      movers:'Same as NIFTY but since it has only 30 stocks, a big move in Reliance or HDFC Bank can swing SENSEX noticeably. More sensitive to banking sector news.',
      sip:'SENSEX and NIFTY generally move together (correlation >0.99). If SENSEX is up 1%, NIFTY is usually up ~0.95-1% too. For practical investment decisions, treat them as the same signal.'
    },
    NSEBANK: {
      title:'NIFTY BANK',icon:'🏦',
      what:'NIFTY Bank tracks the 12 most liquid banking stocks on NSE. Banks are the backbone of any economy — they lend money to businesses, manage your savings, and facilitate all transactions. When banks do well, the whole economy usually does well.',
      who:'Includes HDFC Bank, ICICI Bank, Kotak Mahindra Bank, SBI, Axis Bank, IndusInd Bank, Bank of Baroda, Federal Bank. Private banks like HDFC and ICICI have the highest weight (~60% combined).',
      why:'NIFTY Bank is often more volatile than NIFTY 50. It reacts sharply to: RBI rate decisions (higher rates = banks earn more on loans but borrowers pay more), NPA (bad loan) data, GDP growth, and credit demand. When NIFTY Bank falls, it often drags down NIFTY 50 with it — because banks are such a large part of the economy.',
      movers:'RBI Monetary Policy Committee meetings, bank quarterly results (NPA levels, net interest margin), credit growth data, US Federal Reserve rate decisions (affects FII flows), and currency movements (USD/INR).',
      sip:'If you have a banking sector fund, monitor NIFTY Bank closely. A rising NIFTY Bank means: banks are profitable, loans are being repaid, and credit is growing — all signs of a healthy economy.'
    },
    NIFTYMIDCAP: {
      title:'NIFTY MIDCAP / SMALLCAP',icon:'🚀',
      what:'This index tracks mid-sized and smaller Indian companies — the next generation of potential large-caps. These are businesses with market caps between ₹5,000 Cr and ₹20,000 Cr. They grow faster than large-caps but are also riskier.',
      who:'A diverse mix of sectors — chemicals, specialty pharma, auto ancillaries, specialty finance, consumer brands, IT services. Examples include companies like Persistent Systems, Metropolis, Rajesh Exports, and Navin Fluorine.',
      why:'Smallcap and midcap indices are leading indicators — they react faster to economic changes than large-caps. When retail investors are optimistic, they pile into smallcaps first. When fear strikes, they exit smallcaps fastest.',
      movers:'Domestic retail investor sentiment (since FIIs mostly trade large-caps), Budget announcements (capex, sector policies), domestic consumption data, and GST collection numbers. Less influenced by global cues than NIFTY 50.',
      sip:'Smallcap funds can give 2-3x returns of NIFTY 50 in bull markets — but they can also fall 40-60% in bear markets. Ideal for long-term (10+ year) SIPs where you can ride out volatility.'
    }
  };

  // Store live data for modal
  let _idxLiveData: Record<string,{price:number,chg:number,pct:number,high52?:number,low52?:number}> = {};

  function showIdxModal(key: string) {
    const info = IDX_INFO[key]; if(!info) return;
    const live = _idxLiveData[key];
    const up = (live?.pct??0) >= 0;
    const color = up ? '#22c55e' : '#ef4444';
    const priceHtml = live ? `
      <div style="display:flex;align-items:baseline;gap:16px;margin:16px 0 20px">
        <span style="font-size:2rem;font-weight:800;color:var(--gold)">${live.price.toLocaleString('en-IN',{maximumFractionDigits:2})}</span>
        <span style="font-size:1rem;font-weight:700;color:${color}">${up?'▲':'▼'} ${Math.abs(live.pct).toFixed(2)}% today</span>
      </div>` : '';
    document.getElementById('idxModalContent')!.innerHTML = `
      <div style="font-size:28px;margin-bottom:8px">${info.icon}</div>
      <div style="font-size:22px;font-weight:800;color:#fff;margin-bottom:4px">${info.title}</div>
      ${priceHtml}
      <div class="idx-modal-section">
        <div class="idx-modal-label">WHAT IS IT?</div>
        <p class="idx-modal-text">${info.what}</p>
      </div>
      <div class="idx-modal-section">
        <div class="idx-modal-label">WHO'S INSIDE?</div>
        <p class="idx-modal-text">${info.who}</p>
      </div>
      <div class="idx-modal-section">
        <div class="idx-modal-label">WHAT DOES IT SIGNAL?</div>
        <p class="idx-modal-text">${info.why}</p>
      </div>
      <div class="idx-modal-section">
        <div class="idx-modal-label">WHAT MOVES IT?</div>
        <p class="idx-modal-text">${info.movers}</p>
      </div>
      <div style="background:rgba(212,169,64,0.08);border:1px solid rgba(212,169,64,0.22);border-radius:10px;padding:16px 18px;margin-top:20px">
        <div style="font-size:10px;font-weight:700;letter-spacing:1px;color:var(--gold);margin-bottom:6px">💡 WHAT IT MEANS FOR YOUR SIP</div>
        <p class="idx-modal-text" style="margin:0">${info.sip}</p>
      </div>
      <p style="font-size:10px;color:var(--text-dim);margin-top:16px;text-align:center">⚠️ Educational context only — not financial advice. Always DYOR.</p>`;
    document.getElementById('idxModal')!.style.display = 'block';
  }

  document.querySelectorAll('.idx-clickable').forEach(el => {
    el.addEventListener('click', () => {
      const key = (el as HTMLElement).dataset.idx || '';
      showIdxModal(key);
    });
  });

  loadData();
</script>

<style is:global>
/* ── Clickable index cards ───────────────────────────── */
.idx-clickable { cursor:pointer; }
.idx-clickable:hover { transform:translateY(-4px); border-color:rgba(212,169,64,0.55) !important; box-shadow:0 8px 32px rgba(212,169,64,0.18); }
.idx-tap-hint { display:block; font-size:9px; color:var(--gold); opacity:0.5; margin-top:4px; letter-spacing:0.5px; text-transform:uppercase; }
.idx-clickable:hover .idx-tap-hint { opacity:1; }
.idx-modal-section { margin-bottom:18px; }
.idx-modal-label { font-size:9px; font-weight:800; letter-spacing:1.5px; color:var(--gold); margin-bottom:5px; }
.idx-modal-text { font-size:13px; color:var(--text-muted); line-height:1.8; margin:0; }

/* ── India markets row table ──────────────────────────── */
.in-table-head {
  display: grid;
  grid-template-columns: 2fr 110px 150px 80px;
  gap: 0 16px;
  padding: 6px 16px;
  font-size: 10px;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.8px;
}
.in-table {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.in-row {
  display: grid;
  grid-template-columns: 2fr 110px 150px 80px;
  gap: 0 16px;
  align-items: center;
  padding: 12px 16px;
  background: var(--navy-2);
  border: 1px solid var(--border);
  border-left: 3px solid transparent;
  border-radius: 8px;
  text-decoration: none;
  transition: background 0.15s, border-color 0.15s;
}
.in-row:hover { background: var(--navy-3); border-color: rgba(201,168,76,0.3); }
.in-row.up { border-left-color: #22c55e; }
.in-row.dn { border-left-color: #ef4444; }
.in-row-sym { display: flex; align-items: baseline; gap: 10px; min-width: 0; }
.in-sym { font-size: 14px; font-weight: 800; color: #fff; flex-shrink: 0; letter-spacing: 0.3px; }
.in-name { font-size: 12px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.in-price { font-size: 14px; font-weight: 700; color: #fff; text-align: right; }
.in-chg { font-size: 12px; font-weight: 600; text-align: right; }
.in-pct { text-align: right; }
/* Shimmer while loading */
.in-row:not(.up):not(.dn) .in-price,
.in-row:not(.up):not(.dn) .in-chg,
.in-row:not(.up):not(.dn) .mkt-badge {
  background: linear-gradient(90deg,rgba(255,255,255,.05) 25%,rgba(255,255,255,.12) 50%,rgba(255,255,255,.05) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 4px;
  color: transparent !important;
  min-width: 50px;
  min-height: 13px;
  display: inline-block;
}
@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
.mkt-badge { font-size: 10px; font-weight: 700; padding: 3px 7px; border-radius: 5px; display: inline-block; }
.badge-up { background: rgba(34,197,94,0.15); color: #22c55e; }
.badge-dn { background: rgba(239,68,68,0.15); color: #ef4444; }
@media (max-width: 700px) {
  .in-table-head { grid-template-columns: 2fr 90px 90px; }
  .in-table-head span:last-child { display: none; }
  .in-row { grid-template-columns: 2fr 90px 90px; }
  .in-pct { display: none; }
}
</style>
