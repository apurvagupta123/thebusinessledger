---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await Astro.glob('./blog/*.md').catch(() => []);
const sorted = posts.sort((a: any, b: any) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);

// Morning posts: filename contains "morning-market-watch"
const allMorningPosts = sorted.filter((p: any) =>
  (p.file || '').includes('morning-market-watch')
);
// Evening posts: filename contains "india-market-briefing"
const allEveningPosts = sorted.filter((p: any) =>
  (p.file || '').includes('india-market-briefing')
);
const morningPosts = allMorningPosts.slice(0, 5);
const eveningPosts = allEveningPosts.slice(0, 5);

const SECTOR_TAGS: Record<string, string> = {
  'RELIANCE.NS':   '⚡ Energy',
  'TCS.NS':        '💻 IT',
  'HDFCBANK.NS':   '🏦 Banking',
  'INFY.NS':       '💻 IT',
  'ICICIBANK.NS':  '🏦 Banking',
  'BAJFINANCE.NS': '💳 Finance',
  'TMCV.NS':       '🚗 Auto',
  'BHARTIARTL.NS': '📡 Telecom',
  'MARUTI.NS':     '🚗 Auto',
  'SBIN.NS':       '🏦 PSU Bank',
  'LT.NS':         '🏗️ Infra',
  'WIPRO.NS':      '💻 IT',
  'HCLTECH.NS':    '💻 IT',
  'KOTAKBANK.NS':  '🏦 Banking',
  'TITAN.NS':      '✨ Consumer',
  'ASIANPAINT.NS': '🎨 FMCG',
};
---
<BaseLayout title="Where Smart Money Reads">

  <!-- ── Hero ────────────────────────────────────────── -->
  <section class="hero">
    <!-- Golden graph background -->
    <img src="/download.jpeg" alt="" class="hero-graph-bg" aria-hidden="true" />
    <div class="hero-inner hero-split">

      <!-- Left: Text Content -->
      <div class="hero-content">
        <h1 class="hero-title">
          Bull Signal.<br />
          <span class="hero-accent">Sharper Moves.</span>
        </h1>
        <p class="hero-desc">
          NSE & BSE data updated twice daily — 4 PM & 2 AM IST.<br />
          Indian stock insights and AI-powered investment analysis.
        </p>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hs-num">NSE/BSE</span>
            <span class="hs-label">NSE DATA</span>
          </div>
          <div class="hs-divider"></div>
          <div class="hero-stat">
            <span class="hs-num">AI</span>
            <span class="hs-label">STOCK INSIGHTS</span>
          </div>
          <div class="hs-divider"></div>
          <div class="hero-stat">
            <span class="hs-num">Daily</span>
            <span class="hs-label">MARKET BRIEFING</span>
          </div>
        </div>
        <div class="hero-actions">
          <a href="/markets/" class="btn-primary">Explore Markets →</a>
          <button class="btn-outline" onclick="document.getElementById('market-pulse').scrollIntoView({behavior:'smooth'})">Market Pulse</button>
        </div>
      </div>

      <!-- Right: Bull Image Visual -->
      <div class="hero-visual" aria-hidden="true">
        <!-- Glow backdrop -->
        <div class="hv-glow-backdrop"></div>
        <!-- Orbit rings (outside bull image, so they're visible) -->
        <div class="hv-orbit-ring"></div>
        <div class="hv-orbit-ring-2"></div>

        <!-- Bull Image -->
        <div class="hv-bull-wrap">
          <img src="/bull-hero.webp" alt="Bull market" class="hv-bull-img" />
          <div class="hv-bull-overlay"></div>
        </div>

        <!-- Floating Market Chips -->
        <div class="hv-chip hv-chip-1">
          <span class="chip-label">NIFTY 50</span>
          <span class="chip-val loading" id="chip-nifty-val">——</span>
          <span class="chip-chg loading" id="chip-nifty-chg">——</span>
        </div>
        <div class="hv-chip hv-chip-2">
          <span class="chip-label">SENSEX</span>
          <span class="chip-val loading" id="chip-sensex-val">——</span>
          <span class="chip-chg loading" id="chip-sensex-chg">——</span>
        </div>
        <div class="hv-chip hv-chip-3">
          <span class="chip-label">RELIANCE</span>
          <span class="chip-val loading" id="chip-rel-val">——</span>
          <span class="chip-chg loading" id="chip-rel-chg">——</span>
        </div>
        <div class="hv-chip hv-chip-4">
          <span class="chip-label">TCS</span>
          <span class="chip-val loading" id="chip-tcs-val">——</span>
          <span class="chip-chg loading" id="chip-tcs-chg">——</span>
        </div>

      </div>

    </div>
  </section>

  <!-- ── Indices Strip ─────────────────────────────────── -->
  <section class="indices-section reveal">
    <div class="idx-strip" id="indicesBar">
      {[
        {key:'NSEI',   name:'NIFTY 50',   idx:'NSEI'},
        {key:'BSESN',  name:'SENSEX',     idx:'BSESN'},
        {key:'NSEBANK',name:'NIFTY BANK', idx:'NSEBANK'},
        {key:'MID',    name:'SMALLCAP',   idx:'NIFTYMIDCAP'},
        {key:'IT',     name:'NIFTY IT',   idx:'IT'},
        {key:'AUTO',   name:'NIFTY AUTO', idx:'AUTO'},
        {key:'PHARMA', name:'PHARMA',     idx:'PHARMA'},
        {key:'FMCG',   name:'NIFTY FMCG',idx:'FMCG'},
      ].map(({key, name, idx}) => (
        <div class="idx-pill skeleton" id={`hidx-${key}`} data-idx={idx} style="cursor:pointer">
          <span class="idx-pill-name">{name}</span>
          <span class="idx-pill-price" id={`hidx-${key}-price`}>—</span>
          <span class="idx-pill-chg"   id={`hidx-${key}-chg`}>—</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Index Detail Modal ───────────────────────────── -->
  <div id="idxModal" style="display:none;position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px);padding:20px;overflow-y:auto" onclick="if(event.target===this)this.style.display='none'">
    <div style="max-width:620px;margin:60px auto;background:linear-gradient(135deg,rgba(212,169,64,0.13) 0%,rgba(10,9,4,0.99) 60%);border:1px solid rgba(212,169,64,0.35);border-radius:18px;padding:32px 36px;position:relative">
      <button onclick="document.getElementById('idxModal').style.display='none'" style="position:absolute;top:16px;right:18px;background:rgba(212,169,64,0.12);border:1px solid rgba(212,169,64,0.25);color:var(--gold);border-radius:8px;padding:4px 12px;font-size:13px;cursor:pointer">✕ Close</button>
      <div id="idxModalContent"></div>
    </div>
  </div>

  <!-- ── Today's Indian Markets ──────────────────────── -->
  <section class="content-section reveal" id="markets">
    <div class="section-head">
      <h2 class="section-title">Top 5 Stocks</h2>
      <a href="/markets" class="section-more">View all sectors →</a>
    </div>
    <div class="pie-layout">
      <!-- Donut chart -->
      <div class="pie-chart-wrap">
        <canvas id="stockPieChart" width="260" height="260"></canvas>
      </div>
      <!-- Legend / clickable list -->
      <div class="pie-legend" id="pieLegend">
        {['RELIANCE.NS','TCS.NS','HDFCBANK.NS','INFY.NS','ICICIBANK.NS'].map((sym, i) => (
          <a class="pie-leg-item" id={`pl-${sym}`}
             href={`/company/${sym.toLowerCase().replace(/\./g,'-')}`}
             data-sym={sym} data-idx={i}>
            <span class="pie-leg-dot" id={`pld-${i}`}></span>
            <div class="pie-leg-body">
              <span class="pie-leg-sym">{sym.replace('.NS','')}</span>
              <span class="pie-leg-name" id={`pln-${sym}`}>Loading…</span>
            </div>
            <div class="pie-leg-right">
              <span class="pie-leg-price" id={`plp-${sym}`}>—</span>
              <span class="pie-leg-chg"  id={`plc-${sym}`}>—</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Market Pulse ──────────────────────────────────── -->
  <section class="content-section reveal reveal-d1" id="market-pulse">
    <div class="section-head">
      <h2 class="section-title">Market Pulse</h2>
      <span class="section-live">NSE</span>
    </div>
    <div class="pulse-grid">

      <!-- VIX Gauge -->
      <div class="pulse-card">
        <div class="pulse-label">India VIX <span class="pulse-badge">Fear Index</span></div>
        <div class="vix-gauge-wrap">
          <svg viewBox="0 0 220 130" class="vix-svg">
            <!-- Background track -->
            <path d="M 25 115 A 85 85 0 0 1 195 115" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="14" stroke-linecap="round"/>
            <!-- Zone: Low 0–15 -->
            <path d="M 25 115 A 85 85 0 0 1 77.6 36.5" fill="none" stroke="rgba(16,239,98,0.4)" stroke-width="14" stroke-linecap="round"/>
            <!-- Zone: Moderate 15–22 -->
            <path d="M 77.6 36.5 A 85 85 0 0 1 123.3 31.1" fill="none" stroke="rgba(234,179,8,0.4)" stroke-width="14"/>
            <!-- Zone: High 22–40 -->
            <path d="M 123.3 31.1 A 85 85 0 0 1 195 115" fill="none" stroke="rgba(255,71,87,0.4)" stroke-width="14" stroke-linecap="round"/>
            <!-- Zone labels -->
            <text x="30" y="112" font-size="9" fill="rgba(16,239,98,0.8)" font-weight="700">LOW</text>
            <text x="98" y="26" font-size="9" fill="rgba(234,179,8,0.8)" font-weight="700" text-anchor="middle">MOD</text>
            <text x="183" y="112" font-size="9" fill="rgba(255,71,87,0.8)" font-weight="700" text-anchor="end">HIGH</text>
            <!-- Needle shadow -->
            <line x1="110" y1="115" x2="110" y2="42" stroke="rgba(0,0,0,0.5)" stroke-width="4.5" stroke-linecap="round"
              id="vixNeedleShadow" style="transform-origin:110px 115px;transform:rotate(-90deg);transition:transform 1.2s cubic-bezier(0.34,1.56,0.64,1)"/>
            <!-- Needle -->
            <line x1="110" y1="115" x2="110" y2="40" stroke="#f0c040" stroke-width="3" stroke-linecap="round"
              id="vixNeedle" style="transform-origin:110px 115px;transform:rotate(-90deg);transition:transform 1.2s cubic-bezier(0.34,1.56,0.64,1)"/>
            <!-- Center cap outer ring -->
            <circle cx="110" cy="115" r="8" fill="#0d0b26" stroke="rgba(212,169,64,0.3)" stroke-width="1.5"/>
            <circle cx="110" cy="115" r="4" fill="#d4a940"/>
            <!-- Value -->
            <text x="110" y="96" text-anchor="middle" font-size="28" font-weight="800" fill="white" id="vixGaugeVal">—</text>
          </svg>
        </div>
        <div class="pulse-sub" id="vixSub" style="text-align:center;margin-top:4px">Loading…</div>
      </div>

      <!-- Nifty P/E Zone Bar -->
      <div class="pulse-card">
        <div class="pulse-label">Nifty 50 P/E <span class="pulse-badge">Valuation</span></div>
        <div style="margin:16px 0 8px;text-align:center">
          <span class="pulse-value" id="niftyPE" style="font-size:2.2rem">—</span>
          <span style="font-size:12px;color:var(--text-muted);margin-left:6px">P/E ratio</span>
        </div>
        <div class="pe-zone-wrap">
          <div class="pe-zone-bar">
            <div class="pe-zone pez-cheap">Cheap<br/><span>&lt;18x</span></div>
            <div class="pe-zone pez-fair">Fair<br/><span>18–24x</span></div>
            <div class="pe-zone pez-rich">Pricey<br/><span>24–28x</span></div>
            <div class="pe-zone pez-bubble">Bubble<br/><span>&gt;28x</span></div>
            <div class="pe-marker" id="peMarker" style="left:50%"></div>
          </div>
        </div>
        <div class="pulse-sub" id="niftyPESub" style="margin-top:10px;text-align:center">Long-term avg ~22x · Source: NSE India</div>
        <div class="pulse-insight" id="niftyPEInsight" style="text-align:center"></div>
      </div>

      <!-- FII / DII Bar Chart -->
      <div class="pulse-card">
        <div class="pulse-label">FII / DII Flow <span class="pulse-badge">Latest</span></div>
        <div class="fii-chart-wrap" id="fiiChartWrap">
          <div class="fii-bar-row">
            <span class="fii-lbl">FII</span>
            <div class="fii-track">
              <div class="fii-bar-neg" id="fiiBarNeg" style="width:0%"></div>
              <div class="fii-bar-pos" id="fiiBarPos" style="width:0%"></div>
            </div>
            <span class="fii-val" id="fiiVal">—</span>
          </div>
          <div class="fii-bar-row" style="margin-top:12px">
            <span class="fii-lbl">DII</span>
            <div class="fii-track">
              <div class="fii-bar-neg" id="diiBarNeg" style="width:0%"></div>
              <div class="fii-bar-pos" id="diiBarPos" style="width:0%"></div>
            </div>
            <span class="fii-val" id="diiVal">—</span>
          </div>
          <div class="fii-zero-line"></div>
        </div>
        <div class="pulse-sub" id="fiiSub" style="margin-top:10px">Fetching NSE data…</div>
      </div>

      <!-- Market Mood Donut -->
      <div class="pulse-card">
        <div class="pulse-label">Market Mood <span class="pulse-badge">Today</span></div>
        <div class="mood-wrap">
          <svg viewBox="0 0 120 120" class="mood-donut" id="moodDonut">
            <circle cx="60" cy="60" r="46" fill="none" stroke="rgba(255,255,255,.06)" stroke-width="18"/>
            <circle cx="60" cy="60" r="46" fill="none" stroke="#10ef62" stroke-width="18"
              stroke-dasharray="289" stroke-dashoffset="289" id="moodGreen"
              style="transform:rotate(-90deg);transform-origin:60px 60px;transition:stroke-dashoffset 1s ease"/>
            <circle cx="60" cy="60" r="46" fill="none" stroke="#ff4757" stroke-width="18"
              stroke-dasharray="289" stroke-dashoffset="289" id="moodRed"
              style="transform:rotate(-90deg);transform-origin:60px 60px;transition:stroke-dashoffset 1s ease"/>
            <text x="60" y="55" text-anchor="middle" font-size="20" font-weight="800" fill="white" id="moodPct">—</text>
            <text x="60" y="70" text-anchor="middle" font-size="9" fill="#94a3b8" id="moodLabel">green</text>
          </svg>
          <div class="mood-legend">
            <div class="mood-leg-item"><span style="background:#10ef62"></span><span id="moodGreenCount">—</span> Up</div>
            <div class="mood-leg-item"><span style="background:#ff4757"></span><span id="moodRedCount">—</span> Down</div>
          </div>
        </div>
        <div class="pulse-value" id="moodVal" style="font-size:1.1rem;text-align:center;margin-top:6px">—</div>
        <div class="pulse-insight" id="moodInsight" style="text-align:center"></div>
      </div>

    </div>
  </section>

  <!-- ── Financial News (client-rendered, auto-refreshes every 30 min) ── -->
  <section class="content-section" id="news">
    <div class="section-head">
      <h2 class="section-title">📰 Market News</h2>
      <span class="section-live">LIVE</span>
    </div>
    <!-- JS renders the grid here -->
    <div id="newsGrid" class="news-grid">
      <div class="news-loading">Loading latest news…</div>
    </div>
    <div class="news-footer" id="newsFooter" style="display:none">
      <span class="news-updated" id="newsUpdatedAt"></span>
      <a href="https://www.moneycontrol.com/news/" target="_blank" rel="noopener" class="news-more">More news →</a>
    </div>
  </section>

  <!-- ── News Article Modal ──────────────────────────────────────── -->
  <div id="newsModal" class="nmodal-overlay" role="dialog" aria-modal="true" aria-label="Article Summary" style="display:none">
    <div class="nmodal-box">
      <button class="nmodal-close" id="nmodalClose" aria-label="Close">✕</button>
      <div class="nmodal-img-wrap" id="nmodalImgWrap">
        <img id="nmodalImg" src="" alt="" class="nmodal-img" />
      </div>
      <div class="nmodal-body">
        <div class="nmodal-meta">
          <span class="nmodal-source" id="nmodalSource"></span>
          <span class="nmodal-time" id="nmodalTime"></span>
        </div>
        <h2 class="nmodal-title" id="nmodalTitle"></h2>
        <div class="nmodal-summary-wrap">
          <span class="nmodal-ai-badge">✦ AI Summary</span>
          <p class="nmodal-summary" id="nmodalSummary"></p>
        </div>
        <a class="nmodal-read-btn" id="nmodalReadBtn" href="#" target="_blank" rel="noopener">
          Read full article →
        </a>
      </div>
    </div>
  </div>

  <!-- ── Company Spotlight ─────────────────────────────── -->
  <section class="content-section reveal reveal-d2">
    <div class="section-head">
      <h2 class="section-title">Company Spotlight</h2>
    </div>
    <div class="spotlight-box">
      <div class="spotlight-search" style="position:relative">
        <input id="slInput" type="text" class="sl-input" placeholder="Search company name or ticker (e.g. RELIANCE, HDFC Bank, TCS)" autocomplete="off" />
        <button id="slBtn" class="sl-btn">Analyze →</button>
        <div id="slDropdown" style="display:none;position:absolute;top:100%;left:0;right:0;background:#1a1509;border:1px solid rgba(212,169,64,0.35);border-radius:10px;margin-top:4px;z-index:200;max-height:240px;overflow-y:auto;box-shadow:0 8px 32px rgba(0,0,0,0.5)"></div>
      </div>
      <div id="slResult">
        <p class="sl-hint">Search for any NSE company — by name or ticker symbol.</p>
      </div>
    </div>
  </section>

  <!-- ── Morning Market Briefing ──────────────────────── -->
  <section class="content-section reveal" id="from-ledger">
    <div class="section-head">
      <h2 class="section-title">🌅 Morning Market Briefing</h2>
      <span class="section-live">MORNING</span>
    </div>
    <div class="tl-list">
      {morningPosts.length > 0 ? morningPosts.map((post: any) => {
        const d = new Date(post.frontmatter.date);
        const day   = d.toLocaleDateString('en-IN', { day: 'numeric' });
        const month = d.toLocaleDateString('en-IN', { month: 'short' });
        const year  = d.getFullYear();
        return (
          <a href={post.url} class="tl-item">
            <div class="tl-date-col">
              <span class="tl-day">{day}</span>
              <span class="tl-mon">{month} {year}</span>
            </div>
            <div class="tl-dot-col">
              <div class="tl-dot"></div>
              <div class="tl-line"></div>
            </div>
            <div class="tl-body">
              <h3 class="tl-title">{post.frontmatter.title}</h3>
              {post.frontmatter.excerpt && <p class="tl-desc">{post.frontmatter.excerpt}</p>}
              <span class="tl-read">Read more →</span>
            </div>
          </a>
        );
      }) : (
        <p class="tl-empty">Morning briefings publish weekdays at 10 AM IST — check back soon.</p>
      )}
    </div>
    {allMorningPosts.length > 5 && (
      <div class="tl-viewall-wrap">
        <a href="/blog" class="tl-viewall">View all morning briefings →</a>
      </div>
    )}
  </section>

  <!-- ── Evening Indian Market Briefing ─────────────────── -->
  {eveningPosts.length > 0 && (
    <section class="content-section reveal" id="evening-briefing">
      <div class="section-head">
        <h2 class="section-title">🌆 Evening Indian Market Briefing</h2>
        <span class="section-live">EVENING</span>
      </div>
      <div class="tl-list">
        {eveningPosts.map((post: any) => {
          const d = new Date(post.frontmatter.date);
          const day   = d.toLocaleDateString('en-IN', { day: 'numeric' });
          const month = d.toLocaleDateString('en-IN', { month: 'short' });
          const year  = d.getFullYear();
          return (
            <a href={post.url} class="tl-item">
              <div class="tl-date-col">
                <span class="tl-day">{day}</span>
                <span class="tl-mon">{month} {year}</span>
              </div>
              <div class="tl-dot-col">
                <div class="tl-dot"></div>
                <div class="tl-line"></div>
              </div>
              <div class="tl-body">
                <h3 class="tl-title">{post.frontmatter.title}</h3>
                {post.frontmatter.excerpt && <p class="tl-desc">{post.frontmatter.excerpt}</p>}
                <span class="tl-read">Read more →</span>
              </div>
            </a>
          );
        })}
      </div>
      {allEveningPosts.length > 5 && (
        <div class="tl-viewall-wrap">
          <a href="/blog" class="tl-viewall">View all evening briefings →</a>
        </div>
      )}
    </section>
  )}

</BaseLayout>

<style>
/* ── Hero graph background ──────────────────────────── */
.hero-graph-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center;
  opacity: 0.32;
  pointer-events: none;
  z-index: 0;
  mix-blend-mode: screen;
  filter: sepia(0.6) saturate(4) hue-rotate(5deg) brightness(1.3);
}

/* ── Hero Split Layout ───────────────────────────────── */
.hero-split {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
}
.hero-content { flex: 1; min-width: 0; }
.hero-visual {
  flex: 0 0 420px;
  position: relative;
  height: 420px;
  display: flex;
  align-items: center;
  justify-content: center;
}
@media (max-width: 900px) { .hero-visual { display: none; } }

/* ── Bull Image Visual ───────────────────────────────── */
.hv-glow-backdrop {
  position: absolute;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212,169,64,.22) 0%, rgba(184,134,11,.1) 50%, transparent 75%);
  animation: glow-pulse 3s ease-in-out infinite;
  z-index: 0;
}
@keyframes glow-pulse {
  0%, 100% { transform: scale(1);    opacity: 1; }
  50%       { transform: scale(1.08); opacity: 0.85; }
}

.hv-orbit-ring {
  position: absolute;
  width: 400px;
  height: 400px;
  border-radius: 50%;
  border: 1px solid rgba(212,169,64,.35);
  animation: orbit-spin 18s linear infinite;
  z-index: 3;
  pointer-events: none;
}
.hv-orbit-ring::after {
  content: '';
  position: absolute;
  top: -5px;
  left: 50%;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #f0c040;
  box-shadow: 0 0 12px #d4a940, 0 0 24px rgba(212,169,64,.7);
  transform: translateX(-50%);
}
.hv-orbit-ring-2 {
  position: absolute;
  width: 440px;
  height: 440px;
  border-radius: 50%;
  border: 1px dashed rgba(212,169,64,.18);
  animation: orbit-spin 32s linear infinite reverse;
  z-index: 3;
  pointer-events: none;
}
.hv-orbit-ring-2::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 50%;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: rgba(212,169,64,.8);
  box-shadow: 0 0 8px #d4a940;
  transform: translateX(-50%);
}
@keyframes orbit-spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

.hv-bull-wrap {
  position: absolute;
  width: 360px;
  height: 360px;
  z-index: 2;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 0 40px rgba(212,169,64,.5), 0 0 80px rgba(212,169,64,.25);
  animation: bull-float 5s ease-in-out infinite;
}
@keyframes bull-float {
  0%, 100% { transform: translateY(0px) scale(1); }
  50%       { transform: translateY(-8px) scale(1.02); }
}
.hv-bull-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}
/* Purple tint overlay */
.hv-bull-overlay {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: radial-gradient(circle at 60% 40%, transparent 30%, rgba(184,134,11,.35) 100%);
  mix-blend-mode: multiply;
  pointer-events: none;
}

/* ── Floating Ticker Chips ───────────────────────────── */
.hv-chip {
  position: absolute;
  background: rgba(5,8,15,.92);
  border: 1px solid rgba(212,169,64,.25);
  border-radius: 10px;
  padding: 8px 12px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  backdrop-filter: blur(10px);
  z-index: 4;
  min-width: 90px;
  transition: transform .3s ease, box-shadow .3s ease;
  box-shadow: 0 4px 16px rgba(0,0,0,.4), 0 0 0 1px rgba(212,169,64,.05);
}
.hv-chip:hover { box-shadow: 0 4px 24px rgba(212,169,64,.15), 0 0 0 1px rgba(212,169,64,.2); }
.chip-label { font-size: 9px; font-weight: 700; letter-spacing: .8px; color: #d4a940; text-transform: uppercase; }
.chip-val   { font-size: 13px; font-weight: 800; color: #fff; }
.chip-chg   { font-size: 10px; font-weight: 700; color: var(--text-muted,#94a3b8); }
.chip-chg.up { color: #22c55e; }
.chip-chg.dn { color: #ef4444; }

/* Chip positions + float animations */
.hv-chip-1 { top: 10px;  left: 30px;  animation: float-a 5s ease-in-out infinite; }
.hv-chip-2 { top: 10px;  right: 20px; animation: float-b 6s ease-in-out infinite; }
.hv-chip-3 { bottom: 60px; left: 10px;  animation: float-c 5.5s ease-in-out infinite; }
.hv-chip-4 { bottom: 60px; right: 15px; animation: float-d 4.8s ease-in-out infinite; }
@keyframes float-a { 0%,100%{transform:translateY(0)}   50%{transform:translateY(-10px)} }
@keyframes float-b { 0%,100%{transform:translateY(0)}   50%{transform:translateY(-14px)} }
@keyframes float-c { 0%,100%{transform:translateY(0)}   50%{transform:translateY(-8px)}  }
@keyframes float-d { 0%,100%{transform:translateY(0)}   50%{transform:translateY(-12px)} }

/* Chip loading shimmer */
.hv-chip .chip-val.loading,
.hv-chip .chip-chg.loading {
  background: linear-gradient(90deg,rgba(255,255,255,.06) 25%,rgba(255,255,255,.14) 50%,rgba(255,255,255,.06) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 3px;
  color: transparent !important;
  min-width: 50px;
  min-height: 12px;
  display: block;
}

/* ── Global Shimmer Skeleton ─────────────────────────── */
@keyframes shimmer {
  0%   { background-position:  200% 0; }
  100% { background-position: -200% 0; }
}
.idx-card.skeleton .idx-price,
.idx-card.skeleton .idx-chg {
  background: linear-gradient(90deg,rgba(255,255,255,.05) 25%,rgba(255,255,255,.12) 50%,rgba(255,255,255,.05) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 4px;
  color: transparent !important;
  min-width: 70px;
  display: inline-block;
}
/* Market cards shimmer — before data loads (no .up or .dn class yet) */
.mkt-card:not(.up):not(.dn) .mkt-price,
.mkt-card:not(.up):not(.dn) .mkt-chg,
.mkt-card:not(.up):not(.dn) .mkt-badge {
  background: linear-gradient(90deg,rgba(255,255,255,.05) 25%,rgba(255,255,255,.12) 50%,rgba(255,255,255,.05) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 4px;
  color: transparent !important;
  min-width: 60px;
  min-height: 14px;
  display: inline-block;
}

/* ── Market Pulse Charts ─────────────────────────────── */
.pulse-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 16px;
}
.pulse-card {
  background: var(--navy-2);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 18px 20px;
}
/* VIX gauge */
.vix-gauge-wrap { display:flex;flex-direction:column;align-items:center;margin-top:4px; }
.vix-svg        { width:100%;max-width:220px;height:auto; }
/* P/E zone bar */
.pe-zone-wrap  { padding:0 4px;margin-top:8px; }
.pe-zone-bar   { display:flex;height:34px;border-radius:8px;overflow:hidden;position:relative; }
.pe-zone       { flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:9px;font-weight:700;letter-spacing:.3px;line-height:1.3; }
.pe-zone span  { font-size:8px;opacity:.7; }
.pez-cheap     { background:rgba(16,239,98,.18); color:#10ef62; }
.pez-fair      { background:rgba(212,169,64,.18); color:#d4a940; }
.pez-rich      { background:rgba(234,179,8,.18);  color:#eab308; }
.pez-bubble    { background:rgba(255,71,87,.18);  color:#ff4757; }
.pe-marker     { position:absolute;top:-4px;bottom:-4px;width:3px;background:#fff;border-radius:2px;box-shadow:0 0 8px rgba(255,255,255,.6);transform:translateX(-50%);transition:left 1s ease; }
/* FII/DII bars */
.fii-chart-wrap { margin-top:16px;position:relative; }
.fii-bar-row    { display:flex;align-items:center;gap:8px; }
.fii-lbl        { font-size:11px;font-weight:700;color:var(--text-muted);width:24px;flex-shrink:0; }
.fii-track      { flex:1;height:20px;background:rgba(255,255,255,.06);border-radius:4px;overflow:hidden;display:flex;align-items:center;position:relative; }
.fii-bar-pos    { height:100%;background:linear-gradient(90deg,#10ef62,#16a34a);border-radius:0 4px 4px 0;transition:width 1s ease;min-width:0; }
.fii-bar-neg    { height:100%;background:linear-gradient(90deg,#ff4757,#dc2626);border-radius:4px 0 0 4px;position:absolute;right:50%;transition:width 1s ease;min-width:0; }
.fii-val        { font-size:11px;font-weight:700;color:var(--text);width:70px;text-align:right;flex-shrink:0; }
/* Market mood donut */
.mood-wrap   { display:flex;align-items:center;justify-content:center;gap:16px;margin-top:8px; }
.mood-donut  { width:100px;height:100px; }
.mood-legend { display:flex;flex-direction:column;gap:8px; }
.mood-leg-item { display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-muted); }
.mood-leg-item span:first-child { width:10px;height:10px;border-radius:50%;flex-shrink:0;display:inline-block; }

.pulse-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .8px;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.pulse-badge {
  background: rgba(201,168,76,.12);
  color: var(--gold);
  border-radius: 4px;
  font-size: 9px;
  padding: 2px 6px;
  letter-spacing: .5px;
  font-weight: 700;
}
.pulse-value {
  font-size: 2rem;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  margin-bottom: 4px;
}
.pulse-sub { font-size: 11px; color: var(--text-muted); line-height: 1.5; }
.pulse-insight { font-size: 11px; color: var(--gold); margin-top: 6px; font-style: italic; }
.pulse-meter { margin-top: 10px; }
.pm-track { height: 4px; background: rgba(255,255,255,.08); border-radius: 2px; overflow: hidden; margin-bottom: 4px; }
.pm-fill { height: 100%; border-radius: 2px; transition: width .6s ease; background: linear-gradient(90deg, #22c55e, #eab308, #ef4444); }
.pm-labels { display: flex; justify-content: space-between; font-size: 9px; color: var(--text-dim); }
.guide-strip { background: var(--navy-2); border: 1px solid var(--border); border-radius: 16px; padding: 24px 28px; }
.gs-title { font-size: 11px; font-weight: 700; color: var(--gold); letter-spacing: .8px; margin-bottom: 16px; text-transform: uppercase; }
.gs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; }
.gs-card { background: rgba(255,255,255,.03); border: 1px solid var(--border); border-radius: 10px; padding: 14px; transition: border-color .15s, transform .15s; text-decoration: none; display: block; }
.gs-card:hover { border-color: rgba(201,168,76,.3); transform: translateY(-2px); }
.gs-icon { font-size: 20px; margin-bottom: 6px; }
.gs-name { font-size: 12px; font-weight: 700; color: #fff; margin-bottom: 3px; }
.gs-desc { font-size: 11px; color: var(--text-muted); line-height: 1.4; }

/* ── Timeline Blog Layout ────────────────────────────── */
.tl-list { display: flex; flex-direction: column; }
.tl-viewall-wrap {
  text-align: right;
  margin-top: 12px;
}
.tl-viewall {
  font-size: 13px;
  font-weight: 600;
  color: var(--gold);
  text-decoration: none;
  letter-spacing: 0.3px;
  transition: opacity 0.2s;
}
.tl-viewall:hover { opacity: 0.75; }
.tl-empty {
  color: var(--muted);
  font-size: 14px;
  padding: 18px 0;
  font-style: italic;
}

/* ── News Section ─────────────────────────────────── */
.news-grid {
  display: grid;
  grid-template-columns: 340px 210px;
  gap: 16px;
  align-items: start;
  width: fit-content;
}

/* ── Featured article — vertical card */
.news-featured {
  display: block;
  width: 340px;
  border-radius: 12px;
  border: 1px solid rgba(212,169,64,0.2);
  background: #0d0d0d;
  cursor: pointer;
  contain: content;
  transition: border-color 0.2s;
}
.news-featured:hover { border-color: rgba(212,169,64,0.45); }
.news-feat-img-wrap {
  display: block;
  width: 100%;
  height: 185px;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  background-color: #1a1a1a;
}
.news-feat-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px 14px;
}
.news-feat-body { padding: 12px 14px 8px; }
.news-feat-title {
  font-size: 16px;
  font-weight: 700;
  line-height: 1.4;
  color: var(--text);
  margin: 0;
}
.news-source-tag {
  display: inline-block;
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.6px;
  text-transform: uppercase;
  color: #000;
  background: var(--gold);
  border-radius: 4px;
  padding: 2px 8px;
}
.news-feat-time { font-size: 11px; color: var(--muted); opacity: 0.65; }
.news-feat-excerpt {
  font-size: 12px;
  line-height: 1.5;
  color: var(--muted);
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── Side list (right) — compact text only */
.news-side {
  display: flex;
  flex-direction: column;
  border: 1px solid rgba(212,169,64,0.15);
  border-radius: 10px;
  overflow: hidden;
  background: rgba(212,169,64,0.03);
}
.news-side-item {
  display: flex;
  flex-direction: column;
  padding: 7px 11px;
  border-bottom: 1px solid rgba(212,169,64,0.07);
  cursor: pointer;
  transition: background 0.15s;
}
.news-side-item:last-of-type { border-bottom: none; }
.news-side-item:hover { background: rgba(212,169,64,0.06); }
.news-side-source {
  font-size: 8.5px;
  font-weight: 700;
  letter-spacing: 0.4px;
  text-transform: uppercase;
  color: var(--gold);
  opacity: 0.7;
  margin-bottom: 2px;
}
.news-side-title {
  font-size: 11.5px;
  font-weight: 500;
  line-height: 1.35;
  color: var(--text);
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.news-side-time { display: none; }
.news-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 7px 11px;
  border-top: 1px solid rgba(212,169,64,0.1);
  margin-top: 4px;
}
.news-updated { font-size: 9.5px; color: var(--muted); opacity: 0.5; }
.news-more { font-size: 10.5px; font-weight: 600; color: var(--gold); text-decoration: none; }
.news-more:hover { opacity: 0.75; }
@media (max-width: 640px) {
  .news-grid { grid-template-columns: 1fr; }
  .news-featured { width: 100%; }
  .news-side { display: none; }
}
.news-loading { color: var(--muted); font-size: 13px; padding: 16px 0; opacity: 0.5; }

/* news card buttons — reset browser button styles only */
.news-card-btn {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  font: inherit;
  color: inherit;
  text-align: left;
  cursor: pointer;
  width: 100%;
  /* do NOT set display here — let each card class control it */
}

/* ── News Modal ─────────────────────────────────────────── */
.nmodal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.82);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
  backdrop-filter: blur(4px);
}
.nmodal-box {
  background: #0f0f0f;
  border: 1px solid rgba(212,169,64,0.25);
  border-radius: 16px;
  max-width: 620px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  position: relative;
  box-shadow: 0 24px 64px rgba(0,0,0,0.8);
}
.nmodal-close {
  position: absolute;
  top: 14px;
  right: 16px;
  background: rgba(255,255,255,0.06);
  border: none;
  color: #fff;
  font-size: 16px;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  cursor: pointer;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}
.nmodal-close:hover { background: rgba(212,169,64,0.25); }
.nmodal-img-wrap { width: 100%; aspect-ratio: 16/9; overflow: hidden; border-radius: 16px 16px 0 0; }
.nmodal-img { width: 100%; height: 100%; object-fit: cover; display: block; }
.nmodal-body { padding: 20px 24px 28px; }
.nmodal-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}
.nmodal-source {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--gold);
  background: rgba(212,169,64,0.12);
  padding: 2px 8px;
  border-radius: 20px;
}
.nmodal-time { font-size: 11px; color: var(--muted); opacity: 0.6; }
.nmodal-title {
  font-size: 20px;
  font-weight: 700;
  color: #fff;
  line-height: 1.35;
  margin: 0 0 18px;
}
.nmodal-summary-wrap {
  background: rgba(212,169,64,0.06);
  border-left: 3px solid var(--gold);
  border-radius: 0 8px 8px 0;
  padding: 14px 16px;
  margin-bottom: 22px;
}
.nmodal-ai-badge {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--gold);
  text-transform: uppercase;
  display: block;
  margin-bottom: 8px;
  opacity: 0.85;
}
.nmodal-summary {
  font-size: 14px;
  line-height: 1.7;
  color: rgba(255,255,255,0.82);
  margin: 0;
}
.nmodal-read-btn {
  display: inline-block;
  padding: 10px 22px;
  background: linear-gradient(135deg, var(--gold), #b8922a);
  color: #000;
  font-weight: 700;
  font-size: 13px;
  border-radius: 8px;
  text-decoration: none;
  transition: opacity 0.2s;
}
.nmodal-read-btn:hover { opacity: 0.85; }
@media (max-width: 600px) {
  .nmodal-title { font-size: 17px; }
  .nmodal-body { padding: 16px 16px 22px; }
}

.tl-item {
  display: grid;
  grid-template-columns: 64px 28px 1fr;
  gap: 0 12px;
  text-decoration: none;
  padding: 4px 0;
  transition: background .15s;
  border-radius: 10px;
}
.tl-item:hover .tl-body { background: rgba(212,169,64,.05); }
.tl-item:hover .tl-dot  { background: var(--gold); box-shadow: 0 0 8px rgba(212,169,64,.6); }
.tl-item:hover .tl-title { color: var(--gold); }

.tl-date-col {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  padding-top: 14px;
  min-width: 64px;
}
.tl-day { font-size: 20px; font-weight: 800; color: var(--text); line-height: 1; }
.tl-mon { font-size: 10px; color: var(--text-muted); letter-spacing: .4px; white-space: nowrap; }

.tl-dot-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 18px;
}
.tl-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: rgba(212,169,64,.4);
  border: 2px solid var(--gold);
  flex-shrink: 0;
  transition: background .15s, box-shadow .15s;
  z-index: 1;
}
.tl-line {
  flex: 1;
  width: 1px;
  background: rgba(212,169,64,.15);
  margin-top: 4px;
  min-height: 20px;
}
.tl-item:last-child .tl-line { display: none; }

.tl-body {
  padding: 10px 14px 16px 4px;
  border-radius: 10px;
  transition: background .15s;
}
.tl-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--text);
  line-height: 1.4;
  margin-bottom: 4px;
  transition: color .15s;
}
.tl-desc {
  font-size: 12px;
  color: var(--text-muted);
  line-height: 1.6;
  margin: 0 0 6px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.tl-read { font-size: 11px; color: var(--gold); font-weight: 600; }

@media (max-width: 600px) {
  .tl-item { grid-template-columns: 52px 24px 1fr; }
  .tl-day  { font-size: 16px; }
}

/* ── Indices Strip ───────────────────────────────────── */
.idx-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  padding: 4px 0;
}
.idx-pill {
  display: flex;
  flex-direction: column;
  gap: 5px;
  background: var(--navy-2);
  border: 1px solid var(--border);
  border-top: 3px solid transparent;
  border-radius: 10px;
  padding: 16px 18px 14px;
  overflow: hidden;
  transition: border-color 0.2s, background 0.2s;
}
.idx-pill.up { border-top-color: #22c55e; background: rgba(34,197,94,0.03); }
.idx-pill.dn { border-top-color: #ef4444; background: rgba(239,68,68,0.03); }
.idx-pill:hover { border-color: rgba(212,169,64,0.4); }

.idx-pill-name {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.8px;
  color: var(--text-muted);
  text-transform: uppercase;
  white-space: nowrap;
}
.idx-pill-price {
  font-size: 20px;
  font-weight: 800;
  color: #fff;
  white-space: nowrap;
  line-height: 1.1;
}
.idx-pill-chg {
  font-size: 13px;
  font-weight: 700;
  white-space: nowrap;
}
.idx-pill.up .idx-pill-chg { color: #22c55e; }
.idx-pill.dn .idx-pill-chg { color: #ef4444; }

/* Pill skeleton shimmer */
.idx-pill.skeleton .idx-pill-price,
.idx-pill.skeleton .idx-pill-chg,
.idx-pill.skeleton .idx-pill-name {
  background: linear-gradient(90deg,rgba(255,255,255,.05) 25%,rgba(255,255,255,.12) 50%,rgba(255,255,255,.05) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 4px;
  color: transparent !important;
  min-width: 52px;
  min-height: 13px;
  display: inline-block;
}

/* ── Top 5 Stocks Pie Chart ──────────────────────────── */
.pie-layout {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 28px;
  align-items: center;
}
.pie-chart-wrap {
  position: relative;
  width: 260px;
  height: 260px;
  flex-shrink: 0;
}
#stockPieChart { display: block; cursor: pointer; }
.pie-center {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  pointer-events: none;
}
.pie-center-sym {
  display: block;
  font-size: 15px;
  font-weight: 800;
  color: #fff;
  letter-spacing: 0.5px;
}
.pie-center-price {
  display: block;
  font-size: 13px;
  font-weight: 700;
  color: var(--gold);
  margin: 2px 0;
}
.pie-center-chg {
  display: block;
  font-size: 11px;
  font-weight: 600;
}
.pie-center-chg.up { color: #22c55e; }
.pie-center-chg.dn { color: #ef4444; }

/* Legend */
.pie-legend {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.pie-leg-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  background: linear-gradient(135deg, rgba(212,169,64,0.08), rgba(184,134,11,0.04));
  border: 1px solid rgba(212,169,64,0.18);
  border-radius: 9px;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s, transform 0.15s;
}
.pie-leg-item:hover, .pie-leg-item.active {
  background: rgba(212,169,64,0.15);
  border-color: rgba(212,169,64,0.4);
  transform: translateX(3px);
}
.pie-leg-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  flex-shrink: 0;
}
.pie-leg-body { flex: 1; min-width: 0; }
.pie-leg-sym {
  display: block;
  font-size: 13px;
  font-weight: 800;
  color: #fff;
  letter-spacing: 0.3px;
}
.pie-leg-name {
  display: block;
  font-size: 11px;
  color: var(--muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.pie-leg-right { text-align: right; flex-shrink: 0; }
.pie-leg-price {
  display: block;
  font-size: 13px;
  font-weight: 700;
  color: #fff;
}
.pie-leg-chg {
  display: block;
  font-size: 11px;
  font-weight: 600;
}
.pie-leg-chg.up { color: #22c55e; }
.pie-leg-chg.dn { color: #ef4444; }

@media (max-width: 700px) {
  .pie-layout { grid-template-columns: 1fr; justify-items: center; }
  .pie-chart-wrap { width: 220px; height: 220px; }
}

/* keep badge styles for other pages */
.mkt-badge { font-size: 10px; font-weight: 700; padding: 3px 7px; border-radius: 5px; display: inline-block; }
.badge-up { background: rgba(34,197,94,0.15); color: #22c55e; }
.badge-dn { background: rgba(239,68,68,0.15); color: #ef4444; }
@media (max-width: 700px) {
  .idx-strip { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 400px) {
  .idx-strip { grid-template-columns: 1fr 1fr; }
}
</style>

<script>
  // ── All data from local JSON files (updated daily by GitHub Actions) ──
  const IDX_MAP: Record<string,string> = {
    '^NSEI':'NSEI','^BSESN':'BSESN','^NSEBANK':'NSEBANK','^CNXSC':'MID',
    '^CNXIT':'IT','^CNXAUTO':'AUTO','^CNXPHARMA':'PHARMA','^CNXFMCG':'FMCG'
  };

  function renderIndiaIndex(q: any) {
    const key = IDX_MAP[q.symbol]; if (!key) return;
    const chg=q.regularMarketChange??0, pct=q.regularMarketChangePercent??0, up=chg>=0;
    const color=up?'#22c55e':'#ef4444';
    // Store for modal
    const card=document.getElementById(`hidx-${key}`);
    if(card?.dataset?.idx) _idxHomeLive[card.dataset.idx]={price:q.regularMarketPrice,pct};
    if(card){card.classList.remove('skeleton');card.classList.add(up?'up':'dn');}
    const pEl=document.getElementById(`hidx-${key}-price`);
    if(pEl) pEl.textContent=q.regularMarketPrice?.toLocaleString('en-IN',{maximumFractionDigits:2});
    const cEl=document.getElementById(`hidx-${key}-chg`);
    if(cEl){cEl.textContent=`${up?'▲':'▼'} ${Math.abs(pct).toFixed(2)}%`;(cEl as HTMLElement).style.color=color;}
  }

  async function loadIndiaIndices() {
    try {
      const res = await fetch('/data/india-indices.json');
      const data = await res.json();
      data.indices.forEach(renderIndiaIndex);
    } catch(e) { console.error('indices load failed', e); }
  }

  // ── Pie chart for Top 5 stocks ──────────────────────────
  const PIE_SYMS = ['RELIANCE.NS','TCS.NS','HDFCBANK.NS','INFY.NS','ICICIBANK.NS'];
  const PIE_COLORS = ['#D4A940','#22c55e','#3b82f6','#a855f7','#f97316'];
  let _pieChart: any = null;
  let _pieStocks: any[] = [];
  let _pieActive = 0;

  function initPieChart(stocks: any[]) {
    _pieStocks = stocks;
    const canvas = document.getElementById('stockPieChart') as HTMLCanvasElement;
    if (!canvas || !(window as any).Chart) return;

    // Colour legend dots
    PIE_SYMS.forEach((sym, i) => {
      const dot = document.getElementById(`pld-${i}`);
      if (dot) (dot as HTMLElement).style.background = PIE_COLORS[i];
    });

    const prices = stocks.map(s => s.regularMarketPrice || 1);
    const total  = prices.reduce((a,b)=>a+b,0);

    _pieChart = new (window as any).Chart(canvas, {
      type: 'doughnut',
      data: {
        labels: PIE_SYMS.map(s => s.replace('.NS','')),
        datasets: [{
          data: prices.map(p => +((p/total*100).toFixed(2))),
          backgroundColor: PIE_COLORS,
          borderColor: '#0a0904',
          borderWidth: 3,
          hoverBorderWidth: 0,
          hoverOffset: 8,
        }]
      },
      options: {
        cutout: '68%',
        plugins: { legend: { display: false }, tooltip: { enabled: false } },
        animation: { animateRotate: true, duration: 900 },
        onClick(_e: any, els: any[]) {
          if (els.length) updatePieCenter(els[0].index);
        },
        onHover(_e: any, els: any[]) {
          (canvas as HTMLElement).style.cursor = els.length ? 'pointer' : 'default';
        }
      }
    });

    updatePieCenter(0);
  }

  function updatePieCenter(idx: number) {
    _pieActive = idx;
    const q = _pieStocks[idx];
    if (!q) return;
    const chg = q.regularMarketChange ?? 0;
    const pct = q.regularMarketChangePercent ?? 0;
    const up  = chg >= 0;

    const priceEl = document.getElementById('piePrice');
    const chgEl   = document.getElementById('pieChg');
    if (priceEl) priceEl.textContent = `₹${(q.regularMarketPrice||0).toLocaleString('en-IN',{maximumFractionDigits:2})}`;
    if (chgEl) {
      chgEl.textContent = `${up?'▲':'▼'} ${Math.abs(pct).toFixed(2)}%`;
      chgEl.className = `pie-center-chg ${up?'up':'dn'}`;
    }

    // Highlight legend row
    PIE_SYMS.forEach((sym, i) => {
      document.getElementById(`pl-${sym}`)?.classList.toggle('active', i === idx);
    });
  }

  function renderPieLegend(q: any) {
    const idx = PIE_SYMS.indexOf(q.symbol);
    if (idx < 0) return;
    const chg = q.regularMarketChange ?? 0;
    const pct = q.regularMarketChangePercent ?? 0;
    const up  = chg >= 0;

    const nameEl  = document.getElementById(`pln-${q.symbol}`);
    const priceEl = document.getElementById(`plp-${q.symbol}`);
    const chgEl   = document.getElementById(`plc-${q.symbol}`);
    if (nameEl) nameEl.textContent = q.name || q.symbol.replace('.NS','');
    if (priceEl) priceEl.textContent = `₹${(q.regularMarketPrice||0).toLocaleString('en-IN',{maximumFractionDigits:2})}`;
    if (chgEl) {
      chgEl.textContent = `${up?'+':''}${pct.toFixed(2)}%`;
      chgEl.className = `pie-leg-chg ${up?'up':'dn'}`;
    }
  }

  async function loadMarkets() {
    try {
      const res = await fetch('/data/india-stocks.json');
      const data = await res.json();
      const top5 = PIE_SYMS.map(sym => data.nse.find((s:any) => s.symbol === sym)).filter(Boolean);
      top5.forEach(renderPieLegend);
      initPieChart(top5);

      // Legend click → highlight segment
      PIE_SYMS.forEach((sym, i) => {
        document.getElementById(`pl-${sym}`)?.addEventListener('click', (e) => {
          e.preventDefault();
          updatePieCenter(i);
          // Navigate after short delay so user sees highlight
          setTimeout(() => window.location.href =
            `/company/${sym.toLowerCase().replace(/\./g,'-')}`, 300);
        });
      });
    } catch(e) { console.error('stocks load failed', e); }
  }

  async function loadMarketPulse() {
    // ── VIX from local JSON ──────────────────────────────
    try {
      const res = await fetch('/data/india-indices.json');
      const data = await res.json();
      const vixQ = data.indices?.find((i:any) => i.symbol === '^INDIAVIX');
      if (vixQ && vixQ.regularMarketPrice) {
        const vix = vixQ.regularMarketPrice;
        const pct = vixQ.regularMarketChangePercent ?? 0;
        const color = vix < 15 ? '#10ef62' : vix < 22 ? '#eab308' : '#ff4757';
        const label = vix < 15 ? 'Low fear — market calm' : vix < 22 ? 'Moderate — normal range' : 'High fear — watch out';

        const gaugeVal = document.getElementById('vixGaugeVal');
        const vixArc   = document.getElementById('vixArc') as SVGPathElement|null;
        const vixNeedle= document.getElementById('vixNeedle') as SVGLineElement|null;
        const vixSub   = document.getElementById('vixSub');

        if (gaugeVal) { gaugeVal.textContent = vix.toFixed(1); gaugeVal.setAttribute('fill', color); }
        if (vixSub) vixSub.textContent = `${pct >= 0 ? '+' : ''}${pct.toFixed(2)}% today · ${label}`;

        // Needle: -90deg = left (VIX=0), 0deg = top (VIX=20), +90deg = right (VIX=40)
        const deg = -90 + Math.min(vix / 40, 1) * 180;
        if (vixNeedle) vixNeedle.style.transform = `rotate(${deg}deg)`;
        const shadow = document.getElementById('vixNeedleShadow');
        if (shadow) (shadow as SVGLineElement).style.transform = `rotate(${deg}deg)`;
      }
    } catch(e) {
      const s = document.getElementById('vixSub'); if(s) s.textContent = 'Data updates after market close';
    }

    // ── Nifty P/E (static estimate — NSE doesn't expose via free API) ──
    const PE_VAL = 22.4;
    const peEl  = document.getElementById('niftyPE');
    const peIns = document.getElementById('niftyPEInsight');
    const peMkr = document.getElementById('peMarker') as HTMLElement|null;
    if (peEl) peEl.textContent = `${PE_VAL}x`;
    if (peIns) peIns.textContent = PE_VAL < 18 ? '🟢 Undervalued — good entry zone' : PE_VAL < 24 ? '🟡 Fair value — normal range' : PE_VAL < 28 ? '🟠 Slightly pricey' : '🔴 Overvalued — caution';
    // Marker: PE scale 10–32, map to 0–100%
    if (peMkr) peMkr.style.left = `${Math.min(Math.max((PE_VAL - 10) / 22 * 100, 2), 98)}%`;

    // ── FII / DII — local JSON first, NSE API fallback ──
    const setFiiBar = (posId:string, negId:string, valId:string, net:number, maxAbs:number) => {
      const pct = Math.abs(net) / maxAbs * 100;
      const pos = document.getElementById(posId), neg = document.getElementById(negId), val = document.getElementById(valId);
      if (net >= 0) { if(pos) pos.style.width=pct+'%'; if(neg) neg.style.width='0%'; }
      else           { if(neg) neg.style.width=pct+'%'; if(pos) pos.style.width='0%'; }
      if (val) { val.textContent = `${net>=0?'+':''}₹${Math.abs(net/100).toFixed(0)}Cr`; (val as HTMLElement).style.color = net>=0?'#10ef62':'#ff4757'; }
    };
    let fiiLoaded = false;
    try {
      const r = await fetch('/data/fii-dii.json');
      const d = await r.json();
      if (d?.data?.length > 0) {
        const latest = d.data[0];
        const fiiNet = latest.fiiNet * 100, diiNet = latest.diiNet * 100;
        const maxAbs = Math.max(Math.abs(fiiNet), Math.abs(diiNet), 100);
        setFiiBar('fiiBarPos','fiiBarNeg','fiiVal', fiiNet, maxAbs);
        setFiiBar('diiBarPos','diiBarNeg','diiVal', diiNet, maxAbs);
        const sub = document.getElementById('fiiSub');
        if (sub) sub.textContent = `${latest.date||'Latest'} · Source: NSE India`;
        fiiLoaded = true;
      }
    } catch {}
    if (!fiiLoaded) {
      // Try live NSE API as fallback
      try {
        const r = await fetch('https://corsproxy.io/?' + encodeURIComponent('https://www.nseindia.com/api/fiidiiTradeReact'), { signal: AbortSignal.timeout(8000) });
        const d = await r.json();
        if (d && Array.isArray(d) && d.length > 0) {
          const latest = d[0];
          const fiiNet = parseFloat(latest.fiiNet || latest.fii_net || 0);
          const diiNet = parseFloat(latest.diiNet || latest.dii_net || 0);
          const maxAbs = Math.max(Math.abs(fiiNet), Math.abs(diiNet), 100);
          setFiiBar('fiiBarPos','fiiBarNeg','fiiVal', fiiNet*100, maxAbs*100);
          setFiiBar('diiBarPos','diiBarNeg','diiVal', diiNet*100, maxAbs*100);
          const sub = document.getElementById('fiiSub');
          if (sub) sub.textContent = `${latest.date||'Latest'} · Source: NSE India`;
          fiiLoaded = true;
        }
      } catch {}
    }
    if (!fiiLoaded) {
      const fiiV=document.getElementById('fiiVal'), diiV=document.getElementById('diiVal'), sub=document.getElementById('fiiSub');
      if(fiiV) { fiiV.textContent = 'N/A'; fiiV.style.color = 'var(--text-muted)'; }
      if(diiV) { diiV.textContent = 'N/A'; diiV.style.color = 'var(--text-muted)'; }
      if(sub)  sub.textContent = 'Updates daily after market close (3:30 PM IST)';
    }

    // ── Market Mood donut — from index breadth ──────────
    setTimeout(() => {
      const greenCount = document.querySelectorAll('.idx-pill.up').length;
      const redCount   = document.querySelectorAll('.idx-pill.dn').length;
      const total      = greenCount + redCount || 8;
      const circ       = 289; // 2π × 46
      const greenDash  = (greenCount / total) * circ;
      const redDash    = (redCount   / total) * circ;

      const gArc = document.getElementById('moodGreen') as SVGCircleElement|null;
      const rArc = document.getElementById('moodRed')   as SVGCircleElement|null;
      if (gArc) { gArc.style.strokeDashoffset = String(circ - greenDash); gArc.style.strokeDasharray = `${greenDash} ${circ - greenDash}`; }
      if (rArc) {
        // offset red arc to start after green
        rArc.style.strokeDasharray = `${redDash} ${circ - redDash}`;
        rArc.style.strokeDashoffset = String(circ - greenDash);
        rArc.style.transform = `rotate(${(greenCount/total)*360 - 90}deg)`;
        rArc.style.transformOrigin = '60px 60px';
      }

      const pct = Math.round(greenCount / total * 100);
      const pctEl  = document.getElementById('moodPct');
      const lblEl  = document.getElementById('moodLabel');
      const gCount = document.getElementById('moodGreenCount');
      const rCount = document.getElementById('moodRedCount');
      const moodV  = document.getElementById('moodVal');
      const moodI  = document.getElementById('moodInsight');

      if (pctEl) { pctEl.textContent = pct + '%'; pctEl.setAttribute('fill', pct > 60 ? '#10ef62' : pct > 40 ? '#eab308' : '#ff4757'); }
      if (lblEl) lblEl.textContent = 'green';
      if (gCount) gCount.textContent = String(greenCount);
      if (rCount) rCount.textContent = String(redCount);
      const mood   = pct >= 80 ? 'Very Bullish' : pct >= 60 ? 'Bullish' : pct >= 45 ? 'Neutral' : pct >= 25 ? 'Bearish' : 'Very Bearish';
      const advice = pct >= 80 ? 'Strong broad rally — most sectors green.' : pct >= 60 ? 'Most sectors advancing.' : pct >= 45 ? 'Mixed signals — be selective.' : pct >= 25 ? 'Broad selling — watch levels.' : 'Heavy selling across sectors.';
      const moodColor = pct >= 60 ? '#10ef62' : pct >= 45 ? '#eab308' : '#ff4757';
      if (moodV) { moodV.textContent = mood; (moodV as HTMLElement).style.color = moodColor; }
      if (moodI) moodI.textContent = advice;
    }, 3500);
  }

  // News ticker for Indian markets
  async function loadNews() {
    const list=document.getElementById('newsList');
    if(!list) return;
    try{
      const r=await fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent('https://economictimes.indiatimes.com/markets/rssfeeds/1977021501.cms')}&count=10`);
      const d=await r.json();
      const items=d?.items||[];
      if(!items.length) throw new Error('empty');
      list.innerHTML=items.map((item:any)=>{
        const date=new Date(item.pubDate).toLocaleDateString('en-IN',{month:'short',day:'numeric'});
        return `<a href="${item.link}" class="news-item" target="_blank" rel="noopener"><div class="ni-title">${item.title}</div><div class="ni-meta">Economic Times · ${date}</div></a>`;
      }).join('');
    }catch{}
  }

  // Spotlight — autocomplete + fuzzy match
  let _slTickers: {symbol:string,name:string,sector:string,file:string}[] = [];
  async function slLoadTickers() {
    if(_slTickers.length) return;
    try{ const r=await fetch('/data/tickers.json'); _slTickers=await r.json(); }catch{}
  }
  function slSearch(q:string) {
    if(!q||q.length<1) return [];
    const lq=q.toLowerCase();
    return _slTickers.filter(t=>
      t.symbol.toLowerCase().startsWith(lq)||
      t.name.toLowerCase().includes(lq)||
      t.symbol.toLowerCase().includes(lq)
    ).slice(0,8);
  }
  const slInput=document.getElementById('slInput') as HTMLInputElement;
  const slDropdown=document.getElementById('slDropdown') as HTMLDivElement;
  slLoadTickers();
  slInput?.addEventListener('input',()=>{
    const q=slInput.value.trim();
    const matches=slSearch(q);
    if(!matches.length||!q){slDropdown.style.display='none';return;}
    slDropdown.innerHTML=matches.map(t=>`
      <div class="sl-dd-item" data-symbol="${t.symbol}" data-file="${t.file}"
        style="padding:10px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(212,169,64,0.1);transition:background 0.15s">
        <div>
          <span style="font-weight:700;color:#fff;font-size:14px">${t.symbol}</span>
          <span style="font-size:12px;color:var(--text-muted);margin-left:8px">${t.name}</span>
        </div>
        <span style="font-size:10px;color:var(--gold);background:rgba(212,169,64,0.12);padding:2px 8px;border-radius:10px">${t.sector||'NSE'}</span>
      </div>`).join('');
    slDropdown.style.display='block';
    slDropdown.querySelectorAll('.sl-dd-item').forEach(el=>{
      (el as HTMLElement).addEventListener('mouseover',()=>(el as HTMLElement).style.background='rgba(212,169,64,0.10)');
      (el as HTMLElement).addEventListener('mouseout',()=>(el as HTMLElement).style.background='');
      el.addEventListener('click',()=>{
        const sym=(el as HTMLElement).dataset.symbol||'';
        slInput.value=sym;
        slDropdown.style.display='none';
        loadSpotlight(sym);
      });
    });
  });
  document.addEventListener('click',(e)=>{if(!(e.target as Element)?.closest?.('.spotlight-search'))slDropdown.style.display='none';});

  async function loadSpotlight(rawSym: string) {
    const result=document.getElementById('slResult');
    if(!result) return;
    const s=rawSym.toUpperCase().trim();
    // Try to find the ticker in our manifest first
    await slLoadTickers();
    let fileEntry=_slTickers.find(t=>t.symbol===s);
    if(!fileEntry){
      // Fuzzy fallback: partial match
      fileEntry=_slTickers.find(t=>t.symbol.startsWith(s)||t.name.toLowerCase().includes(s.toLowerCase()));
    }
    const fname=fileEntry?fileEntry.file:(s+'-NS');
    const sym=fname.replace(/-/g,'.');  // for display
    result.innerHTML=`<p class="sl-hint">Analyzing ${fileEntry?.name||s}…</p>`;
    try{
      const res=await fetch(`/data/company/${fname}.json`);
      if(!res.ok) {
        // Suggest close matches
        const suggestions=_slTickers.filter(t=>t.symbol.includes(s)||t.name.toLowerCase().includes(s.toLowerCase())).slice(0,5);
        const sugHtml=suggestions.length?`<div style="margin-top:12px"><div style="font-size:11px;color:var(--text-muted);margin-bottom:8px">Did you mean:</div>${suggestions.map(t=>`<span onclick="document.getElementById('slInput').value='${t.symbol}';loadSpotlightExt('${t.symbol}')" style="display:inline-block;margin:3px;padding:5px 12px;background:rgba(212,169,64,0.12);border:1px solid rgba(212,169,64,0.3);border-radius:8px;cursor:pointer;font-size:12px;color:var(--gold)">${t.symbol} <span style="color:var(--text-muted)">${t.name}</span></span>`).join('')}</div>`:'';
        result.innerHTML=`<p class="sl-hint" style="color:#ef4444">No data for "${rawSym}" yet.${!sugHtml?' Try: RELIANCE, TCS, HDFCBANK, INFY, SBIN':''}</p>${sugHtml}`;
        return;
      }
      const d=await res.json();
      if(!d.regularMarketPrice) throw new Error('not found');
      const price=d.regularMarketPrice,chg=d.regularMarketChange||0,pct=d.regularMarketChangePercent||0;
      const high52=d.fiftyTwoWeekHigh||price,low52=d.fiftyTwoWeekLow||price;
      const up=chg>=0,color=up?'#22c55e':'#ef4444';
      const mcap=d.marketCap>=1e12?`₹${(d.marketCap/1e12).toFixed(2)}T`:d.marketCap>=1e9?`₹${(d.marketCap/1e9).toFixed(1)}B`:d.marketCap>=1e7?`₹${(d.marketCap/1e7).toFixed(0)}Cr`:'—';
      const priceVsHigh=high52>low52?((price-low52)/(high52-low52))*100:50;
      const momentum=pct>1?'Strong positive':pct>0?'Mild positive':pct>-1?'Mild negative':'Strong negative';
      const score=Math.max(10,Math.min(90,Math.round(50+pct*2-(priceVsHigh-50)*0.3)));
      const action=score>65?'🟢 Bullish — consider buying on dips':score>40?'🟡 Neutral — hold and watch':'🔴 Bearish — wait for better entry';
      const actionColor=score>65?'#22c55e':score>40?'#eab308':'#ef4444';
      const entryAdvice=score>65?'Consider SIP entry or buy on 3–5% dip. Price is well-positioned in its 52-week range.':score>40?'No strong signal yet. Use SIP or wait for breakout confirmation on high volume.':'Under selling pressure. Wait for RSI < 40 and price stabilization near 52W low before entering.';
      result.innerHTML=`
        <div class="sl-company">${d.longName||sym.replace('.NS','')} <span style="font-size:12px;color:var(--text-muted);font-weight:400">${d.sector||''}</span></div>
        <div class="sl-price-row">
          <span class="sl-price" style="color:var(--gold)">₹${price.toLocaleString('en-IN',{maximumFractionDigits:2})}</span>
          <span class="sl-delta" style="color:${color}">${up?'▲':'▼'} ₹${Math.abs(chg).toFixed(2)} (${up?'+':''}${pct.toFixed(2)}%)</span>
        </div>
        <div class="sl-stats">
          <div class="sl-stat"><span>Market Cap</span><strong>${mcap}</strong></div>
          <div class="sl-stat"><span>52W High</span><strong>₹${high52.toFixed(2)}</strong></div>
          <div class="sl-stat"><span>52W Low</span><strong>₹${low52.toFixed(2)}</strong></div>
          <div class="sl-stat"><span>vs 52W Range</span><strong>${priceVsHigh.toFixed(0)}%</strong></div>
          <div class="sl-stat"><span>Momentum</span><strong>${momentum}</strong></div>
          <div class="sl-stat"><span>Exchange</span><strong>NSE</strong></div>
        </div>
        <div style="background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.2);border-radius:10px;padding:14px 18px;margin-top:14px">
          <div style="font-size:10px;font-weight:700;letter-spacing:.8px;color:var(--gold);margin-bottom:6px">AI INVESTMENT INSIGHT</div>
          <div style="font-size:15px;font-weight:700;color:${actionColor};margin-bottom:6px">${action}</div>
          <div style="font-size:12px;color:var(--text-muted)">${entryAdvice}</div>
          <div style="font-size:11px;color:var(--text-dim);margin-top:8px">⚠️ Algorithmic analysis only — not financial advice. Always DYOR.</div>
        </div>
        <a href="/company/${(fileEntry?.file||fname).toLowerCase()}" style="display:inline-block;margin-top:12px;background:var(--gold);color:#0b0f1a;padding:8px 20px;border-radius:8px;font-size:12px;font-weight:700">Full Deep Dive →</a>
      `;
    }catch{
      const suggestions=_slTickers.filter(t=>t.symbol.includes(s)||t.name.toLowerCase().includes(s.toLowerCase())).slice(0,5);
      const sugHtml=suggestions.length?`<div style="margin-top:12px">${suggestions.map(t=>`<span onclick="document.getElementById('slInput').value='${t.symbol}';loadSpotlightExt('${t.symbol}')" style="display:inline-block;margin:3px;padding:5px 12px;background:rgba(212,169,64,0.12);border:1px solid rgba(212,169,64,0.3);border-radius:8px;cursor:pointer;font-size:12px;color:var(--gold)">${t.symbol}</span>`).join('')}</div>`:'';
      result.innerHTML=`<p class="sl-hint" style="color:#ef4444">No data available for "${rawSym}" yet.</p>${sugHtml}`;
    }
  }
  (window as any).loadSpotlightExt=(sym:string)=>loadSpotlight(sym);

  document.getElementById('slBtn')?.addEventListener('click',()=>{const v=slInput?.value;if(v?.trim()){slDropdown.style.display='none';loadSpotlight(v.trim());}});
  slInput?.addEventListener('keydown',(e:KeyboardEvent)=>{if(e.key==='Enter'){slDropdown.style.display='none';const v=slInput?.value;if(v?.trim()) loadSpotlight(v.trim());}});

  // ── Index card click → modal ─────────────────────────
  const _IDX_INFO: Record<string,{title:string,icon:string,what:string,who:string,why:string,movers:string,sip:string}> = {
    NSEI:{title:'NIFTY 50',icon:'📊',what:'NIFTY 50 tracks the 50 largest companies on NSE — India\'s main stock exchange. Think of it as a report card for the country\'s biggest businesses: Reliance, TCS, HDFC Bank, Infosys, ICICI Bank. When NIFTY rises, it means investors are confident. When it falls, they\'re cautious.',who:'Financial Services (~33%), IT (~13%), Oil & Gas (~12%), Consumer Goods (~9%), Auto (~6%). Top stocks: Reliance, HDFC Bank, Infosys, ICICI Bank, TCS.',why:'A rising NIFTY means corporate earnings are growing, the economy is healthy, and money is flowing into India. A falling NIFTY means uncertainty — it could be global (US recession fears, oil prices) or local (RBI rate hikes, weak earnings).',movers:'US markets overnight, FII/DII flows, RBI rate decisions, quarterly earnings, crude oil prices, USD/INR rate, and major government policy announcements.',sip:'Your equity mutual fund SIP benchmarks against NIFTY. When NIFTY dips, your SIP buys more units at lower prices — actually building more long-term wealth.'},
    BSESN:{title:'SENSEX',icon:'🏛️',what:'SENSEX is India\'s oldest stock index (since 1986), tracking the top 30 companies on BSE (Bombay Stock Exchange). More concentrated than NIFTY — just 30 stocks — so one big move in Reliance or HDFC Bank can swing it noticeably.',who:'Reliance, HDFC Bank, Infosys, ICICI Bank, TCS, L&T, Bajaj Finance, Kotak Mahindra Bank dominate — these 8 stocks alone make up ~50% of the index.',why:'SENSEX is the face of India internationally. When global media or investors talk about Indian markets, they quote SENSEX. Tracks India\'s entire economic history since the 1980s.',movers:'Same as NIFTY 50 but more sensitive to banking sector moves since banking stocks are heavily weighted.',sip:'SENSEX and NIFTY move almost identically (99%+ correlation). Treat them as the same signal for your investment decisions.'},
    NSEBANK:{title:'NIFTY BANK',icon:'🏦',what:'NIFTY Bank tracks India\'s 12 largest banking stocks. Banks are the economy\'s backbone — they lend to businesses, manage your savings, and drive credit growth. When banks do well, the whole economy usually follows.',who:'HDFC Bank, ICICI Bank, Kotak Mahindra Bank, SBI, Axis Bank, IndusInd Bank, Bank of Baroda, Federal Bank. Private banks (HDFC + ICICI) carry ~60% of the weight.',why:'NIFTY Bank is more volatile than NIFTY 50 and reacts sharply to RBI decisions, NPA (bad loan) data, and credit demand. A falling NIFTY Bank often drags down the broader market.',movers:'RBI Monetary Policy meetings, bank quarterly results (NPA levels, net interest margin), credit growth data, and US Federal Reserve rate decisions (affects FII flows).',sip:'Banking sector funds track NIFTY Bank. Rising NIFTY Bank = banks are profitable, loans are being repaid, credit is growing = healthy economy.'},
    NIFTYMIDCAP:{title:'SMALLCAP / MIDCAP',icon:'🚀',what:'Tracks mid-sized Indian companies (₹5,000–₹20,000 Cr market cap) — the next generation of potential large-caps. They grow faster than large-caps but are also riskier and more volatile.',who:'Diverse mix: specialty chemicals, auto ancillaries, specialty pharma, consumer brands, IT services. Examples: Persistent Systems, Metropolis Healthcare, Navin Fluorine.',why:'Midcap/smallcap indices are leading indicators — they react faster to economic changes. When retail investors are optimistic, they pile into small-caps first. When fear strikes, they exit first too.',movers:'Domestic retail investor sentiment, Budget announcements, GST collections, domestic consumption data. Less driven by global cues than NIFTY 50.',sip:'Smallcap funds can give 2–3x NIFTY returns in bull markets but can fall 40–60% in bear markets. Best suited for long-term (10+ year) SIPs that can ride out volatility.'},
    IT:{title:'NIFTY IT',icon:'💻',what:'Tracks India\'s top IT companies — TCS, Infosys, Wipro, HCL Tech, Tech Mahindra. These companies earn most of their revenue in US dollars but pay salaries in rupees, so currency movements matter a lot.',who:'TCS, Infosys, HCL Technologies, Wipro, Tech Mahindra, LTIMindtree, Mphasis, Coforge. Top 2 (TCS + Infosys) carry ~55% of the weight.',why:'When USD strengthens against INR, Indian IT companies earn more in rupee terms — like a pay raise. When US companies cut tech spending (like in 2023), Indian IT order books shrink.',movers:'USD/INR rate, US tech sector spending (guided by US company results), Fed rate decisions, US GDP data, and global outsourcing trends.',sip:'IT sector funds are good bets during weak rupee periods. But they underperform when global tech spending slows — as seen in 2022–23.'},
    AUTO:{title:'NIFTY AUTO',icon:'🚗',what:'Tracks India\'s top automobile companies — from Maruti and Tata Motors to Bajaj Auto and Hero MotoCorp. Reflects consumer spending confidence: when people buy cars and bikes, the economy is doing well.',who:'Maruti Suzuki, Mahindra & Mahindra, Tata Motors, Bajaj Auto, Hero MotoCorp, Eicher Motors, TVS Motor, Bosch India.',why:'Auto sales are a real-time pulse of Indian consumer confidence. Strong auto sales = people have money and are spending it. Weak sales = economic stress.',movers:'Fuel prices (petrol/diesel directly affects demand), interest rates (auto loans), monsoon (rural demand for two-wheelers), raw material costs (steel, aluminium), and EV policy announcements.',sip:'Auto sector funds do well during economic expansion and consumer boom cycles. Watch monthly SIAM auto sales data as a leading indicator.'},
    PHARMA:{title:'NIFTY PHARMA',icon:'💊',what:'Tracks India\'s top pharmaceutical companies — Sun Pharma, Dr. Reddy\'s, Cipla, Divi\'s Laboratories. India is the "pharmacy of the world," supplying ~20% of global generic medicines. Pharma is often a defensive sector during market downturns.',who:'Sun Pharma, Dr. Reddy\'s Laboratories, Cipla, Divi\'s Labs, Biocon, Aurobindo Pharma, Lupin, Alkem Laboratories.',why:'Pharma stocks are defensive — people need medicines regardless of the economy. During market crashes, pharma often holds up better than other sectors. US FDA approvals can send a pharma stock surging overnight.',movers:'US FDA inspection outcomes, USFDA drug approvals, currency (many pharma cos earn in USD), API (raw material) prices from China, and domestic pricing policy.',sip:'Pharma sector funds are good for portfolio stability. They don\'t grow as fast as IT or auto in bull markets, but they protect capital during downturns.'},
    FMCG:{title:'NIFTY FMCG',icon:'🛒',what:'Tracks Fast-Moving Consumer Goods companies — HUL, ITC, Nestle, Britannia, Dabur, Marico. These sell everyday products: soap, shampoo, biscuits, noodles, cigarettes. Revenues are stable and predictable since people buy these regardless of the market.',who:'Hindustan Unilever (HUL), ITC, Nestle India, Britannia, Dabur, Marico, Colgate-Palmolive, Emami.',why:'FMCG is the most defensive sector. It barely falls during market crashes — because demand for soap and biscuits doesn\'t disappear in a recession. But it also grows slowly in bull markets.',movers:'Rural income (50% of FMCG sales come from rural India), monsoon (good rains = more rural cash = more FMCG spending), inflation (input cost: palm oil, wheat prices), and urban consumption trends.',sip:'FMCG sector funds are ideal for conservative investors. Low growth ceiling but strong downside protection. Good to hold alongside a more aggressive equity fund.'},
  };
  let _idxHomeLive: Record<string,{price:number,pct:number}> = {};

  function showHomePillModal(idxKey: string) {
    const info = _IDX_INFO[idxKey]; if(!info) return;
    const live = _idxHomeLive[idxKey];
    const up = (live?.pct??0) >= 0;
    const color = up ? '#22c55e' : '#ef4444';
    const priceHtml = live ? `<div style="display:flex;align-items:baseline;gap:14px;margin:14px 0 20px"><span style="font-size:1.9rem;font-weight:800;color:var(--gold)">${live.price.toLocaleString('en-IN',{maximumFractionDigits:2})}</span><span style="font-weight:700;color:${color}">${up?'▲':'▼'} ${Math.abs(live.pct).toFixed(2)}% today</span></div>` : '';
    document.getElementById('idxModalContent')!.innerHTML = `
      <div style="font-size:26px;margin-bottom:6px">${info.icon}</div>
      <div style="font-size:20px;font-weight:800;color:#fff;margin-bottom:2px">${info.title}</div>
      ${priceHtml}
      <div style="margin-bottom:14px"><div style="font-size:9px;font-weight:800;letter-spacing:1.5px;color:var(--gold);margin-bottom:4px">WHAT IS IT?</div><p style="font-size:13px;color:var(--text-muted);line-height:1.8;margin:0">${info.what}</p></div>
      <div style="margin-bottom:14px"><div style="font-size:9px;font-weight:800;letter-spacing:1.5px;color:var(--gold);margin-bottom:4px">WHO'S INSIDE?</div><p style="font-size:13px;color:var(--text-muted);line-height:1.8;margin:0">${info.who}</p></div>
      <div style="margin-bottom:14px"><div style="font-size:9px;font-weight:800;letter-spacing:1.5px;color:var(--gold);margin-bottom:4px">WHAT DOES IT SIGNAL?</div><p style="font-size:13px;color:var(--text-muted);line-height:1.8;margin:0">${info.why}</p></div>
      <div style="margin-bottom:14px"><div style="font-size:9px;font-weight:800;letter-spacing:1.5px;color:var(--gold);margin-bottom:4px">WHAT MOVES IT?</div><p style="font-size:13px;color:var(--text-muted);line-height:1.8;margin:0">${info.movers}</p></div>
      <div style="background:rgba(212,169,64,0.08);border:1px solid rgba(212,169,64,0.22);border-radius:10px;padding:14px 16px">
        <div style="font-size:9px;font-weight:800;letter-spacing:1px;color:var(--gold);margin-bottom:5px">💡 WHAT IT MEANS FOR YOUR SIP</div>
        <p style="font-size:13px;color:var(--text-muted);line-height:1.8;margin:0">${info.sip}</p>
      </div>
      <p style="font-size:10px;color:var(--text-dim);margin-top:14px;text-align:center">⚠️ Educational context only — not financial advice. Always DYOR.</p>`;
    document.getElementById('idxModal')!.style.display = 'block';
  }

  document.querySelectorAll('[data-idx]').forEach(el => {
    el.addEventListener('click', () => showHomePillModal((el as HTMLElement).dataset.idx || ''));
  });

  loadMarkets();
  loadIndiaIndices();
  loadNews();
  loadMarketPulse();
  setInterval(()=>{loadMarkets();loadIndiaIndices();loadMarketPulse();},60000);

  // ── Hero chip loading shimmer ─────────────────────────
  ['chip-nifty-val','chip-nifty-chg','chip-sensex-val','chip-sensex-chg','chip-rel-val','chip-rel-chg','chip-tcs-val','chip-tcs-chg'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.add('loading');
  });

  // ── Hero animated chart (sine wave that looks like a stock chart) ──
  function drawHeroChart() {
    const line = document.getElementById('heroChartLine');
    if (!line) return;
    const pts = [];
    const W = 200, H = 80, points = 40;
    let y = 50;
    for (let i = 0; i <= points; i++) {
      const x = (i / points) * W;
      y = y + (Math.random() - 0.46) * 8;
      y = Math.max(10, Math.min(70, y));
      pts.push(`${x},${y}`);
    }
    line.setAttribute('points', pts.join(' '));
  }
  drawHeroChart();
  setInterval(drawHeroChart, 3000);

  // ── Hero chips: update with real Nifty/Sensex/stock data ──
  async function updateHeroChips() {
    try {
      const [idxRes, stkRes] = await Promise.all([
        fetch('/data/india-indices.json'),
        fetch('/data/india-stocks.json')
      ]);
      const idxData = await idxRes.json();
      const stkData = await stkRes.json();

      const chips = [
        { valId:'chip-nifty-val',  chgId:'chip-nifty-chg',  q: idxData.indices?.find(i => i.symbol === '^NSEI') },
        { valId:'chip-sensex-val', chgId:'chip-sensex-chg', q: idxData.indices?.find(i => i.symbol === '^BSESN') },
        { valId:'chip-rel-val',    chgId:'chip-rel-chg',    q: stkData.nse?.find(s => s.symbol === 'RELIANCE.NS') },
        { valId:'chip-tcs-val',    chgId:'chip-tcs-chg',    q: stkData.nse?.find(s => s.symbol === 'TCS.NS') },
      ];

      for (const { valId, chgId, q } of chips) {
        const valEl = document.getElementById(valId);
        const chgEl = document.getElementById(chgId);
        if (!q) {
          if (valEl) { valEl.classList.remove('loading'); }
          if (chgEl) { chgEl.classList.remove('loading'); }
          continue;
        }
        const up = (q.regularMarketChangePercent ?? 0) >= 0;
        if (valEl) {
          valEl.classList.remove('loading');
          valEl.textContent = q.regularMarketPrice?.toLocaleString('en-IN', { maximumFractionDigits: 0 });
        }
        if (chgEl) {
          chgEl.classList.remove('loading');
          chgEl.textContent = `${up ? '▲' : '▼'} ${Math.abs(q.regularMarketChangePercent ?? 0).toFixed(2)}%`;
          chgEl.className = `chip-chg ${up ? 'up' : 'dn'}`;
        }
      }
    } catch(e) {
      // On failure, at least clear the loading state so labels show
      ['chip-nifty-val','chip-nifty-chg','chip-sensex-val','chip-sensex-chg',
       'chip-rel-val','chip-rel-chg','chip-tcs-val','chip-tcs-chg'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.remove('loading');
      });
    }
  }
  updateHeroChips();

  // ── News: client-side fetch + render + auto-refresh every 30 min ──────
  (function () {
    let _articles: any[] = [];

    const overlay  = document.getElementById('newsModal')!;
    const closeBtn = document.getElementById('nmodalClose')!;
    const imgWrap  = document.getElementById('nmodalImgWrap')!;
    const img      = document.getElementById('nmodalImg') as HTMLImageElement;
    const msource  = document.getElementById('nmodalSource')!;
    const mtime    = document.getElementById('nmodalTime')!;
    const mtitle   = document.getElementById('nmodalTitle')!;
    const msummary = document.getElementById('nmodalSummary')!;
    const readBtn  = document.getElementById('nmodalReadBtn') as HTMLAnchorElement;

    // ── modal open/close
    function openModal(idx: number) {
      const a = _articles[idx];
      if (!a) return;
      if (a.image) { img.src = a.image; img.alt = a.title; imgWrap.style.display = ''; }
      else imgWrap.style.display = 'none';
      msource.textContent = a.source || '';
      mtime.textContent = new Date(a.publishedAt).toLocaleString('en-IN', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
      mtitle.textContent = a.title;
      msummary.textContent = a.summary || a.excerpt || '';
      readBtn.href = a.url;
      overlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
    function closeModal() { overlay.style.display = 'none'; document.body.style.overflow = ''; }
    closeBtn.addEventListener('click', closeModal);
    overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

    // ── render news grid from articles array
    function renderNews(articles: any[]) {
      _articles = articles;
      const grid = document.getElementById('newsGrid')!;
      const footer = document.getElementById('newsFooter')! as HTMLElement;
      if (!articles.length) { grid.innerHTML = '<div class="news-loading">No news available.</div>'; return; }

      // Always use an article with an image as featured
      const featured = articles.find(a => a.image) || articles[0];
      const sides = articles.filter(a => a !== featured).slice(0, 10);

      // Featured card — title first, then image, then meta (MoneyControl style)
      const featTime = new Date(featured.publishedAt).toLocaleString('en-IN',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});
      const imgStyle = featured.image ? `style="background-image:url('${featured.image.replace(/'/g,"\\'")}');display:block"` : 'style="display:none"';
      const featHtml = `
        <button class="news-featured news-card-btn" data-idx="0">
          <div class="news-feat-body">
            <h3 class="news-feat-title">${featured.title}</h3>
          </div>
          <div class="news-feat-img-wrap" ${imgStyle} aria-hidden="true"></div>
          <div class="news-feat-meta">
            <span class="news-source-tag">${featured.source}</span>
            <span class="news-feat-time">${featTime}</span>
          </div>
        </button>`;

      // Side cards — compact, text-only (no thumbnail)
      const sidesHtml = sides.map((a, i) => `
        <button class="news-side-item news-card-btn" data-idx="${i+1}">
          <span class="news-side-source">${a.source}</span>
          <p class="news-side-title">${a.title}</p>
        </button>`).join('');

      grid.innerHTML = featHtml + `<div class="news-side">${sidesHtml}</div>`;

      // Wire click handlers
      grid.querySelectorAll<HTMLButtonElement>('.news-card-btn').forEach(btn => {
        btn.addEventListener('click', () => openModal(parseInt(btn.dataset.idx||'0', 10)));
      });

      footer.style.display = '';
    }

    // ── fetch /data/news.json and render
    async function fetchAndRenderNews() {
      const grid = document.getElementById('newsGrid');
      try {
        const res = await fetch('/data/news.json?t=' + Date.now(), { cache: 'no-store' });
        if (!res.ok) {
          if (grid) grid.innerHTML = '<div class="news-loading">Could not load news (HTTP ' + res.status + ')</div>';
          return;
        }
        const data = await res.json();
        renderNews(data.articles || []);
        const updEl = document.getElementById('newsUpdatedAt');
        if (updEl && data.lastUpdated) {
          updEl.textContent = 'Updated: ' + new Date(data.lastUpdated).toLocaleString('en-IN',{hour:'2-digit',minute:'2-digit',day:'numeric',month:'short'});
        }
      } catch (e) {
        console.warn('News fetch failed:', e);
        if (grid) grid.innerHTML = '<div class="news-loading">News unavailable — will retry shortly.</div>';
      }
    }

    // Load immediately, then refresh every 30 minutes
    fetchAndRenderNews();
    setInterval(fetchAndRenderNews, 30 * 60 * 1000);
  })();
</script>
