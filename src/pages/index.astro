---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await Astro.glob('./blog/*.md').catch(() => []);
const sorted = posts.sort((a: any, b: any) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);

const SECTOR_TAGS: Record<string, string> = {
  'RELIANCE.NS':   '⚡ Energy',
  'TCS.NS':        '💻 IT',
  'HDFCBANK.NS':   '🏦 Banking',
  'INFY.NS':       '💻 IT',
  'ICICIBANK.NS':  '🏦 Banking',
  'BAJFINANCE.NS': '💳 Finance',
  'TATAMOTORS.NS': '🚗 Auto',
  'BHARTIARTL.NS': '📡 Telecom',
  'MARUTI.NS':     '🚗 Auto',
  'SBIN.NS':       '🏦 PSU Bank',
  'LT.NS':         '🏗️ Infra',
  'WIPRO.NS':      '💻 IT',
  'HCLTECH.NS':    '💻 IT',
  'KOTAKBANK.NS':  '🏦 Banking',
  'TITAN.NS':      '✨ Consumer',
  'ASIANPAINT.NS': '🎨 FMCG',
};
---
<BaseLayout title="Where Smart Money Reads">

  <!-- ── Hero ────────────────────────────────────────── -->
  <section class="hero hero-bg">
    <div class="hero-overlay"></div>
    <div class="hero-inner hero-split">

      <!-- Left: Text Content -->
      <div class="hero-content">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          LIVE INDIAN MARKET DATA
        </div>
        <h1 class="hero-title">
          Bull Signal.<br />
          <span class="hero-accent">Sharper Moves.</span>
        </h1>
        <p class="hero-desc">
          Live NSE & BSE data, Indian stock insights, and<br />
          AI-powered investment analysis — all in one dashboard.
        </p>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hs-num">NSE/BSE</span>
            <span class="hs-label">LIVE DATA</span>
          </div>
          <div class="hs-divider"></div>
          <div class="hero-stat">
            <span class="hs-num">AI</span>
            <span class="hs-label">STOCK INSIGHTS</span>
          </div>
          <div class="hs-divider"></div>
          <div class="hero-stat">
            <span class="hs-num">Daily</span>
            <span class="hs-label">MARKET BRIEFING</span>
          </div>
        </div>
        <div class="hero-actions">
          <button class="btn-primary" onclick="document.getElementById('markets').scrollIntoView({behavior:'smooth'})">Explore Markets →</button>
          <button class="btn-outline" onclick="document.getElementById('market-pulse').scrollIntoView({behavior:'smooth'})">Market Pulse</button>
        </div>
      </div>

      <!-- Right: Animated Visual -->
      <div class="hero-visual" aria-hidden="true">
        <!-- Pulsing concentric rings -->
        <div class="hv-rings">
          <div class="hv-ring hv-r1"></div>
          <div class="hv-ring hv-r2"></div>
          <div class="hv-ring hv-r3"></div>
          <div class="hv-ring hv-r4"></div>
          <div class="hv-ring hv-r5"></div>
          <div class="hv-inner-ring"></div>
          <!-- Animated chart line inside -->
          <svg class="hv-chart-svg" viewBox="0 0 200 80" preserveAspectRatio="none">
            <polyline id="heroChartLine" points="" fill="none" stroke="url(#chartGrad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <defs>
              <linearGradient id="chartGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#c9a84c" stop-opacity="0.3"/>
                <stop offset="50%" stop-color="#22c55e" stop-opacity="1"/>
                <stop offset="100%" stop-color="#c9a84c" stop-opacity="0.3"/>
              </linearGradient>
            </defs>
          </svg>
          <!-- Center glowing dot -->
          <div class="hv-center-dot"></div>
        </div>

        <!-- Floating live ticker chips -->
        <div class="hv-chip hv-chip-1" id="chip-nifty">
          <span class="chip-label">NIFTY 50</span>
          <span class="chip-val" id="chip-nifty-val">—</span>
          <span class="chip-chg up" id="chip-nifty-chg">—</span>
        </div>
        <div class="hv-chip hv-chip-2" id="chip-sensex">
          <span class="chip-label">SENSEX</span>
          <span class="chip-val" id="chip-sensex-val">—</span>
          <span class="chip-chg up" id="chip-sensex-chg">—</span>
        </div>
        <div class="hv-chip hv-chip-3" id="chip-reliance">
          <span class="chip-label">RELIANCE</span>
          <span class="chip-val" id="chip-rel-val">—</span>
          <span class="chip-chg" id="chip-rel-chg">—</span>
        </div>
        <div class="hv-chip hv-chip-4" id="chip-tcs">
          <span class="chip-label">TCS</span>
          <span class="chip-val" id="chip-tcs-val">—</span>
          <span class="chip-chg" id="chip-tcs-chg">—</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ── Indices Bar (India Only) ─────────────────────── -->
  <section class="indices-section">
    <div class="indices-grid" id="indicesBar">
      <div class="idx-card skeleton" id="hidx-NSEI">
        <span class="idx-name">🇮🇳 NIFTY 50</span>
        <span class="idx-price" id="hidx-NSEI-price">—</span>
        <span class="idx-chg"   id="hidx-NSEI-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="hidx-BSESN">
        <span class="idx-name">🇮🇳 SENSEX</span>
        <span class="idx-price" id="hidx-BSESN-price">—</span>
        <span class="idx-chg"   id="hidx-BSESN-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="hidx-NSEBANK">
        <span class="idx-name">🇮🇳 NIFTY BANK</span>
        <span class="idx-price" id="hidx-NSEBANK-price">—</span>
        <span class="idx-chg"   id="hidx-NSEBANK-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="hidx-MID">
        <span class="idx-name">🇮🇳 NIFTY MIDCAP</span>
        <span class="idx-price" id="hidx-MID-price">—</span>
        <span class="idx-chg"   id="hidx-MID-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="hidx-IT">
        <span class="idx-name">🇮🇳 NIFTY IT</span>
        <span class="idx-price" id="hidx-IT-price">—</span>
        <span class="idx-chg"   id="hidx-IT-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="hidx-AUTO">
        <span class="idx-name">🇮🇳 NIFTY AUTO</span>
        <span class="idx-price" id="hidx-AUTO-price">—</span>
        <span class="idx-chg"   id="hidx-AUTO-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="hidx-PHARMA">
        <span class="idx-name">🇮🇳 NIFTY PHARMA</span>
        <span class="idx-price" id="hidx-PHARMA-price">—</span>
        <span class="idx-chg"   id="hidx-PHARMA-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="hidx-FMCG">
        <span class="idx-name">🇮🇳 NIFTY FMCG</span>
        <span class="idx-price" id="hidx-FMCG-price">—</span>
        <span class="idx-chg"   id="hidx-FMCG-chg">—</span>
      </div>
    </div>
  </section>

  <!-- ── Today's Indian Markets ──────────────────────── -->
  <section class="content-section" id="markets">
    <div class="section-head">
      <h2 class="section-title">Indian Markets — Top Stocks</h2>
      <a href="/markets" class="section-more">View all sectors →</a>
    </div>
    <div class="markets-grid" id="marketsGrid">
      {['RELIANCE.NS','TCS.NS','HDFCBANK.NS','INFY.NS','ICICIBANK.NS','BAJFINANCE.NS','TATAMOTORS.NS','BHARTIARTL.NS','MARUTI.NS','SBIN.NS','LT.NS','WIPRO.NS','HCLTECH.NS','KOTAKBANK.NS','TITAN.NS','ASIANPAINT.NS'].map((sym) => (
        <a class="mkt-card" id={`mc-${sym}`} href={`/company/${sym.toLowerCase().replace(/\./g,'-')}`}>
          {SECTOR_TAGS[sym] && <span class="mkt-sector-tag">{SECTOR_TAGS[sym]}</span>}
          <div class="mkt-top">
            <div>
              <div class="mkt-sym">{sym.replace('.NS','')}</div>
              <div class="mkt-name" id={`mn-${sym}`}>—</div>
            </div>
            <div class="mkt-badge" id={`mb-${sym}`}>—</div>
          </div>
          <div class="mkt-price" id={`mp-${sym}`}>—</div>
          <div class="mkt-chg" id={`mch-${sym}`}>—</div>
          <canvas class="mkt-chart" id={`chart-${sym}`} height="60"></canvas>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Market Pulse ──────────────────────────────────── -->
  <section class="content-section" id="market-pulse">
    <div class="section-head">
      <h2 class="section-title">Market Pulse</h2>
      <span class="section-live">LIVE</span>
    </div>
    <div class="pulse-grid">

      <div class="pulse-card" id="vixCard">
        <div class="pulse-label">India VIX <span class="pulse-badge">Fear Index</span></div>
        <div class="pulse-value" id="vixValue">—</div>
        <div class="pulse-sub" id="vixSub">Loading…</div>
        <div class="pulse-meter">
          <div class="pm-track">
            <div class="pm-fill" id="vixFill" style="width:0%"></div>
          </div>
          <div class="pm-labels"><span>Low (0)</span><span>Moderate (20)</span><span>High (40+)</span></div>
        </div>
      </div>

      <div class="pulse-card">
        <div class="pulse-label">Nifty 50 P/E <span class="pulse-badge">Valuation</span></div>
        <div class="pulse-value" id="niftyPE">—</div>
        <div class="pulse-sub" id="niftyPESub">Loading…</div>
        <div class="pulse-insight" id="niftyPEInsight"></div>
      </div>

      <div class="pulse-card" id="fiiCard">
        <div class="pulse-label">FII / DII Flow <span class="pulse-badge">Latest</span></div>
        <div style="display:flex;gap:12px;margin-top:8px">
          <div style="flex:1">
            <div style="font-size:10px;color:var(--text-muted);margin-bottom:4px">FII (Foreign)</div>
            <div class="pulse-value" id="fiiVal" style="font-size:1.3rem">—</div>
          </div>
          <div style="flex:1">
            <div style="font-size:10px;color:var(--text-muted);margin-bottom:4px">DII (Domestic)</div>
            <div class="pulse-value" id="diiVal" style="font-size:1.3rem">—</div>
          </div>
        </div>
        <div class="pulse-sub" id="fiiSub" style="margin-top:8px">Fetching NSE data…</div>
      </div>

      <div class="pulse-card">
        <div class="pulse-label">Market Mood <span class="pulse-badge">Today</span></div>
        <div class="pulse-value" id="moodVal" style="font-size:1.4rem">—</div>
        <div class="pulse-sub" id="moodSub">Analyzing breadth…</div>
        <div class="pulse-insight" id="moodInsight"></div>
      </div>

    </div>
  </section>

  <!-- ── Company Spotlight ─────────────────────────────── -->
  <section class="content-section">
    <div class="section-head">
      <h2 class="section-title">Company Spotlight</h2>
    </div>
    <div class="spotlight-box">
      <div class="spotlight-search">
        <input id="slInput" type="text" class="sl-input" placeholder="Enter NSE ticker (e.g. RELIANCE, TCS, HDFCBANK)" />
        <button id="slBtn" class="sl-btn">Analyze →</button>
      </div>
      <div id="slResult">
        <p class="sl-hint">Enter an NSE stock symbol above to get live price and AI investment insight.</p>
      </div>
    </div>
  </section>

  <!-- ── Sector Guide Strip ────────────────────────────── -->
  <section class="content-section">
    <div class="guide-strip">
      <div class="gs-title">Browse Indian Market Sectors</div>
      <div class="gs-grid">
        <a href="/markets?sector=banking" class="gs-card">
          <div class="gs-icon">🏦</div>
          <div class="gs-name">Banking</div>
          <div class="gs-desc">NPA ratios, CASA, credit growth</div>
        </a>
        <a href="/markets?sector=it" class="gs-card">
          <div class="gs-icon">💻</div>
          <div class="gs-name">IT</div>
          <div class="gs-desc">Deal wins, margins, USD revenue</div>
        </a>
        <a href="/markets?sector=pharma" class="gs-card">
          <div class="gs-icon">💊</div>
          <div class="gs-name">Pharma</div>
          <div class="gs-desc">USFDA, R&D pipeline, domestic</div>
        </a>
        <a href="/markets?sector=auto" class="gs-card">
          <div class="gs-icon">🚗</div>
          <div class="gs-name">Auto</div>
          <div class="gs-desc">Monthly volumes, EV transition</div>
        </a>
        <a href="/markets?sector=fmcg" class="gs-card">
          <div class="gs-icon">🛒</div>
          <div class="gs-name">FMCG</div>
          <div class="gs-desc">Rural demand, margin recovery</div>
        </a>
        <a href="/markets?sector=infra" class="gs-card">
          <div class="gs-icon">🏗️</div>
          <div class="gs-name">Infra</div>
          <div class="gs-desc">Order book, govt capex cycle</div>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Blog Posts ───────────────────────────────────── -->
  {sorted.length > 0 && (
    <section class="content-section" id="from-ledger">
      <div class="section-head">
        <h2 class="section-title">From the Ledger</h2>
      </div>
      <div class="posts-grid">
        {sorted.map((post: any) => (
          <a href={post.url} class="post-card">
            <div class="pc-date">
              {new Date(post.frontmatter.date).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' })}
            </div>
            <h3 class="pc-title">{post.frontmatter.title}</h3>
            <p class="pc-desc">{post.frontmatter.description}</p>
            <span class="pc-read">Read more →</span>
          </a>
        ))}
      </div>
    </section>
  )}

</BaseLayout>

<style>
/* ── Hero Split Layout ───────────────────────────────── */
.hero-split {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
}
.hero-content { flex: 1; min-width: 0; }
.hero-visual {
  flex: 0 0 420px;
  position: relative;
  height: 420px;
  display: flex;
  align-items: center;
  justify-content: center;
}
@media (max-width: 900px) { .hero-visual { display: none; } }

/* ── Animated Concentric Rings ───────────────────────── */
.hv-rings {
  position: relative;
  width: 340px;
  height: 340px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.hv-ring {
  position: absolute;
  border-radius: 50%;
  border: 1px solid rgba(201,168,76,.25);
  animation: ring-pulse 4s ease-out infinite;
}
.hv-r1 { width: 80px;  height: 80px;  border-color: rgba(34,197,94,.5);  animation-delay: 0s; }
.hv-r2 { width: 140px; height: 140px; border-color: rgba(201,168,76,.35); animation-delay: 0.6s; }
.hv-r3 { width: 210px; height: 210px; border-color: rgba(201,168,76,.22); animation-delay: 1.2s; }
.hv-r4 { width: 280px; height: 280px; border-color: rgba(201,168,76,.12); animation-delay: 1.8s; }
.hv-r5 { width: 340px; height: 340px; border-color: rgba(201,168,76,.06); animation-delay: 2.4s; }
@keyframes ring-pulse {
  0%   { transform: scale(1);    opacity: 1; }
  60%  { transform: scale(1.06); opacity: 0.7; }
  100% { transform: scale(1);    opacity: 1; }
}

/* Separate outward-expanding ripple effect */
.hv-r1::after, .hv-r2::after, .hv-r3::after {
  content: '';
  position: absolute;
  inset: -1px;
  border-radius: 50%;
  border: 1px solid inherit;
  animation: ripple 3s ease-out infinite;
}
.hv-r1::after { border-color: rgba(34,197,94,.4);  animation-delay: 0.5s; }
.hv-r2::after { border-color: rgba(201,168,76,.3); animation-delay: 1.5s; }
.hv-r3::after { border-color: rgba(201,168,76,.2); animation-delay: 2.5s; }
@keyframes ripple {
  0%   { transform: scale(1);   opacity: 0.8; }
  100% { transform: scale(1.5); opacity: 0; }
}

.hv-inner-ring {
  position: absolute;
  width: 110px;
  height: 110px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(34,197,94,.08) 0%, rgba(201,168,76,.06) 60%, transparent 100%);
  border: 1px solid rgba(34,197,94,.3);
}

/* SVG chart inside rings */
.hv-chart-svg {
  position: absolute;
  width: 130px;
  height: 50px;
  z-index: 2;
}

/* Center glowing dot */
.hv-center-dot {
  position: absolute;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 0 4px rgba(34,197,94,.2), 0 0 20px rgba(34,197,94,.6), 0 0 40px rgba(34,197,94,.3);
  z-index: 3;
  animation: dot-pulse 2s ease-in-out infinite;
}
@keyframes dot-pulse {
  0%, 100% { box-shadow: 0 0 0 4px rgba(34,197,94,.2), 0 0 20px rgba(34,197,94,.6), 0 0 40px rgba(34,197,94,.3); }
  50%       { box-shadow: 0 0 0 8px rgba(34,197,94,.1), 0 0 30px rgba(34,197,94,.8), 0 0 60px rgba(34,197,94,.4); }
}

/* ── Floating Ticker Chips ───────────────────────────── */
.hv-chip {
  position: absolute;
  background: rgba(13,20,32,.92);
  border: 1px solid rgba(201,168,76,.3);
  border-radius: 10px;
  padding: 8px 12px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  backdrop-filter: blur(8px);
  z-index: 4;
  min-width: 90px;
  transition: transform .3s ease;
}
.chip-label { font-size: 9px; font-weight: 700; letter-spacing: .8px; color: var(--gold,#c9a84c); text-transform: uppercase; }
.chip-val   { font-size: 13px; font-weight: 800; color: #fff; }
.chip-chg   { font-size: 10px; font-weight: 700; color: var(--text-muted,#94a3b8); }
.chip-chg.up { color: #22c55e; }
.chip-chg.dn { color: #ef4444; }

/* Chip positions + float animations */
.hv-chip-1 { top: 10px;  left: 30px;  animation: float-a 5s ease-in-out infinite; }
.hv-chip-2 { top: 10px;  right: 20px; animation: float-b 6s ease-in-out infinite; }
.hv-chip-3 { bottom: 60px; left: 10px;  animation: float-c 5.5s ease-in-out infinite; }
.hv-chip-4 { bottom: 60px; right: 15px; animation: float-d 4.8s ease-in-out infinite; }
@keyframes float-a { 0%,100%{transform:translateY(0)}   50%{transform:translateY(-10px)} }
@keyframes float-b { 0%,100%{transform:translateY(0)}   50%{transform:translateY(-14px)} }
@keyframes float-c { 0%,100%{transform:translateY(0)}   50%{transform:translateY(-8px)}  }
@keyframes float-d { 0%,100%{transform:translateY(0)}   50%{transform:translateY(-12px)} }

/* Chip loading shimmer */
.hv-chip .chip-val.loading,
.hv-chip .chip-chg.loading {
  background: linear-gradient(90deg,rgba(255,255,255,.06) 25%,rgba(255,255,255,.14) 50%,rgba(255,255,255,.06) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 3px;
  color: transparent !important;
  min-width: 50px;
  min-height: 12px;
  display: block;
}

/* ── Global Shimmer Skeleton ─────────────────────────── */
@keyframes shimmer {
  0%   { background-position:  200% 0; }
  100% { background-position: -200% 0; }
}
.idx-card.skeleton .idx-price,
.idx-card.skeleton .idx-chg {
  background: linear-gradient(90deg,rgba(255,255,255,.05) 25%,rgba(255,255,255,.12) 50%,rgba(255,255,255,.05) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 4px;
  color: transparent !important;
  min-width: 70px;
  display: inline-block;
}
/* Market cards shimmer — before data loads (no .up or .dn class yet) */
.mkt-card:not(.up):not(.dn) .mkt-price,
.mkt-card:not(.up):not(.dn) .mkt-chg,
.mkt-card:not(.up):not(.dn) .mkt-badge {
  background: linear-gradient(90deg,rgba(255,255,255,.05) 25%,rgba(255,255,255,.12) 50%,rgba(255,255,255,.05) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 4px;
  color: transparent !important;
  min-width: 60px;
  min-height: 14px;
  display: inline-block;
}

.pulse-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 16px;
}
.pulse-card {
  background: var(--navy-2);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 18px 20px;
}
.pulse-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .8px;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.pulse-badge {
  background: rgba(201,168,76,.12);
  color: var(--gold);
  border-radius: 4px;
  font-size: 9px;
  padding: 2px 6px;
  letter-spacing: .5px;
  font-weight: 700;
}
.pulse-value {
  font-size: 2rem;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  margin-bottom: 4px;
}
.pulse-sub { font-size: 11px; color: var(--text-muted); line-height: 1.5; }
.pulse-insight { font-size: 11px; color: var(--gold); margin-top: 6px; font-style: italic; }
.pulse-meter { margin-top: 10px; }
.pm-track { height: 4px; background: rgba(255,255,255,.08); border-radius: 2px; overflow: hidden; margin-bottom: 4px; }
.pm-fill { height: 100%; border-radius: 2px; transition: width .6s ease; background: linear-gradient(90deg, #22c55e, #eab308, #ef4444); }
.pm-labels { display: flex; justify-content: space-between; font-size: 9px; color: var(--text-dim); }
.guide-strip { background: var(--navy-2); border: 1px solid var(--border); border-radius: 16px; padding: 24px 28px; }
.gs-title { font-size: 11px; font-weight: 700; color: var(--gold); letter-spacing: .8px; margin-bottom: 16px; text-transform: uppercase; }
.gs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; }
.gs-card { background: rgba(255,255,255,.03); border: 1px solid var(--border); border-radius: 10px; padding: 14px; transition: border-color .15s, transform .15s; text-decoration: none; display: block; }
.gs-card:hover { border-color: rgba(201,168,76,.3); transform: translateY(-2px); }
.gs-icon { font-size: 20px; margin-bottom: 6px; }
.gs-name { font-size: 12px; font-weight: 700; color: #fff; margin-bottom: 3px; }
.gs-desc { font-size: 11px; color: var(--text-muted); line-height: 1.4; }
</style>

<script>
  const FH_KEY  = 'd81lae1r01qrojfc2i2gd81lae1r01qrojfc2i30';
  const PROXIES = ['https://corsproxy.io/?','https://api.allorigins.win/raw?url='];

  const CACHE_TTL = 90000;
  function getCache(key: string) {
    try { const c = JSON.parse(localStorage.getItem(key)||'null'); if(c&&Date.now()-c.ts<CACHE_TTL) return c.data; } catch {} return null;
  }
  function setCache(key: string, data: any) {
    try { localStorage.setItem(key, JSON.stringify({ts:Date.now(),data})); } catch {}
  }

  const IN_NAMES: Record<string,string> = {
    'RELIANCE.NS':'Reliance Industries','TCS.NS':'Tata Consultancy Services','HDFCBANK.NS':'HDFC Bank',
    'INFY.NS':'Infosys','ICICIBANK.NS':'ICICI Bank','BAJFINANCE.NS':'Bajaj Finance',
    'TATAMOTORS.NS':'Tata Motors','BHARTIARTL.NS':'Bharti Airtel','MARUTI.NS':'Maruti Suzuki',
    'SBIN.NS':'State Bank of India','LT.NS':'Larsen & Toubro','WIPRO.NS':'Wipro',
    'HCLTECH.NS':'HCL Technologies','KOTAKBANK.NS':'Kotak Mahindra Bank','TITAN.NS':'Titan Company','ASIANPAINT.NS':'Asian Paints',
  };

  async function fetchIndianQuote(nsSym: string) {
    const fhSym = 'NSE:' + nsSym.replace(/\.(NS|BO)$/,'');
    try {
      const r = await fetch(`https://finnhub.io/api/v1/quote?symbol=${fhSym}&token=${FH_KEY}`, {signal:AbortSignal.timeout(7000)});
      const d = await r.json();
      if (!d.c) return null;
      return { symbol:nsSym, shortName:IN_NAMES[nsSym]||nsSym.replace('.NS',''), regularMarketPrice:d.c, regularMarketChange:d.d||0, regularMarketChangePercent:d.dp||0, high52:d.h, low52:d.l };
    } catch { return null; }
  }

  function renderMarketCard(q: any) {
    const chg=q.regularMarketChange??0, pct=q.regularMarketChangePercent??0, up=chg>=0;
    const color=up?'#22c55e':'#ef4444';
    const nameEl=document.getElementById(`mn-${q.symbol}`),badgeEl=document.getElementById(`mb-${q.symbol}`),priceEl=document.getElementById(`mp-${q.symbol}`),chgEl=document.getElementById(`mch-${q.symbol}`),card=document.getElementById(`mc-${q.symbol}`);
    if(nameEl) nameEl.textContent=q.shortName||'';
    if(priceEl) priceEl.textContent=`₹${q.regularMarketPrice?.toLocaleString('en-IN',{maximumFractionDigits:2})}`;
    if(chgEl){chgEl.textContent=`${up?'▲':'▼'} ₹${Math.abs(chg).toFixed(2)} ${up?'+':''}${pct.toFixed(2)}%`;(chgEl as HTMLElement).style.color=color;}
    if(badgeEl){badgeEl.textContent=`${up?'+':''}${pct.toFixed(2)}%`;badgeEl.classList.add(up?'badge-up':'badge-dn');}
    if(card) card.classList.add(up?'up':'dn');
    const fhSym='NSE:'+q.symbol.replace('.NS','');
    const to=Math.floor(Date.now()/1000),from=to-30*86400;
    fetch(`https://finnhub.io/api/v1/stock/candle?symbol=${fhSym}&resolution=D&from=${from}&to=${to}&token=${FH_KEY}`)
      .then(r=>r.json()).then((d:any)=>{
        if(d.s!=='ok'||!d.c?.length) return;
        const canvas=document.getElementById(`chart-${q.symbol}`) as HTMLCanvasElement;
        if(!canvas) return;
        new (window as any).Chart(canvas,{type:'line',data:{labels:d.c.map((_:any,i:number)=>i),datasets:[{data:d.c,borderColor:color,borderWidth:2,pointRadius:0,fill:true,backgroundColor:up?'rgba(34,197,94,0.08)':'rgba(239,68,68,0.08)'}]},options:{animation:false,responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{enabled:false}},scales:{x:{display:false},y:{display:false}}}});
      }).catch(()=>{});
  }

  async function loadMarkets() {
    const syms=['RELIANCE.NS','TCS.NS','HDFCBANK.NS','INFY.NS','ICICIBANK.NS','BAJFINANCE.NS','TATAMOTORS.NS','BHARTIARTL.NS','MARUTI.NS','SBIN.NS','LT.NS','WIPRO.NS','HCLTECH.NS','KOTAKBANK.NS','TITAN.NS','ASIANPAINT.NS'];
    const cached=getCache('india_mkts_v4');
    if(cached) cached.forEach(renderMarketCard);
    const results:any[]=[];
    for(let i=0;i<syms.length;i+=4){
      const chunk=syms.slice(i,i+4);
      const res=await Promise.allSettled(chunk.map(fetchIndianQuote));
      res.forEach((r:any)=>{if(r.status==='fulfilled'&&r.value){renderMarketCard(r.value);results.push(r.value);}});
    }
    if(results.length>0) setCache('india_mkts_v4',results);
  }

  function renderIndiaIndex(q: any) {
    const idMap:Record<string,string>={'^NSEI':'NSEI','^BSESN':'BSESN','^NSEBANK':'NSEBANK','^NIFTYMIDCAP150':'MID','^CNXIT':'IT','^CNXAUTO':'AUTO','^CNXPHARMA':'PHARMA','^CNXFMCG':'FMCG'};
    const key=idMap[q.symbol]; if(!key) return;
    const chg=q.regularMarketChange??0,pct=q.regularMarketChangePercent??0,up=chg>=0;
    const color=up?'#22c55e':'#ef4444';
    const card=document.getElementById(`hidx-${key}`);
    if(card){card.classList.remove('skeleton');card.classList.add(up?'up':'dn');}
    const pEl=document.getElementById(`hidx-${key}-price`);
    if(pEl) pEl.textContent=q.regularMarketPrice?.toLocaleString('en-IN',{maximumFractionDigits:2});
    const cEl=document.getElementById(`hidx-${key}-chg`);
    if(cEl){cEl.textContent=`${up?'▲':'▼'} ${Math.abs(pct).toFixed(2)}%`;(cEl as HTMLElement).style.color=color;}
  }

  async function loadIndiaIndices() {
    const cached=getCache('india_idx_v4');
    if(cached) cached.forEach(renderIndiaIndex);
    const IDX=[
      {enc:'%5ENSEI',sym:'^NSEI'},{enc:'%5EBSESN',sym:'^BSESN'},
      {enc:'%5ENSEBANK',sym:'^NSEBANK'},{enc:'%5ENIFTYMIDCAP150',sym:'^NIFTYMIDCAP150'},
      {enc:'%5ECNXIT',sym:'^CNXIT'},{enc:'%5ECNXAUTO',sym:'^CNXAUTO'},
      {enc:'%5ECNXPHARMA',sym:'^CNXPHARMA'},{enc:'%5ECNXFMCG',sym:'^CNXFMCG'},
    ];
    const results:any[]=[];
    await Promise.all(IDX.map(async({enc,sym:idxSym})=>{
      const url=`https://query2.finance.yahoo.com/v8/finance/chart/${enc}?range=1d&interval=5m`;
      for(const px of PROXIES){
        try{
          const r=await fetch(px+encodeURIComponent(url),{signal:AbortSignal.timeout(8000)});
          if(!r.ok) continue;
          const d=await r.json();
          const meta=d?.chart?.result?.[0]?.meta;
          if(!meta?.regularMarketPrice) continue;
          const price=meta.regularMarketPrice,prev=meta.previousClose||meta.chartPreviousClose||price;
          const chg=price-prev,pct=prev?(chg/prev)*100:0;
          const q={symbol:idxSym,regularMarketPrice:price,regularMarketChange:chg,regularMarketChangePercent:pct};
          renderIndiaIndex(q);results.push(q);break;
        }catch{}
      }
    }));
    if(results.length>0) setCache('india_idx_v4',results);
  }

  async function loadMarketPulse() {
    // India VIX
    try {
      const url=`https://query2.finance.yahoo.com/v8/finance/chart/%5EINDIAVIX?range=1d&interval=5m`;
      for(const px of PROXIES){
        try{
          const r=await fetch(px+encodeURIComponent(url),{signal:AbortSignal.timeout(8000)});
          if(!r.ok) continue;
          const d=await r.json();
          const meta=d?.chart?.result?.[0]?.meta;
          if(!meta?.regularMarketPrice) continue;
          const vix=meta.regularMarketPrice,prev=meta.previousClose||vix,pct=prev?((vix-prev)/prev)*100:0;
          const vixEl=document.getElementById('vixValue'),vixSub=document.getElementById('vixSub'),vixFill=document.getElementById('vixFill');
          if(vixEl){vixEl.textContent=vix.toFixed(2);(vixEl as HTMLElement).style.color=vix<15?'#22c55e':vix<22?'#eab308':'#ef4444';}
          if(vixSub) vixSub.textContent=`${pct>=0?'+':''}${pct.toFixed(2)}% vs yesterday · ${vix<15?'Low fear — market may be complacent':vix<22?'Moderate volatility — normal range':'High fear — potential contrarian buy opportunity'}`;
          if(vixFill)(vixFill as HTMLElement).style.width=Math.min((vix/40)*100,100)+'%';
          break;
        }catch{}
      }
    }catch{}

    // Nifty P/E approximation
    const peEl=document.getElementById('niftyPE'),peSubEl=document.getElementById('niftyPESub'),peInsEl=document.getElementById('niftyPEInsight');
    if(peEl) peEl.textContent='~22x';
    if(peSubEl) peSubEl.textContent='Long-term avg ~22x · Fair zone 18–24x · Source: NSE India';
    if(peInsEl) peInsEl.textContent='Below 18x = undervalued · Above 26x = overvalued';

    // FII / DII
    try{
      const r=await fetch('https://corsproxy.io/?'+encodeURIComponent('https://www.nseindia.com/api/fiidiiTradeReact'),{signal:AbortSignal.timeout(8000)});
      const d=await r.json();
      if(d&&Array.isArray(d)&&d.length>0){
        const latest=d[0];
        const fiiNet=parseFloat(latest.fiiNet||latest.fii_net||0);
        const diiNet=parseFloat(latest.diiNet||latest.dii_net||0);
        const fiiEl=document.getElementById('fiiVal'),diiEl=document.getElementById('diiVal'),fiiSub=document.getElementById('fiiSub');
        if(fiiEl){fiiEl.textContent=`${fiiNet>=0?'+':''}₹${Math.abs(fiiNet).toFixed(0)}Cr`;(fiiEl as HTMLElement).style.color=fiiNet>=0?'#22c55e':'#ef4444';}
        if(diiEl){diiEl.textContent=`${diiNet>=0?'+':''}₹${Math.abs(diiNet).toFixed(0)}Cr`;(diiEl as HTMLElement).style.color=diiNet>=0?'#22c55e':'#ef4444';}
        if(fiiSub) fiiSub.textContent=`Date: ${latest.date||'Latest'} · Source: NSE India`;
      } else throw new Error('empty');
    }catch{
      const fiiSub=document.getElementById('fiiSub'),fiiEl=document.getElementById('fiiVal'),diiEl=document.getElementById('diiVal');
      if(fiiEl) fiiEl.textContent='N/A';
      if(diiEl) diiEl.textContent='N/A';
      if(fiiSub) fiiSub.textContent='NSE FII/DII data available after market hours · Check moneycontrol.com';
    }

    // Market mood from index breadth
    setTimeout(()=>{
      const greenCount=document.querySelectorAll('.idx-card.up').length;
      const total=document.querySelectorAll('.idx-card:not(.skeleton)').length||8;
      const ratio=total>0?greenCount/total:0.5;
      const mood=ratio>0.7?'Bullish 🟢':ratio>0.4?'Neutral 🟡':'Bearish 🔴';
      const advice=ratio>0.7?'Most sectors advancing. Trend is your friend.':ratio>0.4?'Mixed signals — sector-specific approach advised.':'Broad selling. Watch support levels before adding.';
      const mEl=document.getElementById('moodVal'),mSub=document.getElementById('moodSub'),mIns=document.getElementById('moodInsight');
      if(mEl) mEl.textContent=mood;
      if(mSub) mSub.textContent=`${greenCount}/${total} indices in green today`;
      if(mIns) mIns.textContent=advice;
    },4000);
  }

  // News ticker for Indian markets
  async function loadNews() {
    const list=document.getElementById('newsList');
    if(!list) return;
    try{
      const r=await fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent('https://economictimes.indiatimes.com/markets/rssfeeds/1977021501.cms')}&count=10`);
      const d=await r.json();
      const items=d?.items||[];
      if(!items.length) throw new Error('empty');
      list.innerHTML=items.map((item:any)=>{
        const date=new Date(item.pubDate).toLocaleDateString('en-IN',{month:'short',day:'numeric'});
        return `<a href="${item.link}" class="news-item" target="_blank" rel="noopener"><div class="ni-title">${item.title}</div><div class="ni-meta">Economic Times · ${date}</div></a>`;
      }).join('');
    }catch{}
  }

  // Spotlight
  async function loadSpotlight(rawSym: string) {
    const result=document.getElementById('slResult');
    if(!result) return;
    const s=rawSym.toUpperCase().trim();
    const sym=s.includes('.')?s:s+'.NS';
    result.innerHTML=`<p class="sl-hint">Analyzing ${sym}…</p>`;
    try{
      const fhSym='NSE:'+sym.replace('.NS','');
      const [qRes,pRes]=await Promise.all([
        fetch(`https://finnhub.io/api/v1/quote?symbol=${fhSym}&token=${FH_KEY}`,{signal:AbortSignal.timeout(8000)}).then(r=>r.json()),
        fetch(`https://finnhub.io/api/v1/stock/profile2?symbol=${fhSym}&token=${FH_KEY}`,{signal:AbortSignal.timeout(8000)}).then(r=>r.json()),
      ]);
      if(!qRes.c) throw new Error('not found');
      const price=qRes.c,chg=qRes.d||0,pct=qRes.dp||0;
      const high52=qRes.h||price,low52=qRes.l||price;
      const up=chg>=0,color=up?'#22c55e':'#ef4444';
      const mcap=pRes.marketCapitalization?`₹${(pRes.marketCapitalization*1e6/1e7).toFixed(0)}Cr`:'—';
      const priceVsHigh=high52>low52?((price-low52)/(high52-low52))*100:50;
      const momentum=pct>1?'Strong positive':pct>0?'Mild positive':pct>-1?'Mild negative':'Strong negative';
      const score=Math.max(10,Math.min(90,Math.round(50+pct*2-(priceVsHigh-50)*0.3)));
      const action=score>65?'🟢 Bullish — consider buying on dips':score>40?'🟡 Neutral — hold and watch':'🔴 Bearish — wait for better entry';
      const actionColor=score>65?'#22c55e':score>40?'#eab308':'#ef4444';
      const entryAdvice=score>65?'Consider SIP entry or buy on 3–5% dip. Price is well-positioned in its 52-week range.':score>40?'No strong signal yet. Use SIP or wait for breakout confirmation on high volume.':'Under selling pressure. Wait for RSI < 40 and price stabilization near 52W low before entering.';
      result.innerHTML=`
        <div class="sl-company">${pRes.name||sym.replace('.NS','')} <span style="font-size:12px;color:var(--text-muted);font-weight:400">${pRes.finnhubIndustry||''}</span></div>
        <div class="sl-price-row">
          <span class="sl-price" style="color:var(--gold)">₹${price.toLocaleString('en-IN',{maximumFractionDigits:2})}</span>
          <span class="sl-delta" style="color:${color}">${up?'▲':'▼'} ₹${Math.abs(chg).toFixed(2)} (${up?'+':''}${pct.toFixed(2)}%)</span>
        </div>
        <div class="sl-stats">
          <div class="sl-stat"><span>Market Cap</span><strong>${mcap}</strong></div>
          <div class="sl-stat"><span>52W High</span><strong>₹${high52.toFixed(2)}</strong></div>
          <div class="sl-stat"><span>52W Low</span><strong>₹${low52.toFixed(2)}</strong></div>
          <div class="sl-stat"><span>vs 52W Range</span><strong>${priceVsHigh.toFixed(0)}%</strong></div>
          <div class="sl-stat"><span>Momentum</span><strong>${momentum}</strong></div>
          <div class="sl-stat"><span>Exchange</span><strong>NSE</strong></div>
        </div>
        <div style="background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.2);border-radius:10px;padding:14px 18px;margin-top:14px">
          <div style="font-size:10px;font-weight:700;letter-spacing:.8px;color:var(--gold);margin-bottom:6px">AI INVESTMENT INSIGHT</div>
          <div style="font-size:15px;font-weight:700;color:${actionColor};margin-bottom:6px">${action}</div>
          <div style="font-size:12px;color:var(--text-muted)">${entryAdvice}</div>
          <div style="font-size:11px;color:var(--text-dim);margin-top:8px">⚠️ Algorithmic analysis only — not financial advice. Always DYOR.</div>
        </div>
        <a href="/company/${sym.toLowerCase().replace(/\./g,'-')}" style="display:inline-block;margin-top:12px;background:var(--gold);color:#0b0f1a;padding:8px 20px;border-radius:8px;font-size:12px;font-weight:700">Full Deep Dive →</a>
      `;
    }catch{
      result.innerHTML=`<p class="sl-hint" style="color:#ef4444">Ticker "${rawSym}" not found on NSE. Try: RELIANCE, TCS, HDFCBANK, INFY, SBIN</p>`;
    }
  }

  document.getElementById('slBtn')?.addEventListener('click',()=>{const v=(document.getElementById('slInput') as HTMLInputElement)?.value;if(v?.trim()) loadSpotlight(v.trim());});
  document.getElementById('slInput')?.addEventListener('keydown',(e:KeyboardEvent)=>{if(e.key==='Enter'){const v=(document.getElementById('slInput') as HTMLInputElement)?.value;if(v?.trim()) loadSpotlight(v.trim());}});

  loadMarkets();
  loadIndiaIndices();
  loadNews();
  loadMarketPulse();
  setInterval(()=>{loadMarkets();loadIndiaIndices();loadMarketPulse();},60000);

  // ── Hero chip loading shimmer ─────────────────────────
  ['chip-nifty-val','chip-nifty-chg','chip-sensex-val','chip-sensex-chg','chip-rel-val','chip-rel-chg','chip-tcs-val','chip-tcs-chg'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.add('loading');
  });

  // ── Hero animated chart (sine wave that looks like a stock chart) ──
  function drawHeroChart() {
    const line = document.getElementById('heroChartLine');
    if (!line) return;
    const pts = [];
    const W = 200, H = 80, points = 40;
    let y = 50;
    for (let i = 0; i <= points; i++) {
      const x = (i / points) * W;
      y = y + (Math.random() - 0.46) * 8;
      y = Math.max(10, Math.min(70, y));
      pts.push(`${x},${y}`);
    }
    line.setAttribute('points', pts.join(' '));
  }
  drawHeroChart();
  setInterval(drawHeroChart, 3000);

  // ── Hero chips: update with real Nifty/Sensex/stock data ──
  async function updateHeroChips() {
    const FH = 'd81lae1r01qrojfc2i2gd81lae1r01qrojfc2i30';
    const chips = [
      { sym: '%5ENSEI',     valId: 'chip-nifty-val',   chgId: 'chip-nifty-chg',   label: 'NIFTY', proxy: true },
      { sym: '%5EBSESN',    valId: 'chip-sensex-val',  chgId: 'chip-sensex-chg',  label: 'SENSEX', proxy: true },
      { sym: 'NSE:RELIANCE',valId: 'chip-rel-val',     chgId: 'chip-rel-chg',     label: 'RELIANCE', proxy: false },
      { sym: 'NSE:TCS',     valId: 'chip-tcs-val',     chgId: 'chip-tcs-chg',     label: 'TCS', proxy: false },
    ];
    for (const c of chips) {
      try {
        let price = 0, pct = 0;
        if (c.proxy) {
          const url = `https://query1.finance.yahoo.com/v8/finance/chart/${c.sym}?interval=1d&range=1d`;
          const r = await fetch(`https://corsproxy.io/?${encodeURIComponent(url)}`, { signal: AbortSignal.timeout(5000) });
          const d = await r.json();
          const meta = d?.chart?.result?.[0]?.meta;
          if (meta?.regularMarketPrice) {
            price = meta.regularMarketPrice;
            const prev = meta.previousClose || price;
            pct = prev ? ((price - prev) / prev) * 100 : 0;
          }
        } else {
          const r = await fetch(`https://finnhub.io/api/v1/quote?symbol=${c.sym}&token=${FH}`, { signal: AbortSignal.timeout(5000) });
          const d = await r.json();
          if (d?.c) { price = d.c; pct = d.dp || 0; }
        }
        if (price > 0) {
          const up = pct >= 0;
          const valEl = document.getElementById(c.valId);
          const chgEl = document.getElementById(c.chgId);
          if (valEl) { valEl.classList.remove('loading'); valEl.textContent = price.toLocaleString('en-IN', { maximumFractionDigits: 0 }); }
          if (chgEl) {
            chgEl.classList.remove('loading');
            chgEl.textContent = `${up ? '▲' : '▼'} ${Math.abs(pct).toFixed(2)}%`;
            chgEl.className = `chip-chg ${up ? 'up' : 'dn'}`;
          }
        }
      } catch {}
    }
  }
  updateHeroChips();
</script>
