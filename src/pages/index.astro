---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await Astro.glob('./blog/*.md').catch(() => []);
const sorted = posts.sort((a: any, b: any) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---
<BaseLayout title="Where Smart Money Reads">

  <!-- ── Hero ────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-left">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          LIVE MARKET DATA
        </div>
        <h1 class="hero-title">
          Smart Money.<br />
          <span class="hero-accent">Sharper Moves.</span>
        </h1>
        <p class="hero-desc">
          Professional-grade market intelligence for people<br />
          who'd rather invest than guess.
        </p>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hs-num">500+</span>
            <span class="hs-label">STOCKS TRACKED</span>
          </div>
          <div class="hs-divider"></div>
          <div class="hero-stat">
            <span class="hs-num">Daily</span>
            <span class="hs-label">NEWS UPDATES</span>
          </div>
          <div class="hs-divider"></div>
          <div class="hero-stat">
            <span class="hs-num">Real-Time</span>
            <span class="hs-label">MARKET DATA</span>
          </div>
        </div>
        <div class="hero-actions">
          <button class="btn-primary" onclick="document.getElementById('markets').scrollIntoView({behavior:'smooth'})">Explore Markets →</button>
          <button class="btn-outline" onclick="document.getElementById('news').scrollIntoView({behavior:'smooth'})">Latest News</button>
        </div>
      </div>

    </div>
  </section>

  <!-- ── Indices Bar ──────────────────────────────────── -->
  <section class="indices-section">
    <div class="indices-grid" id="indicesBar">
      <div class="idx-card skeleton" id="idx-SPY">
        <span class="idx-name">S&P 500</span>
        <span class="idx-price">—</span>
        <span class="idx-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="idx-QQQ">
        <span class="idx-name">NASDAQ</span>
        <span class="idx-price">—</span>
        <span class="idx-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="idx-DIA">
        <span class="idx-name">DOW JONES</span>
        <span class="idx-price">—</span>
        <span class="idx-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="idx-IWM">
        <span class="idx-name">RUSSELL 2000</span>
        <span class="idx-price">—</span>
        <span class="idx-chg">—</span>
      </div>
    </div>
  </section>

  <!-- ── Fear & Greed + Sector Heatmap ───────────────── -->
  <section class="content-section">
    <div class="section-head">
      <h2 class="section-title">Sector Performance</h2>
      <span class="section-live">LIVE</span>
    </div>
    <div class="sector-pill-bar" id="heatmapGrid">
      {[
        {sym:'XLK',name:'Technology'},
        {sym:'XLF',name:'Financials'},
        {sym:'XLE',name:'Energy'},
        {sym:'XLV',name:'Health Care'},
        {sym:'XLY',name:'Cons. Disc.'},
        {sym:'XLP',name:'Cons. Staples'},
        {sym:'XLI',name:'Industrials'},
        {sym:'XLU',name:'Utilities'},
        {sym:'XLB',name:'Materials'},
        {sym:'XLRE',name:'Real Estate'},
      ].map(s => (
        <div class="sector-pill" id={`hm-${s.sym}`}>
          <span class="sp-name">{s.name}</span>
          <span class="sp-pct" id={`hmp-${s.sym}`}>—</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Today's Markets ─────────────────────────────── -->
  <section class="content-section" id="markets">
    <div class="section-head">
      <h2 class="section-title">Today's Markets</h2>
      <a href="/" class="section-more">View all markets →</a>
    </div>
    <div class="markets-grid" id="marketsGrid">
      {['AAPL','MSFT','GOOGL','AMZN','TSLA','META','NVDA','JPM','GS','NFLX'].map((sym) => (
        <div class="mkt-card" id={`mc-${sym}`}>
          <div class="mkt-top">
            <div>
              <div class="mkt-sym">{sym}</div>
              <div class="mkt-name" id={`mn-${sym}`}>—</div>
            </div>
            <div class="mkt-badge" id={`mb-${sym}`}>—</div>
          </div>
          <div class="mkt-price" id={`mp-${sym}`}>—</div>
          <div class="mkt-chg" id={`mch-${sym}`}>—</div>
          <canvas class="mkt-chart" id={`chart-${sym}`} height="60"></canvas>
        </div>
      ))}
    </div>
  </section>


  <!-- ── Company Spotlight ─────────────────────────────── -->
  <section class="content-section">
    <div class="section-head">
      <h2 class="section-title">Company Spotlight</h2>
    </div>
    <div class="spotlight-box">
      <div class="spotlight-search">
        <input id="slInput" type="text" class="sl-input" placeholder="Enter ticker symbol (e.g. AAPL)" />
        <button id="slBtn" class="sl-btn">Search</button>
      </div>
      <div id="slResult">
        <p class="sl-hint">Enter a stock ticker above to see company details, live price, and 3-month chart.</p>
      </div>
    </div>
  </section>

  <!-- ── Blog Posts ───────────────────────────────────── -->
  {sorted.length > 0 && (
    <section class="content-section">
      <div class="section-head">
        <h2 class="section-title">From the Ledger</h2>
      </div>
      <div class="posts-grid">
        {sorted.map((post: any) => (
          <a href={post.url} class="post-card">
            <div class="pc-date">
              {new Date(post.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </div>
            <h3 class="pc-title">{post.frontmatter.title}</h3>
            <p class="pc-desc">{post.frontmatter.description}</p>
            <span class="pc-read">Read more →</span>
          </a>
        ))}
      </div>
    </section>
  )}

</BaseLayout>

<script>
const TD_KEY = 'c0f820df7be2436d88d2e2092d1066fc';
const FH_KEY = 'd81lae1r01qrojfc2i2gd81lae1r01qrojfc2i30';
const TD_BASE = 'https://api.twelvedata.com';
const FH_BASE = 'https://finnhub.io/api/v1';

function fmtPrice(v: number) {
  if (!v && v !== 0) return '—';
  return v >= 1000 ? v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : v.toFixed(2);
}

async function tdQuote(symbols: string[]) {
  const r = await fetch(`${TD_BASE}/quote?symbol=${symbols.join(',')}&apikey=${TD_KEY}`);
  const d = await r.json();
  return symbols.length === 1 ? { [symbols[0]]: d } : d;
}

async function fhQuote(sym: string) {
  try {
    const r = await fetch(`${FH_BASE}/quote?symbol=${sym}&token=${FH_KEY}`);
    const d = await r.json();
    return (d.error || !d.c) ? null : d;
  } catch { return null; }
}

async function fhCandles(sym: string) {
  const to = Math.floor(Date.now() / 1000);
  const from = to - 90 * 86400;
  const d: any = await fetch(`${FH_BASE}/stock/candle?symbol=${sym}&resolution=D&from=${from}&to=${to}&token=${FH_KEY}`).then((r: any) => r.json());
  if (d.s !== 'ok' || !d.c) return null;
  return { closes: d.c, timestamps: d.t };
}

// ── Indices (Twelve Data) ─────────────────────────────────────────────
async function loadIndices() {
  try {
    const data: any = await tdQuote(['SPY', 'QQQ', 'DIA', 'IWM']);
    ['SPY', 'QQQ', 'DIA', 'IWM'].forEach((sym: string) => {
      const q = data[sym];
      if (!q || q.status === 'error') return;
      const el = document.getElementById(`idx-${sym}`);
      if (!el) return;
      const pct = parseFloat(q.percent_change);
      const up = pct >= 0;
      el.classList.remove('skeleton');
      el.classList.add(up ? 'up' : 'dn');
      el.querySelector('.idx-price')!.textContent = fmtPrice(parseFloat(q.close));
      el.querySelector('.idx-chg')!.textContent = `${up ? '▲' : '▼'} ${Math.abs(pct).toFixed(2)}%`;
    });
  } catch {}
}

// ── Markets Grid (Finnhub) ────────────────────────────────────────────
async function loadMarkets() {
  const syms = ['AAPL', 'MSFT', 'GOOGL', 'AMZN', 'TSLA', 'META', 'NVDA', 'JPM', 'GS', 'NFLX'];
  try {
    const quotes: any[] = await Promise.all(syms.map((s: string, i: number) => new Promise<void>(r => setTimeout(r, i * 80)).then(() => fhQuote(s).then((q: any) => ({ sym: s, q })).catch(() => ({ sym: s, q: null })))));
    for (const { sym, q } of quotes) {
      if (!q || !q.c) continue;
      const up = q.dp >= 0;
      const color = up ? '#22c55e' : '#ef4444';
      const nameEl = document.getElementById(`mn-${sym}`);
      const badgeEl = document.getElementById(`mb-${sym}`);
      const priceEl = document.getElementById(`mp-${sym}`);
      const chgEl = document.getElementById(`mch-${sym}`);
      const card = document.getElementById(`mc-${sym}`);
      if (nameEl) nameEl.textContent = sym;
      if (priceEl) priceEl.textContent = `$${fmtPrice(q.c)}`;
      if (chgEl) {
        chgEl.textContent = `${up ? '▲' : '▼'} $${Math.abs(q.d).toFixed(2)} ${up ? '+' : ''}${q.dp.toFixed(2)}%`;
        (chgEl as HTMLElement).style.color = color;
      }
      if (badgeEl) { badgeEl.textContent = `${up ? '▲' : '▼'} ${Math.abs(q.dp).toFixed(2)}%`; badgeEl.classList.add(up ? 'badge-up' : 'badge-dn'); }
      if (card) card.classList.add(up ? 'up' : 'dn');
      fhCandles(sym).then((cd: any) => {
        if (!cd) return;
        const canvas = document.getElementById(`chart-${sym}`) as HTMLCanvasElement;
        if (!canvas) return;
        const existing = (window as any).Chart?.getChart?.(canvas);
        if (existing) existing.destroy();
        new (window as any).Chart(canvas, {
          type: 'line',
          data: { labels: cd.closes.map((_: any, i: number) => i),
            datasets: [{ data: cd.closes, borderColor: color, borderWidth: 2, pointRadius: 0,
              fill: true, backgroundColor: up ? 'rgba(34,197,94,0.08)' : 'rgba(239,68,68,0.08)' }] },
          options: { animation: false, responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { enabled: false } },
            scales: { x: { display: false }, y: { display: false } } }
        });
      }).catch(() => {});
    }
  } catch {}
}

// ── Sector Heatmap (Finnhub) ──────────────────────────────────────────
async function loadHeatmap() {
  const sectors = ['XLK', 'XLF', 'XLE', 'XLV', 'XLY', 'XLP', 'XLI', 'XLU', 'XLB', 'XLRE'];
  try {
    const quotes: any[] = await Promise.all(sectors.map((s: string, i: number) => new Promise<void>(r => setTimeout(r, (i + 10) * 80)).then(() => fhQuote(s).then((q: any) => ({ sym: s, q })))));
    quotes.forEach(({ sym, q }: any) => {
      if (!q || !q.c) return;
      const pct = q.dp ?? 0;
      const cell = document.getElementById(`hm-${sym}`);
      const pEl = document.getElementById(`hmp-${sym}`);
      if (!cell || !pEl) return;
      cell.classList.remove('skeleton');
      const intensity = Math.min(Math.abs(pct) / 3, 1);
      const bg = pct >= 0 ? `rgba(34,197,94,${0.1 + intensity * 0.5})` : `rgba(239,68,68,${0.1 + intensity * 0.5})`;
      const color = pct >= 0 ? '#22c55e' : '#ef4444';
      (cell as HTMLElement).style.background = bg;
      (cell as HTMLElement).style.borderColor = color + '40';
      pEl.textContent = `${pct >= 0 ? '+' : ''}${pct.toFixed(2)}%`;
      (pEl as HTMLElement).style.color = color;
    });
  } catch {}
}

// ── Fear & Greed ──────────────────────────────────────────────────────
async function loadFearGreed() {
  try {
    const r = await fetch('https://api.alternative.me/fng/?limit=2');
    const d = await r.json();
    const cur = d?.data?.[0];
    const prev = d?.data?.[1];
    if (!cur) throw new Error('empty');
    const val = parseInt(cur.value);
    const label = cur.value_classification;
    const color = val >= 75 ? '#22c55e' : val >= 55 ? '#84cc16' : val >= 45 ? '#eab308' : val >= 25 ? '#f97316' : '#ef4444';
    const fgValue = document.getElementById('fgValue');
    const fgLabel = document.getElementById('fgLabel');
    const fgPrev = document.getElementById('fgPrev');
    const needle = document.getElementById('fgNeedle');
    if (fgValue) { fgValue.textContent = val.toString(); (fgValue as HTMLElement).style.color = color; }
    if (fgLabel) { fgLabel.textContent = label; (fgLabel as HTMLElement).style.color = color; }
    if (needle) needle.setAttribute('transform', `rotate(${(val / 100) * 180 - 90} 100 100)`);
    if (prev && fgPrev) {
      const prevVal = parseInt(prev.value);
      const diff = val - prevVal;
      fgPrev.innerHTML = `Yesterday: <strong>${prevVal}</strong> ${prev.value_classification} <span style="color:${diff >= 0 ? '#22c55e' : '#ef4444'}">${diff >= 0 ? '+' : ''}${diff}</span>`;
    }
  } catch {}
}

// ── News (RSS) ────────────────────────────────────────────────────────
async function loadNews() {
  const list = document.getElementById('newsList');
  if (!list) return;
  const feeds = [
    { url: 'https://feeds.reuters.com/reuters/businessNews', source: 'Reuters' },
    { url: 'https://feeds.bbci.co.uk/news/business/rss.xml', source: 'BBC Business' },
  ];
  for (const feed of feeds) {
    try {
      const r = await fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(feed.url)}&count=8`);
      const d: any = await r.json();
      const items = d?.items || [];
      if (!items.length) continue;
      list.innerHTML = items.map((item: any) => {
        const date = new Date(item.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        return `<a href="${item.link}" class="news-item" target="_blank" rel="noopener noreferrer"><div class="ni-title">${item.title}</div><div class="ni-meta">${item.author || feed.source} · ${date}</div></a>`;
      }).join('');
      return;
    } catch { continue; }
  }
  const fallback = [['Fed holds rates as inflation nears 2% target','Reuters'],['S&P 500 hits record high on strong earnings','Bloomberg'],['Apple unveils new AI features at WWDC','CNBC'],['Oil climbs on Middle East supply concerns','Reuters'],['Tesla beats delivery estimates, stock surges 8%','WSJ'],['Goldman Sachs raises S&P 500 year-end target','FT']];
  list.innerHTML = fallback.map(([t, s]: any) => `<a href="https://www.google.com/search?q=${encodeURIComponent(t)}&tbm=nws" class="news-item" target="_blank"><div class="ni-title">${t}</div><div class="ni-meta">${s}</div></a>`).join('');
}

// ── Spotlight ─────────────────────────────────────────────────────────
async function loadSpotlight(sym: string) {
  const result = document.getElementById('slResult');
  if (!result) return;
  result.innerHTML = `<p class="sl-hint">Loading ${sym.toUpperCase()}…</p>`;
  try {
    const s = sym.toUpperCase().trim();
    const [fhQ, tdQ, cd]: any[] = await Promise.all([fhQuote(s), fetch(`${TD_BASE}/quote?symbol=${s}&apikey=${TD_KEY}`).then((r: any) => r.json()), fhCandles(s)]);
    const price = fhQ?.c || parseFloat(tdQ?.close);
    const pct = fhQ?.dp ?? parseFloat(tdQ?.percent_change);
    const chg = fhQ?.d ?? parseFloat(tdQ?.change);
    if (!price) throw new Error('not found');
    const up = pct >= 0;
    const color = up ? '#22c55e' : '#ef4444';
    const name = tdQ?.name || s;
    result.innerHTML = `<div class="sl-company">${name}</div><div class="sl-price-row"><span class="sl-price" style="color:var(--gold)">$${fmtPrice(price)}</span><span class="sl-delta" style="color:${color}">${up ? '▲' : '▼'} $${Math.abs(chg).toFixed(2)} (${up ? '+' : ''}${pct.toFixed(2)}%)</span></div><div class="sl-stats"><div class="sl-stat"><span>Open</span><strong>$${fmtPrice(fhQ?.o)}</strong></div><div class="sl-stat"><span>Prev Close</span><strong>$${fmtPrice(fhQ?.pc)}</strong></div><div class="sl-stat"><span>High</span><strong>$${fmtPrice(fhQ?.h)}</strong></div><div class="sl-stat"><span>Low</span><strong>$${fmtPrice(fhQ?.l)}</strong></div></div><canvas id="slChart" style="height:130px;width:100%"></canvas>`;
    if (cd) {
      new (window as any).Chart(document.getElementById('slChart') as HTMLCanvasElement, {
        type: 'line',
        data: { labels: cd.timestamps.map((t: number) => new Date(t * 1000).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })),
          datasets: [{ data: cd.closes, borderColor: color, borderWidth: 2, pointRadius: 0, fill: true, backgroundColor: up ? 'rgba(34,197,94,0.08)' : 'rgba(239,68,68,0.08)' }] },
        options: { animation: false, responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx: any) => `$${ctx.parsed.y.toFixed(2)}` } } },
          scales: { x: { ticks: { color: '#8892a4', maxTicksLimit: 5 }, grid: { color: 'rgba(255,255,255,0.04)' } }, y: { ticks: { color: '#8892a4', callback: (v: any) => `$${v}` }, grid: { color: 'rgba(255,255,255,0.04)' } } } }
      });
    }
  } catch { document.getElementById('slResult')!.innerHTML = `<p class="sl-hint" style="color:#ef4444">Ticker "${sym}" not found.</p>`; }
}

document.getElementById('slBtn')?.addEventListener('click', () => {
  const v = (document.getElementById('slInput') as HTMLInputElement)?.value;
  if (v?.trim()) loadSpotlight(v.trim());
});
document.getElementById('slInput')?.addEventListener('keydown', (e: KeyboardEvent) => {
  if (e.key === 'Enter') { const v = (document.getElementById('slInput') as HTMLInputElement)?.value; if (v?.trim()) loadSpotlight(v.trim()); }
});

loadIndices();
loadMarkets();
loadNews();
loadFearGreed();
loadHeatmap();
setInterval(() => { loadIndices(); loadMarkets(); loadHeatmap(); }, 300000);
</script>
