</style>

<script>
  // ── All data from local JSON files (updated daily by GitHub Actions) ──
  const IDX_MAP: Record<string,string> = {
    '^NSEI':'NSEI','^BSESN':'BSESN','^NSEBANK':'NSEBANK','^CNXSC':'MID',
    '^CNXIT':'IT','^CNXAUTO':'AUTO','^CNXPHARMA':'PHARMA','^CNXFMCG':'FMCG'
  };

  function renderIndiaIndex(q: any) {
    const key = IDX_MAP[q.symbol]; if (!key) return;
    const chg=q.regularMarketChange??0, pct=q.regularMarketChangePercent??0, up=chg>=0;
    const color=up?'#22c55e':'#ef4444';
    const card=document.getElementById(`hidx-${key}`);
    if(card){card.classList.remove('skeleton');card.classList.add(up?'up':'dn');}
    const pEl=document.getElementById(`hidx-${key}-price`);
    if(pEl) pEl.textContent=q.regularMarketPrice?.toLocaleString('en-IN',{maximumFractionDigits:2});
    const cEl=document.getElementById(`hidx-${key}-chg`);
    if(cEl){cEl.textContent=`${up?'▲':'▼'} ${Math.abs(pct).toFixed(2)}%`;(cEl as HTMLElement).style.color=color;}
  }

  async function loadIndiaIndices() {
    try {
      const res = await fetch('/data/india-indices.json');
      const data = await res.json();
      data.indices.forEach(renderIndiaIndex);
    } catch(e) { console.error('indices load failed', e); }
  }

  function renderMarketCard(q: any) {
    const chg=q.regularMarketChange??0, pct=q.regularMarketChangePercent??0, up=chg>=0;
    const color=up?'#22c55e':'#ef4444';
    const nameEl=document.getElementById(`mn-${q.symbol}`),badgeEl=document.getElementById(`mb-${q.symbol}`),priceEl=document.getElementById(`mp-${q.symbol}`),chgEl=document.getElementById(`mch-${q.symbol}`),card=document.getElementById(`mc-${q.symbol}`);
    if(nameEl) nameEl.textContent=q.name||q.symbol.replace('.NS','');
    if(priceEl) priceEl.textContent=`₹${q.regularMarketPrice?.toLocaleString('en-IN',{maximumFractionDigits:2})}`;
    if(chgEl){chgEl.textContent=`${up?'▲':'▼'} ₹${Math.abs(chg).toFixed(2)}`;(chgEl as HTMLElement).style.color=color;}
    if(badgeEl){badgeEl.textContent=`${up?'+':''}${pct.toFixed(2)}%`;badgeEl.classList.add(up?'badge-up':'badge-dn');}
    if(card) card.classList.add(up?'up':'dn');
  }

  async function loadMarkets() {
    try {
      const res = await fetch('/data/india-stocks.json');
      const data = await res.json();
      data.nse.forEach(renderMarketCard);
    } catch(e) { console.error('stocks load failed', e); }
  }

  async function loadMarketPulse() {
    // ── VIX from local JSON ──────────────────────────────
    try {
      const res = await fetch('/data/india-indices.json');
      const data = await res.json();
      const vixQ = data.indices?.find((i:any) => i.symbol === '^INDIAVIX');
      if (vixQ && vixQ.regularMarketPrice) {
        const vix = vixQ.regularMarketPrice;
        const pct = vixQ.regularMarketChangePercent ?? 0;
        const color = vix < 15 ? '#10ef62' : vix < 22 ? '#eab308' : '#ff4757';
        const label = vix < 15 ? 'Low fear — market calm' : vix < 22 ? 'Moderate — normal range' : 'High fear — watch out';

        const gaugeVal = document.getElementById('vixGaugeVal');
        const vixArc   = document.getElementById('vixArc') as SVGPathElement|null;
        const vixNeedle= document.getElementById('vixNeedle') as SVGLineElement|null;
        const vixSub   = document.getElementById('vixSub');

        if (gaugeVal) { gaugeVal.textContent = vix.toFixed(1); gaugeVal.setAttribute('fill', color); }
        if (vixSub) vixSub.textContent = `${pct >= 0 ? '+' : ''}${pct.toFixed(2)}% today · ${label}`;

        // Needle: -90deg = left (VIX=0), 0deg = top (VIX=20), +90deg = right (VIX=40)
        const deg = -90 + Math.min(vix / 40, 1) * 180;
        if (vixNeedle) vixNeedle.style.transform = `rotate(${deg}deg)`;
        const shadow = document.getElementById('vixNeedleShadow');
        if (shadow) (shadow as SVGLineElement).style.transform = `rotate(${deg}deg)`;
      }
    } catch(e) {
      const s = document.getElementById('vixSub'); if(s) s.textContent = 'Data updates after market close';
    }

    // ── Nifty P/E (static estimate — NSE doesn't expose via free API) ──
    const PE_VAL = 22.4;
    const peEl  = document.getElementById('niftyPE');
    const peIns = document.getElementById('niftyPEInsight');
    const peMkr = document.getElementById('peMarker') as HTMLElement|null;
    if (peEl) peEl.textContent = `${PE_VAL}x`;
    if (peIns) peIns.textContent = PE_VAL < 18 ? '🟢 Undervalued — good entry zone' : PE_VAL < 24 ? '🟡 Fair value — normal range' : PE_VAL < 28 ? '🟠 Slightly pricey' : '🔴 Overvalued — caution';
    // Marker: PE scale 10–32, map to 0–100%
    if (peMkr) peMkr.style.left = `${Math.min(Math.max((PE_VAL - 10) / 22 * 100, 2), 98)}%`;

    // ── FII / DII — local JSON first, NSE API fallback ──
    const setFiiBar = (posId:string, negId:string, valId:string, net:number, maxAbs:number) => {
      const pct = Math.abs(net) / maxAbs * 100;
      const pos = document.getElementById(posId), neg = document.getElementById(negId), val = document.getElementById(valId);
      if (net >= 0) { if(pos) pos.style.width=pct+'%'; if(neg) neg.style.width='0%'; }
      else           { if(neg) neg.style.width=pct+'%'; if(pos) pos.style.width='0%'; }
      if (val) { val.textContent = `${net>=0?'+':''}₹${Math.abs(net/100).toFixed(0)}Cr`; (val as HTMLElement).style.color = net>=0?'#10ef62':'#ff4757'; }
    };
    let fiiLoaded = false;
    try {
      const r = await fetch('/data/fii-dii.json');
      const d = await r.json();
      if (d?.data?.length > 0) {
        const latest = d.data[0];
        const fiiNet = latest.fiiNet * 100, diiNet = latest.diiNet * 100;
        const maxAbs = Math.max(Math.abs(fiiNet), Math.abs(diiNet), 100);
        setFiiBar('fiiBarPos','fiiBarNeg','fiiVal', fiiNet, maxAbs);
        setFiiBar('diiBarPos','diiBarNeg','diiVal', diiNet, maxAbs);
        const sub = document.getElementById('fiiSub');
        if (sub) sub.textContent = `${latest.date||'Latest'} · Source: NSE India`;
        fiiLoaded = true;
      }
    } catch {}
    if (!fiiLoaded) {
      // Try live NSE API as fallback
      try {
        const r = await fetch('https://corsproxy.io/?' + encodeURIComponent('https://www.nseindia.com/api/fiidiiTradeReact'), { signal: AbortSignal.timeout(8000) });
        const d = await r.json();
        if (d && Array.isArray(d) && d.length > 0) {
          const latest = d[0];
          const fiiNet = parseFloat(latest.fiiNet || latest.fii_net || 0);
          const diiNet = parseFloat(latest.diiNet || latest.dii_net || 0);
          const maxAbs = Math.max(Math.abs(fiiNet), Math.abs(diiNet), 100);
          setFiiBar('fiiBarPos','fiiBarNeg','fiiVal', fiiNet*100, maxAbs*100);
          setFiiBar('diiBarPos','diiBarNeg','diiVal', diiNet*100, maxAbs*100);
          const sub = document.getElementById('fiiSub');
          if (sub) sub.textContent = `${latest.date||'Latest'} · Source: NSE India`;
          fiiLoaded = true;
        }
      } catch {}
    }
    if (!fiiLoaded) {
      const fiiV=document.getElementById('fiiVal'), diiV=document.getElementById('diiVal'), sub=document.getElementById('fiiSub');
      if(fiiV) { fiiV.textContent = 'N/A'; fiiV.style.color = 'var(--text-muted)'; }
      if(diiV) { diiV.textContent = 'N/A'; diiV.style.color = 'var(--text-muted)'; }
      if(sub)  sub.textContent = 'Updates daily after market close (3:30 PM IST)';
    }

    // ── Market Mood donut — from index breadth ──────────
    setTimeout(() => {
      const greenCount = document.querySelectorAll('.idx-pill.up').length;
      const redCount   = document.querySelectorAll('.idx-pill.dn').length;
      const total      = greenCount + redCount || 8;
      const circ       = 289; // 2π × 46
      const greenDash  = (greenCount / total) * circ;
      const redDash    = (redCount   / total) * circ;

      const gArc = document.getElementById('moodGreen') as SVGCircleElement|null;
      const rArc = document.getElementById('moodRed')   as SVGCircleElement|null;
      if (gArc) { gArc.style.strokeDashoffset = String(circ - greenDash); gArc.style.strokeDasharray = `${greenDash} ${circ - greenDash}`; }
      if (rArc) {
        // offset red arc to start after green
        rArc.style.strokeDasharray = `${redDash} ${circ - redDash}`;
        rArc.style.strokeDashoffset = String(circ - greenDash);
        rArc.style.transform = `rotate(${(greenCount/total)*360 - 90}deg)`;
        rArc.style.transformOrigin = '60px 60px';
      }

      const pct = Math.round(greenCount / total * 100);
      const pctEl  = document.getElementById('moodPct');
      const lblEl  = document.getElementById('moodLabel');
      const gCount = document.getElementById('moodGreenCount');
      const rCount = document.getElementById('moodRedCount');
      const moodV  = document.getElementById('moodVal');
      const moodI  = document.getElementById('moodInsight');

      if (pctEl) { pctEl.textContent = pct + '%'; pctEl.setAttribute('fill', pct > 60 ? '#10ef62' : pct > 40 ? '#eab308' : '#ff4757'); }
      if (lblEl) lblEl.textContent = 'green';
      if (gCount) gCount.textContent = String(greenCount);
      if (rCount) rCount.textContent = String(redCount);
      const mood   = pct > 65 ? 'Bullish' : pct > 40 ? 'Neutral' : 'Bearish';
      const advice = pct > 65 ? 'Most sectors advancing.' : pct > 40 ? 'Mixed signals — be selective.' : 'Broad selling — watch levels.';
      if (moodV) { moodV.textContent = mood; (moodV as HTMLElement).style.color = pct > 65 ? '#10ef62' : pct > 40 ? '#eab308' : '#ff4757'; }
      if (moodI) moodI.textContent = advice;
    }, 3500);
  }

  // News ticker for Indian markets
  async function loadNews() {
    const list=document.getElementById('newsList');
    if(!list) return;
    try{
      const r=await fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent('https://economictimes.indiatimes.com/markets/rssfeeds/1977021501.cms')}&count=10`);
      const d=await r.json();
      const items=d?.items||[];
      if(!items.length) throw new Error('empty');
      list.innerHTML=items.map((item:any)=>{
        const date=new Date(item.pubDate).toLocaleDateString('en-IN',{month:'short',day:'numeric'});
        return `<a href="${item.link}" class="news-item" target="_blank" rel="noopener"><div class="ni-title">${item.title}</div><div class="ni-meta">Economic Times · ${date}</div></a>`;
      }).join('');
    }catch{}
  }

  // Spotlight
  async function loadSpotlight(rawSym: string) {
    const result=document.getElementById('slResult');
    if(!result) return;
    const s=rawSym.toUpperCase().trim();
    const sym=s.includes('.')?s:s+'.NS';
    const fname=sym.replace(/\./g,'-');
    result.innerHTML=`<p class="sl-hint">Analyzing ${sym}…</p>`;
    try{
      const res=await fetch(`/data/company/${fname}.json`);
      if(!res.ok) throw new Error('not found');
      const d=await res.json();
      if(!d.regularMarketPrice) throw new Error('not found');
      const price=d.regularMarketPrice,chg=d.regularMarketChange||0,pct=d.regularMarketChangePercent||0;
      const high52=d.fiftyTwoWeekHigh||price,low52=d.fiftyTwoWeekLow||price;
      const up=chg>=0,color=up?'#22c55e':'#ef4444';
      const mcap=d.marketCap>=1e12?`₹${(d.marketCap/1e12).toFixed(2)}T`:d.marketCap>=1e9?`₹${(d.marketCap/1e9).toFixed(1)}B`:d.marketCap>=1e7?`₹${(d.marketCap/1e7).toFixed(0)}Cr`:'—';
      const priceVsHigh=high52>low52?((price-low52)/(high52-low52))*100:50;
      const momentum=pct>1?'Strong positive':pct>0?'Mild positive':pct>-1?'Mild negative':'Strong negative';
      const score=Math.max(10,Math.min(90,Math.round(50+pct*2-(priceVsHigh-50)*0.3)));
      const action=score>65?'🟢 Bullish — consider buying on dips':score>40?'🟡 Neutral — hold and watch':'🔴 Bearish — wait for better entry';
      const actionColor=score>65?'#22c55e':score>40?'#eab308':'#ef4444';
      const entryAdvice=score>65?'Consider SIP entry or buy on 3–5% dip. Price is well-positioned in its 52-week range.':score>40?'No strong signal yet. Use SIP or wait for breakout confirmation on high volume.':'Under selling pressure. Wait for RSI < 40 and price stabilization near 52W low before entering.';
      result.innerHTML=`
        <div class="sl-company">${d.longName||sym.replace('.NS','')} <span style="font-size:12px;color:var(--text-muted);font-weight:400">${d.sector||''}</span></div>
        <div class="sl-price-row">
          <span class="sl-price" style="color:var(--gold)">₹${price.toLocaleString('en-IN',{maximumFractionDigits:2})}</span>
          <span class="sl-delta" style="color:${color}">${up?'▲':'▼'} ₹${Math.abs(chg).toFixed(2)} (${up?'+':''}${pct.toFixed(2)}%)</span>
        </div>
        <div class="sl-stats">
          <div class="sl-stat"><span>Market Cap</span><strong>${mcap}</strong></div>
          <div class="sl-stat"><span>52W High</span><strong>₹${high52.toFixed(2)}</strong></div>
          <div class="sl-stat"><span>52W Low</span><strong>₹${low52.toFixed(2)}</strong></div>
          <div class="sl-stat"><span>vs 52W Range</span><strong>${priceVsHigh.toFixed(0)}%</strong></div>
          <div class="sl-stat"><span>Momentum</span><strong>${momentum}</strong></div>
          <div class="sl-stat"><span>Exchange</span><strong>NSE</strong></div>
        </div>
        <div style="background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.2);border-radius:10px;padding:14px 18px;margin-top:14px">
          <div style="font-size:10px;font-weight:700;letter-spacing:.8px;color:var(--gold);margin-bottom:6px">AI INVESTMENT INSIGHT</div>
          <div style="font-size:15px;font-weight:700;color:${actionColor};margin-bottom:6px">${action}</div>
          <div style="font-size:12px;color:var(--text-muted)">${entryAdvice}</div>
          <div style="font-size:11px;color:var(--text-dim);margin-top:8px">⚠️ Algorithmic analysis only — not financial advice. Always DYOR.</div>
        </div>
        <a href="/company/${sym.toLowerCase().replace(/\./g,'-')}" style="display:inline-block;margin-top:12px;background:var(--gold);color:#0b0f1a;padding:8px 20px;border-radius:8px;font-size:12px;font-weight:700">Full Deep Dive →</a>
      `;
    }catch{
      result.innerHTML=`<p class="sl-hint" style="color:#ef4444">Ticker "${rawSym}" not found. Try: RELIANCE, TCS, HDFCBANK, INFY, SBIN, BAJFINANCE</p>`;
    }
  }

  document.getElementById('slBtn')?.addEventListener('click',()=>{const v=(document.getElementById('slInput') as HTMLInputElement)?.value;if(v?.trim()) loadSpotlight(v.trim());});
  document.getElementById('slInput')?.addEventListener('keydown',(e:KeyboardEvent)=>{if(e.key==='Enter'){const v=(document.getElementById('slInput') as HTMLInputElement)?.value;if(v?.trim()) loadSpotlight(v.trim());}});

  loadMarkets();
  loadIndiaIndices();
  loadNews();
  loadMarketPulse();
  setInterval(()=>{loadMarkets();loadIndiaIndices();loadMarketPulse();},60000);

  // ── Hero chip loading shimmer ─────────────────────────
  ['chip-nifty-val','chip-nifty-chg','chip-sensex-val','chip-sensex-chg','chip-rel-val','chip-rel-chg','chip-tcs-val','chip-tcs-chg'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.add('loading');
  });

  // ── Hero animated chart (sine wave that looks like a stock chart) ──
  function drawHeroChart() {
    const line = document.getElementById('heroChartLine');
    if (!line) return;
    const pts = [];
    const W = 200, H = 80, points = 40;
    let y = 50;
    for (let i = 0; i <= points; i++) {
      const x = (i / points) * W;
      y = y + (Math.random() - 0.46) * 8;
      y = Math.max(10, Math.min(70, y));
      pts.push(`${x},${y}`);
    }
    line.setAttribute('points', pts.join(' '));
  }
  drawHeroChart();
  setInterval(drawHeroChart, 3000);

  // ── Hero chips: update with real Nifty/Sensex/stock data ──
  async function updateHeroChips() {
    try {
      const [idxRes, stkRes] = await Promise.all([
        fetch('/data/india-indices.json'),
        fetch('/data/india-stocks.json')
      ]);
      const idxData = await idxRes.json();
      const stkData = await stkRes.json();

      const chips = [
        { valId:'chip-nifty-val',  chgId:'chip-nifty-chg',  q: idxData.indices?.find(i => i.symbol === '^NSEI') },
        { valId:'chip-sensex-val', chgId:'chip-sensex-chg', q: idxData.indices?.find(i => i.symbol === '^BSESN') },
        { valId:'chip-rel-val',    chgId:'chip-rel-chg',    q: stkData.nse?.find(s => s.symbol === 'RELIANCE.NS') },
        { valId:'chip-tcs-val',    chgId:'chip-tcs-chg',    q: stkData.nse?.find(s => s.symbol === 'TCS.NS') },
      ];

      for (const { valId, chgId, q } of chips) {
        const valEl = document.getElementById(valId);
        const chgEl = document.getElementById(chgId);
        if (!q) {
          if (valEl) { valEl.classList.remove('loading'); }
          if (chgEl) { chgEl.classList.remove('loading'); }
          continue;
        }
        const up = (q.regularMarketChangePercent ?? 0) >= 0;
        if (valEl) {
          valEl.classList.remove('loading');
          valEl.textContent = q.regularMarketPrice?.toLocaleString('en-IN', { maximumFractionDigits: 0 });
        }
        if (chgEl) {
          chgEl.classList.remove('loading');
          chgEl.textContent = `${up ? '▲' : '▼'} ${Math.abs(q.regularMarketChangePercent ?? 0).toFixed(2)}%`;
          chgEl.className = `chip-chg ${up ? 'up' : 'dn'}`;
        }
      }
    } catch(e) {
      // On failure, at least clear the loading state so labels show
      ['chip-nifty-val','chip-nifty-chg','chip-sensex-val','chip-sensex-chg',
       'chip-rel-val','chip-rel-chg','chip-tcs-val','chip-tcs-chg'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.remove('loading');
      });
    }
  }
  updateHeroChips();
</script>
