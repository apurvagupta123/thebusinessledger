---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await Astro.glob('./blog/*.md').catch(() => []);
const sorted = posts.sort((a: any, b: any) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);

const INDIA_TAGS = ['india-market-briefing', 'market-briefing', 'today-indian-market'];
const allIndiaPosts = sorted.filter((p: any) =>
  (p.frontmatter.tags || []).some((t: string) => INDIA_TAGS.includes(t))
);
const allLedgerPosts = sorted.filter((p: any) =>
  !(p.frontmatter.tags || []).some((t: string) => INDIA_TAGS.includes(t))
);
const indiaPosts  = allIndiaPosts.slice(0, 5);
const ledgerPosts = allLedgerPosts.slice(0, 5);

const SECTOR_TAGS: Record<string, string> = {
  'RELIANCE.NS':   '⚡ Energy',
  'TCS.NS':        '💻 IT',
  'HDFCBANK.NS':   '🏦 Banking',
  'INFY.NS':       '💻 IT',
  'ICICIBANK.NS':  '🏦 Banking',
  'BAJFINANCE.NS': '💳 Finance',
  'TMCV.NS':       '🚗 Auto',
  'BHARTIARTL.NS': '📡 Telecom',
  'MARUTI.NS':     '🚗 Auto',
  'SBIN.NS':       '🏦 PSU Bank',
  'LT.NS':         '🏗️ Infra',
  'WIPRO.NS':      '💻 IT',
  'HCLTECH.NS':    '💻 IT',
  'KOTAKBANK.NS':  '🏦 Banking',
  'TITAN.NS':      '✨ Consumer',
  'ASIANPAINT.NS': '🎨 FMCG',
};
---
<BaseLayout title="Where Smart Money Reads">

  <!-- ── Hero ────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner hero-split">

      <!-- Left: Text Content -->
      <div class="hero-content">
        <h1 class="hero-title">
          Bull Signal.<br />
          <span class="hero-accent">Sharper Moves.</span>
        </h1>
        <p class="hero-desc">
          NSE & BSE data updated twice daily — 4 PM & 2 AM IST.<br />
          Indian stock insights and AI-powered investment analysis.
        </p>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hs-num">NSE/BSE</span>
            <span class="hs-label">LIVE DATA</span>
          </div>
          <div class="hs-divider"></div>
          <div class="hero-stat">
            <span class="hs-num">AI</span>
            <span class="hs-label">STOCK INSIGHTS</span>
          </div>
          <div class="hs-divider"></div>
          <div class="hero-stat">
            <span class="hs-num">Daily</span>
            <span class="hs-label">MARKET BRIEFING</span>
          </div>
        </div>
        <div class="hero-actions">
          <button class="btn-primary" onclick="document.getElementById('markets').scrollIntoView({behavior:'smooth'})">Explore Markets →</button>
          <button class="btn-outline" onclick="document.getElementById('market-pulse').scrollIntoView({behavior:'smooth'})">Market Pulse</button>
        </div>
      </div>

      <!-- Right: Bull Image Visual -->
      <div class="hero-visual" aria-hidden="true">
        <!-- Glow backdrop -->
        <div class="hv-glow-backdrop"></div>
        <!-- Orbit rings (outside bull image, so they're visible) -->
        <div class="hv-orbit-ring"></div>
        <div class="hv-orbit-ring-2"></div>

        <!-- Bull Image -->
        <div class="hv-bull-wrap">
          <img src="/bull-hero.jpg" alt="Bull market" class="hv-bull-img" />
          <div class="hv-bull-overlay"></div>
        </div>

        <!-- Floating Market Chips -->
        <div class="hv-chip hv-chip-1">
          <span class="chip-label">NIFTY 50</span>
          <span class="chip-val loading" id="chip-nifty-val">——</span>
          <span class="chip-chg loading" id="chip-nifty-chg">——</span>
        </div>
        <div class="hv-chip hv-chip-2">
          <span class="chip-label">SENSEX</span>
          <span class="chip-val loading" id="chip-sensex-val">——</span>
          <span class="chip-chg loading" id="chip-sensex-chg">——</span>
        </div>
        <div class="hv-chip hv-chip-3">
          <span class="chip-label">RELIANCE</span>
          <span class="chip-val loading" id="chip-rel-val">——</span>
          <span class="chip-chg loading" id="chip-rel-chg">——</span>
        </div>
        <div class="hv-chip hv-chip-4">
          <span class="chip-label">TCS</span>
          <span class="chip-val loading" id="chip-tcs-val">——</span>
          <span class="chip-chg loading" id="chip-tcs-chg">——</span>
        </div>

      </div>

    </div>
  </section>

  <!-- ── Indices Strip ─────────────────────────────────── -->
  <section class="indices-section reveal">
    <div class="idx-strip" id="indicesBar">
      {[
        {key:'NSEI',   name:'NIFTY 50'},
        {key:'BSESN',  name:'SENSEX'},
        {key:'NSEBANK',name:'NIFTY BANK'},
        {key:'MID',    name:'SMALLCAP'},
        {key:'IT',     name:'NIFTY IT'},
        {key:'AUTO',   name:'NIFTY AUTO'},
        {key:'PHARMA', name:'PHARMA'},
        {key:'FMCG',   name:'NIFTY FMCG'},
      ].map(({key, name}) => (
        <div class="idx-pill skeleton" id={`hidx-${key}`}>
          <span class="idx-pill-name">{name}</span>
          <span class="idx-pill-price" id={`hidx-${key}-price`}>—</span>
          <span class="idx-pill-chg"   id={`hidx-${key}-chg`}>—</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Today's Indian Markets ──────────────────────── -->
  <section class="content-section reveal" id="markets">
    <div class="section-head">
      <h2 class="section-title">Indian Markets — Top Stocks</h2>
      <a href="/markets" class="section-more">View all sectors →</a>
    </div>
    <!-- Table header -->
    <div class="mkt-table-head">
      <span>Company</span>
      <span>Price</span>
      <span>Change</span>
      <span class="mkt-th-pct">% Change</span>
    </div>
    <div class="mkt-table" id="marketsGrid">
      {['RELIANCE.NS','TCS.NS','HDFCBANK.NS','INFY.NS','ICICIBANK.NS','BAJFINANCE.NS','TMCV.NS','BHARTIARTL.NS','MARUTI.NS','SBIN.NS','LT.NS','WIPRO.NS','HCLTECH.NS','KOTAKBANK.NS','TITAN.NS','ASIANPAINT.NS'].map((sym) => (
        <a class="mkt-row" id={`mc-${sym}`} href={`/company/${sym.toLowerCase().replace(/\./g,'-')}`}>
          <div class="mkt-row-sym">
            {SECTOR_TAGS[sym] && <span class="mkt-row-sector">{SECTOR_TAGS[sym]}</span>}
            <span class="mkt-sym">{sym.replace('.NS','')}</span>
            <span class="mkt-name" id={`mn-${sym}`}>—</span>
          </div>
          <div class="mkt-row-price" id={`mp-${sym}`}>—</div>
          <div class="mkt-row-chg"  id={`mch-${sym}`}>—</div>
          <div class="mkt-row-pct">
            <span class="mkt-badge" id={`mb-${sym}`}>—</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Market Pulse ──────────────────────────────────── -->
  <section class="content-section reveal reveal-d1" id="market-pulse">
    <div class="section-head">
      <h2 class="section-title">Market Pulse</h2>
      <span class="section-live">LIVE</span>
    </div>
    <div class="pulse-grid">

      <!-- VIX Gauge -->
      <div class="pulse-card">
        <div class="pulse-label">India VIX <span class="pulse-badge">Fear Index</span></div>
        <div class="vix-gauge-wrap">
          <svg viewBox="0 0 220 130" class="vix-svg">
            <!-- Background track -->
            <path d="M 25 115 A 85 85 0 0 1 195 115" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="14" stroke-linecap="round"/>
            <!-- Zone: Low 0–15 -->
            <path d="M 25 115 A 85 85 0 0 1 77.6 36.5" fill="none" stroke="rgba(16,239,98,0.4)" stroke-width="14" stroke-linecap="round"/>
            <!-- Zone: Moderate 15–22 -->
            <path d="M 77.6 36.5 A 85 85 0 0 1 123.3 31.1" fill="none" stroke="rgba(234,179,8,0.4)" stroke-width="14"/>
            <!-- Zone: High 22–40 -->
            <path d="M 123.3 31.1 A 85 85 0 0 1 195 115" fill="none" stroke="rgba(255,71,87,0.4)" stroke-width="14" stroke-linecap="round"/>
            <!-- Zone labels -->
            <text x="30" y="112" font-size="9" fill="rgba(16,239,98,0.8)" font-weight="700">LOW</text>
            <text x="98" y="26" font-size="9" fill="rgba(234,179,8,0.8)" font-weight="700" text-anchor="middle">MOD</text>
            <text x="183" y="112" font-size="9" fill="rgba(255,71,87,0.8)" font-weight="700" text-anchor="end">HIGH</text>
            <!-- Needle shadow -->
            <line x1="110" y1="115" x2="110" y2="42" stroke="rgba(0,0,0,0.5)" stroke-width="4.5" stroke-linecap="round"
              id="vixNeedleShadow" style="transform-origin:110px 115px;transform:rotate(-90deg);transition:transform 1.2s cubic-bezier(0.34,1.56,0.64,1)"/>
            <!-- Needle -->
            <line x1="110" y1="115" x2="110" y2="40" stroke="#f0c040" stroke-width="3" stroke-linecap="round"
              id="vixNeedle" style="transform-origin:110px 115px;transform:rotate(-90deg);transition:transform 1.2s cubic-bezier(0.34,1.56,0.64,1)"/>
            <!-- Center cap outer ring -->
            <circle cx="110" cy="115" r="8" fill="#0d0b26" stroke="rgba(212,169,64,0.3)" stroke-width="1.5"/>
            <circle cx="110" cy="115" r="4" fill="#d4a940"/>
            <!-- Value -->
            <text x="110" y="96" text-anchor="middle" font-size="28" font-weight="800" fill="white" id="vixGaugeVal">—</text>
          </svg>
        </div>
        <div class="pulse-sub" id="vixSub" style="text-align:center;margin-top:4px">Loading…</div>
      </div>

      <!-- Nifty P/E Zone Bar -->
      <div class="pulse-card">
        <div class="pulse-label">Nifty 50 P/E <span class="pulse-badge">Valuation</span></div>
        <div style="margin:16px 0 8px;text-align:center">
          <span class="pulse-value" id="niftyPE" style="font-size:2.2rem">—</span>
          <span style="font-size:12px;color:var(--text-muted);margin-left:6px">P/E ratio</span>
        </div>
        <div class="pe-zone-wrap">
          <div class="pe-zone-bar">
            <div class="pe-zone pez-cheap">Cheap<br/><span>&lt;18x</span></div>
            <div class="pe-zone pez-fair">Fair<br/><span>18–24x</span></div>
            <div class="pe-zone pez-rich">Pricey<br/><span>24–28x</span></div>
            <div class="pe-zone pez-bubble">Bubble<br/><span>&gt;28x</span></div>
            <div class="pe-marker" id="peMarker" style="left:50%"></div>
          </div>
        </div>
        <div class="pulse-sub" id="niftyPESub" style="margin-top:10px;text-align:center">Long-term avg ~22x · Source: NSE India</div>
        <div class="pulse-insight" id="niftyPEInsight" style="text-align:center"></div>
      </div>

      <!-- FII / DII Bar Chart -->
      <div class="pulse-card">
        <div class="pulse-label">FII / DII Flow <span class="pulse-badge">Latest</span></div>
        <div class="fii-chart-wrap" id="fiiChartWrap">
          <div class="fii-bar-row">
            <span class="fii-lbl">FII</span>
            <div class="fii-track">
              <div class="fii-bar-neg" id="fiiBarNeg" style="width:0%"></div>
              <div class="fii-bar-pos" id="fiiBarPos" style="width:0%"></div>
            </div>
            <span class="fii-val" id="fiiVal">—</span>
          </div>
          <div class="fii-bar-row" style="margin-top:12px">
            <span class="fii-lbl">DII</span>
            <div class="fii-track">
              <div class="fii-bar-neg" id="diiBarNeg" style="width:0%"></div>
              <div class="fii-bar-pos" id="diiBarPos" style="width:0%"></div>
            </div>
            <span class="fii-val" id="diiVal">—</span>
          </div>
          <div class="fii-zero-line"></div>
        </div>
        <div class="pulse-sub" id="fiiSub" style="margin-top:10px">Fetching NSE data…</div>
      </div>

      <!-- Market Mood Donut -->
      <div class="pulse-card">
        <div class="pulse-label">Market Mood <span class="pulse-badge">Today</span></div>
        <div class="mood-wrap">
          <svg viewBox="0 0 120 120" class="mood-donut" id="moodDonut">
            <circle cx="60" cy="60" r="46" fill="none" stroke="rgba(255,255,255,.06)" stroke-width="18"/>
            <circle cx="60" cy="60" r="46" fill="none" stroke="#10ef62" stroke-width="18"
              stroke-dasharray="289" stroke-dashoffset="289" id="moodGreen"
              style="transform:rotate(-90deg);transform-origin:60px 60px;transition:stroke-dashoffset 1s ease"/>
            <circle cx="60" cy="60" r="46" fill="none" stroke="#ff4757" stroke-width="18"
              stroke-dasharray="289" stroke-dashoffset="289" id="moodRed"
              style="transform:rotate(-90deg);transform-origin:60px 60px;transition:stroke-dashoffset 1s ease"/>
            <text x="60" y="55" text-anchor="middle" font-size="20" font-weight="800" fill="white" id="moodPct">—</text>
            <text x="60" y="70" text-anchor="middle" font-size="9" fill="#94a3b8" id="moodLabel">green</text>
          </svg>
          <div class="mood-legend">
            <div class="mood-leg-item"><span style="background:#10ef62"></span><span id="moodGreenCount">—</span> Up</div>
            <div class="mood-leg-item"><span style="background:#ff4757"></span><span id="moodRedCount">—</span> Down</div>
          </div>
        </div>
        <div class="pulse-value" id="moodVal" style="font-size:1.1rem;text-align:center;margin-top:6px">—</div>
        <div class="pulse-insight" id="moodInsight" style="text-align:center"></div>
      </div>

    </div>
  </section>

  <!-- ── Company Spotlight ─────────────────────────────── -->
  <section class="content-section reveal reveal-d2">
    <div class="section-head">
      <h2 class="section-title">Company Spotlight</h2>
    </div>
    <div class="spotlight-box">
      <div class="spotlight-search">
        <input id="slInput" type="text" class="sl-input" placeholder="Enter NSE ticker (e.g. RELIANCE, TCS, HDFCBANK)" />
        <button id="slBtn" class="sl-btn">Analyze →</button>
      </div>
      <div id="slResult">
        <p class="sl-hint">Enter an NSE stock symbol above to get live price and AI investment insight.</p>
      </div>
    </div>
  </section>


  <!-- ── Blog Posts — From the Ledger (timeline) ──────── -->
  {ledgerPosts.length > 0 && (
    <section class="content-section reveal" id="from-ledger">
      <div class="section-head">
        <h2 class="section-title">From the Ledger</h2>
        <span class="section-live">MARKET SUMMARIES</span>
      </div>
      <div class="tl-list">
        {ledgerPosts.map((post: any) => {
          const d = new Date(post.frontmatter.date);
          const day   = d.toLocaleDateString('en-IN', { day: 'numeric' });
          const month = d.toLocaleDateString('en-IN', { month: 'short' });
          const year  = d.getFullYear();
          return (
            <a href={post.url} class="tl-item">
              <div class="tl-date-col">
                <span class="tl-day">{day}</span>
                <span class="tl-mon">{month} {year}</span>
              </div>
              <div class="tl-dot-col">
                <div class="tl-dot"></div>
                <div class="tl-line"></div>
              </div>
              <div class="tl-body">
                <h3 class="tl-title">{post.frontmatter.title}</h3>
                {post.frontmatter.description && <p class="tl-desc">{post.frontmatter.description}</p>}
                <span class="tl-read">Read more →</span>
              </div>
            </a>
          );
        })}
      </div>
      {allLedgerPosts.length > 5 && (
        <div class="tl-viewall-wrap">
          <a href="/blog/?section=ledger" class="tl-viewall">View all market summaries →</a>
        </div>
      )}
    </section>
  )}

  <!-- ── Blog Posts — Daily India Insights (timeline) ──── -->
  {indiaPosts.length > 0 && (
    <section class="content-section reveal" id="daily-india">
      <div class="section-head">
        <h2 class="section-title">Daily India Insights</h2>
        <span class="section-live">INDIA BRIEFINGS</span>
      </div>
      <div class="tl-list">
        {indiaPosts.map((post: any) => {
          const d = new Date(post.frontmatter.date);
          const day   = d.toLocaleDateString('en-IN', { day: 'numeric' });
          const month = d.toLocaleDateString('en-IN', { month: 'short' });
          const year  = d.getFullYear();
          return (
            <a href={post.url} class="tl-item">
              <div class="tl-date-col">
                <span class="tl-day">{day}</span>
                <span class="tl-mon">{month} {year}</span>
              </div>
              <div class="tl-dot-col">
                <div class="tl-dot"></div>
                <div class="tl-line"></div>
              </div>
              <div class="tl-body">
                <h3 class="tl-title">{post.frontmatter.title}</h3>
                {post.frontmatter.description && <p class="tl-desc">{post.frontmatter.description}</p>}
                <span class="tl-read">Read more →</span>
              </div>
            </a>
          );
        })}
      </div>
      {allIndiaPosts.length > 5 && (
        <div class="tl-viewall-wrap">
          <a href="/blog/?section=india" class="tl-viewall">View all India briefings →</a>
        </div>
      )}
    </section>
  )}

</BaseLayout>

<style>
/* ── Hero Split Layout ───────────────────────────────── */
.hero-split {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
}
.hero-content { flex: 1; min-width: 0; }
.hero-visual {
  flex: 0 0 420px;
  position: relative;
  height: 420px;
  display: flex;
  align-items: center;
  justify-content: center;
}
@media (max-width: 900px) { .hero-visual { display: none; } }

/* ── Bull Image Visual ───────────────────────────────── */
.hv-glow-backdrop {
  position: absolute;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212,169,64,.22) 0%, rgba(184,134,11,.1) 50%, transparent 75%);
  animation: glow-pulse 3s ease-in-out infinite;
  z-index: 0;
}
@keyframes glow-pulse {
  0%, 100% { transform: scale(1);    opacity: 1; }
  50%       { transform: scale(1.08); opacity: 0.85; }
}

.hv-orbit-ring {
  position: absolute;
  width: 400px;
  height: 400px;
  border-radius: 50%;
  border: 1px solid rgba(212,169,64,.35);
  animation: orbit-spin 18s linear infinite;
  z-index: 3;
  pointer-events: none;
}
.hv-orbit-ring::after {
  content: '';
  position: absolute;
  top: -5px;
  left: 50%;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #f0c040;
  box-shadow: 0 0 12px #d4a940, 0 0 24px rgba(212,169,64,.7);
  transform: translateX(-50%);
}
.hv-orbit-ring-2 {
  position: absolute;
  width: 440px;
  height: 440px;
  border-radius: 50%;
  border: 1px dashed rgba(212,169,64,.18);
  animation: orbit-spin 32s linear infinite reverse;
  z-index: 3;
  pointer-events: none;
}
.hv-orbit-ring-2::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 50%;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: rgba(212,169,64,.8);
  box-shadow: 0 0 8px #d4a940;
  transform: translateX(-50%);
}
@keyframes orbit-spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

.hv-bull-wrap {
  position: absolute;
  width: 360px;
  height: 360px;
  z-index: 2;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 0 40px rgba(212,169,64,.5), 0 0 80px rgba(212,169,64,.25);
  animation: bull-float 5s ease-in-out infinite;
}
@keyframes bull-float {
  0%, 100% { transform: translateY(0px) scale(1); }
  50%       { transform: translateY(-8px) scale(1.02); }
}
.hv-bull-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}
/* Purple tint overlay */
.hv-bull-overlay {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: radial-gradient(circle at 60% 40%, transparent 30%, rgba(184,134,11,.35) 100%);
  mix-blend-mode: multiply;
  pointer-events: none;
}

/* ── Floating Ticker Chips ───────────────────────────── */
.hv-chip {
  position: absolute;
  background: rgba(5,8,15,.92);
  border: 1px solid rgba(212,169,64,.25);
  border-radius: 10px;
  padding: 8px 12px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  backdrop-filter: blur(10px);
  z-index: 4;
  min-width: 90px;
  transition: transform .3s ease, box-shadow .3s ease;
  box-shadow: 0 4px 16px rgba(0,0,0,.4), 0 0 0 1px rgba(212,169,64,.05);
}
.hv-chip:hover { box-shadow: 0 4px 24px rgba(212,169,64,.15), 0 0 0 1px rgba(212,169,64,.2); }
.chip-label { font-size: 9px; font-weight: 700; letter-spacing: .8px; color: #d4a940; text-transform: uppercase; }
.chip-val   { font-size: 13px; font-weight: 800; color: #fff; }
.chip-chg   { font-size: 10px; font-weight: 700; color: var(--text-muted,#94a3b8); }
.chip-chg.up { color: #22c55e; }
.chip-chg.dn { color: #ef4444; }

/* Chip positions + float animations */
.hv-chip-1 { top: 10px;  left: 30px;  animation: float-a 5s ease-in-out infinite; }
.hv-chip-2 { top: 10px;  right: 20px; animation: float-b 6s ease-in-out infinite; }
.hv-chip-3 { bottom: 60px; left: 10px;  animation: float-c 5.5s ease-in-out infinite; }
.hv-chip-4 { bottom: 60px; right: 15px; animation: float-d 4.8s ease-in-out infinite; }
@keyframes float-a { 0%,100%{transform:translateY(0)}   50%{transform:translateY(-10px)} }
@keyframes float-b { 0%,100%{transform:translateY(0)}   50%{transform:translateY(-14px)} }
@keyframes float-c { 0%,100%{transform:translateY(0)}   50%{transform:translateY(-8px)}  }
@keyframes float-d { 0%,100%{transform:translateY(0)}   50%{transform:translateY(-12px)} }

/* Chip loading shimmer */
.hv-chip .chip-val.loading,
.hv-chip .chip-chg.loading {
  background: linear-gradient(90deg,rgba(255,255,255,.06) 25%,rgba(255,255,255,.14) 50%,rgba(255,255,255,.06) 75%);
  background-size: 200% 100%;
