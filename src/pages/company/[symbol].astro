---
import BaseLayout from '../../layouts/BaseLayout.astro';

const { symbol } = Astro.params;
const sym = symbol?.toUpperCase() || 'AAPL';

export async function getStaticPaths() {
  // Pre-build pages for major companies; any other symbol works via SSR fallback
  const symbols = ['AAPL','MSFT','GOOGL','AMZN','TSLA','META','NVDA','JPM','GS','NFLX','AMD','INTC','BRK-B','V','MA'];
  return symbols.map(s => ({ params: { symbol: s.toLowerCase() } }));
}
---
<BaseLayout title={`${sym} — Company Deep Dive`}>

  <div class="company-page">

    <!-- Header -->
    <div class="cp-header">
      <a href="/" class="cp-back">← Markets</a>
      <div class="cp-hero" id="cpHero">
        <div class="cp-sym">{sym}</div>
        <div class="cp-name-loading">Loading…</div>
      </div>
    </div>

    <!-- Price + Stats Strip -->
    <div class="cp-price-strip" id="cpPriceStrip">
      <div class="cps-item"><span class="cps-label">PRICE</span><span class="cps-val" id="cpPrice">—</span></div>
      <div class="cps-item"><span class="cps-label">CHANGE</span><span class="cps-val" id="cpChange">—</span></div>
      <div class="cps-item"><span class="cps-label">MARKET CAP</span><span class="cps-val" id="cpMcap">—</span></div>
      <div class="cps-item"><span class="cps-label">P/E RATIO</span><span class="cps-val" id="cpPE">—</span></div>
      <div class="cps-item"><span class="cps-label">52W HIGH</span><span class="cps-val" id="cpHigh">—</span></div>
      <div class="cps-item"><span class="cps-label">52W LOW</span><span class="cps-val" id="cpLow">—</span></div>
      <div class="cps-item"><span class="cps-label">AVG VOLUME</span><span class="cps-val" id="cpVol">—</span></div>
      <div class="cps-item"><span class="cps-label">DIVIDEND</span><span class="cps-val" id="cpDiv">—</span></div>
    </div>

    <!-- Chart + About -->
    <div class="cp-main">
      <div class="cp-chart-box">
        <div class="cp-chart-controls">
          <button class="cpc-btn active" data-days="30" data-span="day">1M</button>
          <button class="cpc-btn" data-days="90" data-span="day">3M</button>
          <button class="cpc-btn" data-days="180" data-span="day">6M</button>
          <button class="cpc-btn" data-days="365" data-span="day">1Y</button>
          <button class="cpc-btn" data-days="1825" data-span="week">5Y</button>
        </div>
        <div class="cp-chart-wrap">
          <canvas id="companyChart"></canvas>
        </div>
      </div>

      <div class="cp-about-box" id="cpAboutBox">
        <h3 class="cp-box-title">About</h3>
        <p class="cp-about-text" id="cpAbout">Loading company information…</p>
        <div class="cp-about-meta" id="cpAboutMeta"></div>
      </div>
    </div>

    <!-- News -->
    <div class="content-section" style="padding:0">
      <div class="section-head">
        <h2 class="section-title" id="cpNewsTitle">{sym} News</h2>
      </div>
      <div class="news-list" id="cpNewsList">
        {[1,2,3,4,5].map(() => (
          <div class="news-item">
            <div class="news-shimmer news-shimmer-title"></div>
            <div class="news-shimmer news-shimmer-meta"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Related Companies -->
    <div class="content-section" style="padding:0; margin-top:44px">
      <div class="section-head">
        <h2 class="section-title">Related Companies</h2>
      </div>
      <div class="markets-grid" id="cpRelated">
        {['AAPL','MSFT','GOOGL','AMZN','TSLA'].filter(s => s !== sym).slice(0,4).map(s => (
          <a href={`/company/${s.toLowerCase()}`} class="mkt-card">
            <div class="mkt-top">
              <div><div class="mkt-sym">{s}</div></div>
            </div>
            <div class="mkt-price" id={`rel-${s}`}>—</div>
          </a>
        ))}
      </div>
    </div>

  </div>

</BaseLayout>

<script define:vars={{ sym }}>
  const POLY_KEY = 'qczUHLpgL7HeJGazAePXSrcYsoAIULbC';
  const FMP_KEY  = 'phURcaq2LTL75pvNfsEL2Lf0GUG8Az2B';
  let chartInstance = null;

  // ── Load Quote + Profile (FMP) ──────────────────────────────
  async function loadQuote() {
    try {
      const [qArr, pArr] = await Promise.all([
        fetch(`https://financialmodelingprep.com/api/v3/quote/${sym}?apikey=${FMP_KEY}`).then(r => r.json()),
        fetch(`https://financialmodelingprep.com/api/v3/profile/${sym}?apikey=${FMP_KEY}`).then(r => r.json()),
      ]);
      const q = Array.isArray(qArr) ? qArr[0] : null;
      const p = Array.isArray(pArr) ? pArr[0] : null;
      if (!q) return;

      const chg   = q.change ?? 0;
      const pct   = q.changesPercentage ?? 0;
      const up    = chg >= 0;
      const color = up ? '#22c55e' : '#ef4444';

      document.getElementById('cpHero').innerHTML = `
        <div class="cp-sym">${sym}</div>
        <div class="cp-name">${q.name || sym}</div>
        <div style="font-size:12px;color:var(--text-muted);margin-top:4px">${p?.sector || ''} ${p?.industry ? '· ' + p.industry : ''}</div>
      `;

      const fmtMcap = q.marketCap >= 1e12 ? `$${(q.marketCap/1e12).toFixed(2)}T` : q.marketCap >= 1e9 ? `$${(q.marketCap/1e9).toFixed(1)}B` : '—';
      const fmtVol  = q.avgVolume ? (q.avgVolume/1e6).toFixed(1)+'M' : '—';

      document.getElementById('cpPrice').textContent  = `$${q.price?.toFixed(2) || '—'}`;
      document.getElementById('cpChange').innerHTML   = `<span style="color:${color}">${up?'+':''}${chg.toFixed(2)} (${up?'+':''}${pct.toFixed(2)}%)</span>`;
      document.getElementById('cpMcap').textContent   = fmtMcap;
      document.getElementById('cpPE').textContent     = q.pe?.toFixed(1) || '—';
      document.getElementById('cpHigh').textContent   = `$${q.yearHigh?.toFixed(2) || '—'}`;
      document.getElementById('cpLow').textContent    = `$${q.yearLow?.toFixed(2) || '—'}`;
      document.getElementById('cpVol').textContent    = fmtVol;
      const lastDiv = p?.lastDiv || 0;
      document.getElementById('cpDiv').textContent    = lastDiv > 0 ? `${((lastDiv / q.price)*100).toFixed(2)}%` : 'N/A';

      document.getElementById('cpAbout').textContent = p?.description || 'No description available.';
      if (p?.website || p?.country || p?.fullTimeEmployees) {
        document.getElementById('cpAboutMeta').innerHTML = [
          p.website ? `<a href="${p.website}" target="_blank" class="cp-meta-link">${p.website.replace('https://','')}</a>` : '',
          p.country ? `<span>${p.country}</span>` : '',
          p.fullTimeEmployees ? `<span>${Number(p.fullTimeEmployees).toLocaleString()} employees</span>` : ''
        ].filter(Boolean).join('<span class="cp-meta-sep">·</span>');
      }
    } catch {}
  }

  // ── Load Chart (Polygon aggregates) ────────────────────────
  async function loadChart(days = 30, span = 'day') {
    try {
      const to   = new Date().toISOString().split('T')[0];
      const from = new Date(Date.now() - days * 86400000).toISOString().split('T')[0];
      const r = await fetch(`https://api.polygon.io/v2/aggs/ticker/${sym}/range/1/${span}/${from}/${to}?adjusted=true&sort=asc&limit=300&apikey=${POLY_KEY}`);
      const d = await r.json();
      const bars = d.results || [];
      if (!bars.length) return;

      const closes = bars.map(b => b.c);
      const labels = bars.map(b => new Date(b.t).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }));
      const up     = closes[closes.length-1] >= closes[0];
      const color  = up ? '#22c55e' : '#ef4444';

      if (chartInstance) chartInstance.destroy();
      chartInstance = new Chart(document.getElementById('companyChart'), {
        type: 'line',
        data: { labels, datasets: [{ data: closes, borderColor: color, borderWidth: 2.5, pointRadius: 0,
          fill: true, backgroundColor: up ? 'rgba(34,197,94,0.07)' : 'rgba(239,68,68,0.07)' }] },
        options: {
          animation: false, responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => `$${ctx.parsed.y.toFixed(2)}` } } },
          scales: {
            x: { ticks: { color: '#7a8899', maxTicksLimit: 8, font: { size: 11 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
            y: { ticks: { color: '#7a8899', callback: v => `$${v}`, font: { size: 11 } }, grid: { color: 'rgba(255,255,255,0.04)' } }
          }
        }
      });
    } catch {}
  }

  // ── Load News (FMP) ─────────────────────────────────────────
  async function loadNews() {
    const list = document.getElementById('cpNewsList');
    try {
      const r = await fetch(`https://financialmodelingprep.com/api/v3/stock_news?tickers=${sym}&limit=8&apikey=${FMP_KEY}`);
      const items = await r.json();
      if (!Array.isArray(items) || !items.length) throw new Error('empty');
      list.innerHTML = items.map(item => {
        const date = new Date(item.publishedDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        return `<a href="${item.url}" class="news-item" target="_blank" rel="noopener">
          <div class="ni-title">${item.title}</div>
          <div class="ni-meta">${item.site || 'Financial News'} · ${date}</div>
        </a>`;
      }).join('');
    } catch {
      list.innerHTML = `<div class="news-item"><div class="ni-title">No recent news found for ${sym}.</div></div>`;
    }
  }

  // ── Load Related Prices (Polygon) ───────────────────────────
  async function loadRelated() {
    const related = ['AAPL','MSFT','GOOGL','AMZN','TSLA'].filter(s => s !== sym).slice(0,4);
    try {
      const r = await fetch(`https://api.polygon.io/v2/snapshot/locale/us/markets/stocks/tickers?tickers=${related.join(',')}&apikey=${POLY_KEY}`);
      const d = await r.json();
      (d.tickers || []).forEach(t => {
        const price = t.lastTrade?.p || t.day?.c || 0;
        const pct   = t.todaysChangePerc || 0;
        const up    = pct >= 0;
        const el    = document.getElementById(`rel-${t.ticker}`);
        if (el) el.innerHTML = `$${price.toFixed(2)} <span style="color:${up?'#22c55e':'#ef4444'};font-size:11px">${up?'+':''}${pct.toFixed(2)}%</span>`;
      });
    } catch {}
  }

  // ── Chart Range Buttons ─────────────────────────────────────
  document.querySelectorAll('.cpc-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cpc-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      loadChart(parseInt(btn.dataset.days), btn.dataset.span);
    });
  });

  loadQuote();
  loadChart();
  loadNews();
  loadRelated();
</script>
