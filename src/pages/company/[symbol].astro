---
import BaseLayout from '../../layouts/BaseLayout.astro';

const { symbol } = Astro.params;
// URL uses dashes for dots: reliance-ns → RELIANCE.NS
const sym = (symbol?.toUpperCase() || 'AAPL').replace(/-NS$/, '.NS').replace(/-BO$/, '.BO');
const isIndian = sym.endsWith('.NS') || sym.endsWith('.BO');
const curr = isIndian ? '₹' : '$';

export async function getStaticPaths() {
  const symbols = [
    'AAPL','MSFT','GOOGL','AMZN','TSLA','META','NVDA','JPM','GS','NFLX',
    'AMD','INTC','BRK-B','V','MA','BAC','WFC','MS','C','BLK','AXP','SCHW',
    'XOM','CVX','COP','SLB','EOG','MPC','VLO','OXY','HAL','PSX',
    'JNJ','UNH','PFE','MRK','ABBV','TMO','ABT','LLY','BMY','AMGN',
    'HD','MCD','NKE','SBUX','TGT','LOW','TJX','BKNG','CMG','F',
    'BA','CAT','GE','UPS','HON','LMT','RTX','DE','NOC','FDX',
    'CRM','ORCL','ADBE','QCOM','AVGO',
    'RELIANCE.NS','TCS.NS','HDFCBANK.NS','INFY.NS','ICICIBANK.NS',
    'WIPRO.NS','BAJFINANCE.NS','TATAMOTORS.NS','BHARTIARTL.NS','MARUTI.NS',
    'SBIN.NS','LT.NS',
    'JIOFSL.NS','NETWORK18.NS','TV18BRDCST.NS',
    'TATASTEEL.NS','TATAPOWER.NS','TITAN.NS','TATACONSUM.NS',
    'HDFCAMC.NS','HDFCLIFE.NS',
  ];
  return symbols.map(s => ({ params: { symbol: s.toLowerCase().replace(/\./g, '-') } }));
}
---
<BaseLayout title={`${sym} — Company Deep Dive`}>

  <div class="company-page">

    <!-- Header -->
    <div class="cp-header">
      <a href="/" class="cp-back">← Markets</a>
      <div class="cp-hero" id="cpHero">
        <div class="cp-sym">{sym}</div>
        <div class="cp-name-loading">Loading…</div>
      </div>
    </div>

    <!-- Price + Stats Strip -->
    <div class="cp-price-strip" id="cpPriceStrip">
      <div class="cps-item"><span class="cps-label">PRICE</span><span class="cps-val" id="cpPrice">—</span></div>
      <div class="cps-item"><span class="cps-label">CHANGE</span><span class="cps-val" id="cpChange">—</span></div>
      <div class="cps-item"><span class="cps-label">MARKET CAP</span><span class="cps-val" id="cpMcap">—</span></div>
      <div class="cps-item"><span class="cps-label">P/E RATIO</span><span class="cps-val" id="cpPE">—</span></div>
      <div class="cps-item"><span class="cps-label">52W HIGH</span><span class="cps-val" id="cpHigh">—</span></div>
      <div class="cps-item"><span class="cps-label">52W LOW</span><span class="cps-val" id="cpLow">—</span></div>
      <div class="cps-item"><span class="cps-label">AVG VOLUME</span><span class="cps-val" id="cpVol">—</span></div>
      <div class="cps-item"><span class="cps-label">DIVIDEND</span><span class="cps-val" id="cpDiv">—</span></div>
    </div>

    <!-- Chart + About -->
    <div class="cp-main">
      <div class="cp-chart-box">
        <div class="cp-chart-controls">
          <button class="cpc-btn active" data-days="30" data-span="day">1M</button>
          <button class="cpc-btn" data-days="90" data-span="day">3M</button>
          <button class="cpc-btn" data-days="180" data-span="day">6M</button>
          <button class="cpc-btn" data-days="365" data-span="day">1Y</button>
          <button class="cpc-btn" data-days="1825" data-span="week">5Y</button>
        </div>
        <div class="cp-chart-wrap">
          <canvas id="companyChart"></canvas>
        </div>
      </div>

      <div class="cp-about-box" id="cpAboutBox">
        <h3 class="cp-box-title">About</h3>
        <p class="cp-about-text" id="cpAbout">Loading company information…</p>
        <div class="cp-about-meta" id="cpAboutMeta"></div>
      </div>
    </div>

    <!-- News -->
    <div class="content-section" style="padding:0">
      <div class="section-head">
        <h2 class="section-title" id="cpNewsTitle">{sym} News</h2>
      </div>
      <div class="news-list" id="cpNewsList">
        {[1,2,3,4,5].map(() => (
          <div class="news-item">
            <div class="news-shimmer news-shimmer-title"></div>
            <div class="news-shimmer news-shimmer-meta"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Related Companies -->
    <div class="content-section" style="padding:0; margin-top:44px">
      <div class="section-head">
        <h2 class="section-title">Related Companies</h2>
      </div>
      <div class="markets-grid" id="cpRelated">
        {['AAPL','MSFT','GOOGL','AMZN','TSLA'].filter(s => s !== sym).slice(0,4).map(s => (
          <a href={`/company/${s.toLowerCase()}`} class="mkt-card">
            <div class="mkt-top">
              <div><div class="mkt-sym">{s}</div></div>
            </div>
            <div class="mkt-price" id={`rel-${s}`}>—</div>
          </a>
        ))}
      </div>
    </div>

    <!-- ── Conglomerate / Group Companies ───────────── -->
    <div id="grpSection" style="display:none; margin-top:44px">
      <div class="section-head" style="padding:0 0 4px">
        <h2 class="section-title" id="grpTitle"></h2>
      </div>
      <p class="grp-subtitle" id="grpSubtitle"></p>
      <div id="grpDivisions" class="grp-divisions"></div>
      <div id="grpListedWrap" style="display:none; margin-top:28px">
        <div class="section-head" style="padding:0 0 16px">
          <h3 style="font-size:1rem;font-weight:700;color:#fff;margin:0;letter-spacing:.3px">Listed Group Entities</h3>
        </div>
        <div class="markets-grid" id="grpStocks"></div>
      </div>
    </div>

  </div>

</BaseLayout>

<script define:vars={{ sym, curr, isIndian }}>
  const P = 'https://corsproxy.io/?';
  let chartInstance = null;

  const rangeMap = { 30: ['1mo','1d'], 90: ['3mo','1d'], 180: ['6mo','1wk'], 365: ['1y','1wk'], 1825: ['5y','1mo'] };

  async function yf(fields) {
    const url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${sym}&fields=${fields}`;
    const r = await fetch(P + encodeURIComponent(url));
    const w = await r.json();
    return w?.quoteResponse?.result?.[0] || null;
  }

  async function yfChart(range, interval) {
    const url = `https://query1.finance.yahoo.com/v8/finance/chart/${sym}?range=${range}&interval=${interval}`;
    const r = await fetch(P + encodeURIComponent(url));
    const w = await r.json();
    return w?.chart?.result?.[0] || null;
  }

  async function loadQuote() {
    const q = await yf('symbol,shortName,longName,regularMarketPrice,regularMarketChange,regularMarketChangePercent,marketCap,trailingPE,fiftyTwoWeekHigh,fiftyTwoWeekLow,averageVolume,dividendYield,longBusinessSummary,sector,industry,website,country,fullTimeEmployees');
    if (!q) return;
    const chg = q.regularMarketChange ?? 0;
    const pct = q.regularMarketChangePercent ?? 0;
    const up  = chg >= 0;
    const color = up ? '#22c55e' : '#ef4444';

    document.getElementById('cpHero').innerHTML = `
      <div class="cp-sym">${sym}</div>
      <div class="cp-name">${q.longName || q.shortName || sym}</div>
      <div style="font-size:12px;color:var(--text-muted);margin-top:4px">${q.sector || ''} ${q.industry ? '· ' + q.industry : ''}</div>
    `;
    const fmtMcap = q.marketCap >= 1e12 ? `$${(q.marketCap/1e12).toFixed(2)}T` : q.marketCap >= 1e9 ? `$${(q.marketCap/1e9).toFixed(1)}B` : '—';
    document.getElementById('cpPrice').textContent  = `${curr}${q.regularMarketPrice?.toLocaleString(undefined,{maximumFractionDigits:2}) || '—'}`;
    document.getElementById('cpChange').innerHTML   = `<span style="color:${color}">${up?'+':''}${chg.toFixed(2)} (${up?'+':''}${pct.toFixed(2)}%)</span>`;
    document.getElementById('cpMcap').textContent   = fmtMcap;
    document.getElementById('cpPE').textContent     = q.trailingPE?.toFixed(1) || '—';
    document.getElementById('cpHigh').textContent   = `${curr}${q.fiftyTwoWeekHigh?.toFixed(2) || '—'}`;
    document.getElementById('cpLow').textContent    = `${curr}${q.fiftyTwoWeekLow?.toFixed(2) || '—'}`;
    document.getElementById('cpVol').textContent    = q.averageVolume ? (q.averageVolume/1e6).toFixed(1)+'M' : '—';
    document.getElementById('cpDiv').textContent    = q.dividendYield ? `${(q.dividendYield*100).toFixed(2)}%` : 'N/A';
    // show Yahoo summary immediately, then enrich with Wikipedia
    const yahooBio = q.longBusinessSummary || '';
    document.getElementById('cpAbout').textContent = yahooBio || 'Loading description…';

    if (q.website || q.country || q.fullTimeEmployees) {
      document.getElementById('cpAboutMeta').innerHTML = [
        q.website ? `<a href="${q.website}" target="_blank" class="cp-meta-link">${q.website.replace('https://','')}</a>` : '',
        q.country ? `<span>${q.country}</span>` : '',
        q.fullTimeEmployees ? `<span>${Number(q.fullTimeEmployees).toLocaleString()} employees</span>` : ''
      ].filter(Boolean).join('<span class="cp-meta-sep">·</span>');
    }

    // enrich with Wikipedia description
    fetchWikipedia(q.longName || q.shortName || sym, yahooBio);
  }

  async function fetchWikipedia(companyName, fallback) {
    try {
      // try exact name first, then simplified
      const attempts = [
        companyName,
        companyName.replace(/,?\s*(Inc\.?|Corp\.?|Ltd\.?|plc|Limited|Group|Holdings?|Technologies?|Platforms?|Industries?)\.?$/i, '').trim(),
      ];
      for (const name of attempts) {
        const url = `https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(name)}`;
        const r = await fetch(url);
        if (!r.ok) continue;
        const d = await r.json();
        if (d.extract && d.extract.length > 80 && d.type !== 'disambiguation') {
          document.getElementById('cpAbout').textContent = d.extract;
          // add wikipedia link
          const meta = document.getElementById('cpAboutMeta');
          if (meta && d.content_urls?.desktop?.page) {
            const existing = meta.innerHTML;
            const wikLink = `<a href="${d.content_urls.desktop.page}" target="_blank" class="cp-meta-link">Wikipedia →</a>`;
            meta.innerHTML = existing ? existing + '<span class="cp-meta-sep">·</span>' + wikLink : wikLink;
          }
          return;
        }
      }
      // fallback to Yahoo summary if Wikipedia didn't work
      if (fallback) document.getElementById('cpAbout').textContent = fallback;
      else document.getElementById('cpAbout').textContent = 'No description available.';
    } catch {
      if (fallback) document.getElementById('cpAbout').textContent = fallback;
    }
  }

  async function loadChart(days = 30) {
    const [range, interval] = rangeMap[days] || ['1mo','1d'];
    const cd = await yfChart(range, interval);
    const closes    = cd?.indicators?.quote?.[0]?.close?.filter(Boolean) || [];
    const timestamps = cd?.timestamp || [];
    if (!closes.length) return;
    const up    = closes[closes.length-1] >= closes[0];
    const color = up ? '#22c55e' : '#ef4444';
    const labels = timestamps.map(t => new Date(t*1000).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }));
    if (chartInstance) chartInstance.destroy();
    chartInstance = new Chart(document.getElementById('companyChart'), {
      type: 'line',
      data: { labels, datasets: [{ data: closes, borderColor: color, borderWidth: 2.5, pointRadius: 0,
        fill: true, backgroundColor: up ? 'rgba(34,197,94,0.07)' : 'rgba(239,68,68,0.07)' }] },
      options: { animation: false, responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => `${curr}${ctx.parsed.y.toFixed(2)}` } } },
        scales: {
          x: { ticks: { color: '#7a8899', maxTicksLimit: 8, font: { size: 11 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
          y: { ticks: { color: '#7a8899', callback: v => `${curr}${v}`, font: { size: 11 } }, grid: { color: 'rgba(255,255,255,0.04)' } }
        } }
    });
  }

  async function loadNews() {
    const list = document.getElementById('cpNewsList');
    try {
      const rss = `https://feeds.finance.yahoo.com/rss/2.0/headline?s=${sym}&region=US&lang=en-US`;
      const r = await fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(rss)}&count=8`);
      const d = await r.json();
      const items = d?.items || [];
      if (!items.length) throw new Error('empty');
      list.innerHTML = items.map(item => {
        const date = new Date(item.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        return `<a href="${item.link}" class="news-item" target="_blank" rel="noopener">
          <div class="ni-title">${item.title}</div>
          <div class="ni-meta">${item.author || 'Yahoo Finance'} · ${date}</div>
        </a>`;
      }).join('');
    } catch {
      list.innerHTML = `<div class="news-item"><div class="ni-title">No recent news found for ${sym}.</div></div>`;
    }
  }

  async function loadRelated() {
    const related = ['AAPL','MSFT','GOOGL','AMZN','TSLA'].filter(s => s !== sym).slice(0,4);
    for (const s of related) {
      try {
        const url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${s}&fields=regularMarketPrice,regularMarketChangePercent`;
        const r = await fetch(P + encodeURIComponent(url));
        const w = await r.json();
        const q = w?.quoteResponse?.result?.[0];
        if (q) {
          const pct = q.regularMarketChangePercent ?? 0;
          const up  = pct >= 0;
          const el  = document.getElementById(`rel-${s}`);
          if (el) el.innerHTML = `$${q.regularMarketPrice?.toFixed(2)} <span style="color:${up?'#22c55e':'#ef4444'};font-size:11px">${up?'+':''}${pct.toFixed(2)}%</span>`;
        }
      } catch {}
    }
  }

  document.querySelectorAll('.cpc-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cpc-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      loadChart(parseInt(btn.dataset.days));
    });
  });

  // ── Conglomerate / Group Data ────────────────────────
  const CONGLOMERATES = {
    'RELIANCE.NS': {
      groupName: 'Reliance Industries Group',
      subtitle: 'India\'s largest conglomerate — energy, retail, telecom, media & finance under one umbrella.',
      divisions: [
        { name: 'Reliance Retail', icon: '🛒', tag: 'Consumer', stat: '18,800+ stores', desc: 'India\'s largest retailer. Operates Reliance Digital (electronics), Reliance Trends (fashion), Smart Bazaar, Reliance Fresh, and JioMart (e-commerce). Revenue ~₹3.3L Cr annually.' },
        { name: 'Reliance Jio', icon: '📱', tag: 'Telecom', stat: '480M+ subscribers', desc: 'India\'s largest 5G telecom network. Also runs JioFiber broadband, JioAirFiber, and Jio Platforms — backed by Google, Meta, KKR and others. Dominant in every circle.' },
        { name: 'O2C (Oil-to-Chemicals)', icon: '🏭', tag: 'Energy', stat: '~₹5.3L Cr revenue', desc: 'World\'s largest integrated refinery complex at Jamnagar, Gujarat. Produces fuels, petrochemicals, polyester, and specialty chemicals. Exports to 100+ countries.' },
        { name: 'New Energy', icon: '☀️', tag: 'Green', stat: '₹75,000 Cr capex', desc: 'Major push into solar, green hydrogen, and battery storage. Building the Dhirubhai Ambani Green Energy Giga Complex in Jamnagar — one of the world\'s largest renewable energy parks.' },
        { name: 'Media & Entertainment', icon: '📺', tag: 'Media', stat: 'Network18 + JioCinema', desc: 'Controls Network18, TV18, CNBC-TV18, CNN-News18. JioCinema streams IPL, FIFA World Cup, Hollywood & Bollywood. Merger with Disney Star India in progress.' },
      ],
      listed: [
        { sym: 'JIOFSL.NS', name: 'Jio Financial Services' },
        { sym: 'NETWORK18.NS', name: 'Network18 Media' },
        { sym: 'TV18BRDCST.NS', name: 'TV18 Broadcast' },
      ],
    },
    'TATAMOTORS.NS': {
      groupName: 'Tata Group',
      subtitle: 'India\'s oldest and most diversified conglomerate — operating in 100+ countries across 30+ industries.',
      divisions: [
        { name: 'Jaguar Land Rover', icon: '🚗', tag: 'Luxury Auto', stat: '£21B revenue', desc: 'UK-based premium automotive brand fully owned by Tata Motors. Produces Defender, Discovery, Range Rover, and Jaguar models. Strong recovery post-COVID with EV pivot.' },
        { name: 'Tata EV', icon: '⚡', tag: 'Electric', stat: '#1 EV in India', desc: 'India\'s EV market leader. Nexon EV, Tiago EV, Punch EV, Harrier EV. Plans a dedicated gigafactory and 10 new EV models by 2026. Commands 50%+ of India\'s EV market.' },
        { name: 'Air India', icon: '✈️', tag: 'Aviation', stat: 'Re-acquired 2022', desc: 'India\'s national carrier taken back by Tata Group in Jan 2022. Undergoing a $400M transformation — new livery, fleet expansion, Vistara merger, improved service.' },
        { name: 'Tata Electronics', icon: '📱', tag: 'Manufacturing', stat: 'iPhone assembler', desc: 'Assembles iPhones for Apple in India — Wistron acquisition 2021. Also entering semiconductor manufacturing via a $11B Fab in Gujarat.' },
      ],
      listed: [
        { sym: 'TCS.NS', name: 'Tata Consultancy Services' },
        { sym: 'TATASTEEL.NS', name: 'Tata Steel' },
        { sym: 'TATAPOWER.NS', name: 'Tata Power' },
        { sym: 'TITAN.NS', name: 'Titan Company' },
        { sym: 'TATACONSUM.NS', name: 'Tata Consumer Products' },
      ],
    },
    'TCS.NS': {
      groupName: 'Tata Group',
      subtitle: 'TCS is the tech flagship of the Tata Group — one of India\'s most trusted and diversified conglomerates.',
      divisions: [
        { name: 'TCS BaNCS', icon: '🏦', tag: 'FinTech', stat: '450+ global clients', desc: 'World\'s leading banking & financial services software suite, deployed at 450+ financial institutions across 80+ countries. Processes trillions in transactions daily.' },
        { name: 'Ignio (AI)', icon: '🤖', tag: 'AI/ML', stat: '200M events/day', desc: 'Cognitive automation platform powered by AI. Handles 200M+ events daily for enterprise IT. Competing with ServiceNow and BMC in the AIOps space.' },
        { name: 'TCS iON', icon: '🎓', tag: 'EdTech', stat: '10M exam seats/yr', desc: 'Assessment & digital learning platform. Runs over 10 million exam seats annually for government bodies and large corporates.' },
        { name: 'Quartz (Blockchain)', icon: '⛓️', tag: 'Blockchain', stat: 'Enterprise grade', desc: 'Enterprise blockchain-as-a-service platform for supply chain, trade finance, and digital identity across banking and government sectors.' },
      ],
      listed: [
        { sym: 'TATAMOTORS.NS', name: 'Tata Motors' },
        { sym: 'TATASTEEL.NS', name: 'Tata Steel' },
        { sym: 'TATAPOWER.NS', name: 'Tata Power' },
        { sym: 'TITAN.NS', name: 'Titan' },
      ],
    },
    'HDFCBANK.NS': {
      groupName: 'HDFC Group',
      subtitle: 'India\'s largest private sector bank by assets, now merged with HDFC Ltd. A full-stack financial services powerhouse.',
      divisions: [
        { name: 'HDFC Securities', icon: '📈', tag: 'Broking', stat: '3.5M+ clients', desc: 'Full-service brokerage for equity, derivatives, currency, and mutual funds. One of India\'s largest retail broking platforms, integrated with HDFC Bank accounts.' },
        { name: 'HDB Financial Services', icon: '💳', tag: 'NBFC', stat: 'IPO planned', desc: 'Non-banking financial company providing personal loans, business loans, and BPO services. AUM of ₹95,000+ Cr. Highly anticipated IPO in pipeline.' },
        { name: 'HDFC Credila', icon: '🎓', tag: 'Education Finance', stat: 'India\'s largest', desc: 'India\'s largest education loan company. Finances students at IITs, IIMs, and 400+ universities abroad. Partially divested to BPEA EQT.' },
        { name: 'HDFC Bank (Banking)', icon: '🏦', tag: 'Banking', stat: '₹25L Cr+ deposits', desc: 'Core banking arm with 8,700+ branches and 20,000+ ATMs. Largest by market cap among Indian private banks. Net NPA consistently below 0.4%.' },
      ],
      listed: [
        { sym: 'HDFCAMC.NS', name: 'HDFC AMC' },
        { sym: 'HDFCLIFE.NS', name: 'HDFC Life Insurance' },
      ],
    },
    'INFY.NS': {
      groupName: 'Infosys Ecosystem',
      subtitle: 'Infosys is India\'s second-largest IT firm and a global leader in digital transformation, cloud, and AI services.',
      divisions: [
        { name: 'Infosys BPM', icon: '⚙️', tag: 'BPO', stat: '50,000+ employees', desc: 'Business process management arm handling back-office, finance, accounting, and customer service for global enterprises across 50+ countries.' },
        { name: 'EdgeVerve (Finacle)', icon: '🏦', tag: 'Banking SaaS', stat: '1B+ bank customers', desc: 'Finacle is the world\'s top core banking platform, used by 1 billion+ retail customers globally at 100+ banks. EdgeVerve also builds AI assistants for enterprises.' },
        { name: 'Infosys Cobalt', icon: '☁️', tag: 'Cloud', stat: '200+ cloud clients', desc: 'Cloud-first services suite covering migration, native development, and SaaS integration across AWS, Azure, and GCP for Fortune 500 companies.' },
        { name: 'Topaz (AI)', icon: '🤖', tag: 'Generative AI', stat: '300+ use cases', desc: 'AI-first platform launched 2023. Offers 300+ AI use cases, LLM fine-tuning, and responsible AI frameworks. Competes with Accenture AI and IBM watsonx.' },
      ],
      listed: [],
    },
    'BHARTIARTL.NS': {
      groupName: 'Bharti Enterprises Group',
      subtitle: 'Sunil Mittal\'s Bharti Group spans telecom, agri, real estate, financial services, and defence manufacturing.',
      divisions: [
        { name: 'Airtel Africa', icon: '🌍', tag: 'Africa Telecom', stat: '150M+ subscribers', desc: 'Listed separately in London. Airtel Africa operates mobile and money services across 14 countries. One of the fastest growing telcos on the continent.' },
        { name: 'Airtel Payments Bank', icon: '💸', tag: 'FinTech', stat: '500M+ transactions', desc: 'India\'s largest payments bank by transaction volume. Provides savings accounts, UPI, insurance, and credit products to rural and semi-urban India.' },
        { name: 'Nxtra (Data Centers)', icon: '🖥️', tag: 'Data Centers', stat: '12 data centers', desc: 'Airtel\'s data center business, operating 12 hyperscale and edge facilities across India. Expanding rapidly to serve cloud computing and enterprise needs.' },
        { name: 'Bharti Defence', icon: '🛡️', tag: 'Defence', stat: 'Make in India', desc: 'JV with Elbit Systems for defence electronics and avionics. Part of India\'s Make in India push for indigenous military technology manufacturing.' },
      ],
      listed: [],
    },
  };

  async function loadGroupSection() {
    const g = CONGLOMERATES[sym];
    if (!g) return;

    const section = document.getElementById('grpSection');
    if (!section) return;
    section.style.display = 'block';
    document.getElementById('grpTitle').textContent = g.groupName;
    document.getElementById('grpSubtitle').textContent = g.subtitle || '';

    // Render business division cards
    document.getElementById('grpDivisions').innerHTML = g.divisions.map(d => `
      <div class="grp-div-card">
        <div class="grp-div-top">
          <span class="grp-div-icon">${d.icon}</span>
          <div style="flex:1;min-width:0">
            <div class="grp-div-name">${d.name}</div>
            <span class="grp-div-tag">${d.tag}</span>
          </div>
          <div class="grp-div-stat">${d.stat || ''}</div>
        </div>
        <p class="grp-div-desc">${d.desc}</p>
      </div>
    `).join('');

    // Render + fetch prices for listed group stocks
    if (g.listed && g.listed.length) {
      document.getElementById('grpListedWrap').style.display = 'block';
      document.getElementById('grpStocks').innerHTML = g.listed.map(s => `
        <a href="/company/${s.sym.toLowerCase().replace(/\./g,'-')}" class="mkt-card">
          <div class="mkt-top">
            <div>
              <div class="mkt-sym">${s.sym.replace(/\.(NS|BO)$/,'')}</div>
              <div class="mkt-name">${s.name}</div>
            </div>
            <div class="mkt-badge" id="grpb-${s.sym}">—</div>
          </div>
          <div class="mkt-price" id="grpp-${s.sym}">—</div>
          <div class="mkt-chg"   id="grpc-${s.sym}">—</div>
        </a>
      `).join('');

      try {
        const url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${g.listed.map(s=>s.sym).join(',')}&fields=symbol,regularMarketPrice,regularMarketChange,regularMarketChangePercent`;
        const r = await fetch(P + encodeURIComponent(url));
        const quotes = (await r.json())?.quoteResponse?.result || [];
        quotes.forEach(q => {
          const chg = q.regularMarketChange ?? 0;
          const pct = q.regularMarketChangePercent ?? 0;
          const up  = chg >= 0;
          const color = up ? '#22c55e' : '#ef4444';
          const c = (q.symbol.endsWith('.NS')||q.symbol.endsWith('.BO')) ? '₹' : '$';
          const pEl = document.getElementById(`grpp-${q.symbol}`);
          const bEl = document.getElementById(`grpb-${q.symbol}`);
          const cEl = document.getElementById(`grpc-${q.symbol}`);
          if (pEl) pEl.textContent = `${c}${q.regularMarketPrice?.toLocaleString(undefined,{maximumFractionDigits:2})}`;
          if (bEl) { bEl.textContent = `${up?'+':''}${pct.toFixed(2)}%`; bEl.classList.add(up?'badge-up':'badge-dn'); }
          if (cEl) { cEl.textContent = `${up?'▲':'▼'} ${c}${Math.abs(chg).toFixed(2)}`; cEl.style.color = color; }
        });
      } catch {}
    }
  }

  loadQuote();
  loadChart();
  loadNews();
  loadRelated();
  loadGroupSection();
</script>

