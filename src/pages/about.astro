---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About BullSignal">

<div class="ab-wrap">

  <!-- ── Hero ─────────────────────────────────────────── -->
  <div class="ab-hero">
    <div class="ab-hero-badge">INDIA MARKET INTELLIGENCE</div>
    <h1 class="ab-hero-title">Built for investors<br/>who want the full picture.</h1>
    <p class="ab-hero-sub">
      BullSignal covers NSE, BSE, and India macro — with the global context that actually moves our markets.
      Real data, plain language, twice daily.
    </p>
    <div class="ab-hero-stats">
      <div class="ab-stat"><span class="ab-stat-num">2×</span><span class="ab-stat-lbl">daily updates</span></div>
      <div class="ab-stat-div"></div>
      <div class="ab-stat"><span class="ab-stat-num">50+</span><span class="ab-stat-lbl">NSE stocks tracked</span></div>
      <div class="ab-stat-div"></div>
      <div class="ab-stat"><span class="ab-stat-num">100%</span><span class="ab-stat-lbl">India-first</span></div>
    </div>
  </div>

  <!-- ── What's inside ─────────────────────────────────── -->
  <div class="ab-section">
    <div class="ab-section-label">WHAT YOU GET</div>
    <div class="ab-features">

      <div class="ab-feat ab-feat--wide">
        <div class="ab-feat-icon">📊</div>
        <div>
          <div class="ab-feat-title">Market Data</div>
          <div class="ab-feat-desc">NSE & BSE prices, Nifty 50, Sensex, sector heatmaps, and 52-week position bars — refreshed automatically at 4 PM and 2 AM IST.</div>
        </div>
      </div>

      <div class="ab-feat ab-feat--wide">
        <div class="ab-feat-icon">🏛️</div>
        <div>
          <div class="ab-feat-title">India Economic Calendar</div>
          <div class="ab-feat-desc">RBI policy dates, CPI & WPI releases, GDP announcements, F&O expiries — every macro event that moves Indian markets, explained in plain English.</div>
        </div>
      </div>

      <div class="ab-feat">
        <div class="ab-feat-icon">📅</div>
        <div>
          <div class="ab-feat-title">Earnings Calendar</div>
          <div class="ab-feat-desc">Upcoming results from major NSE companies, organised by quarter.</div>
        </div>
      </div>

      <div class="ab-feat">
        <div class="ab-feat-icon">🚀</div>
        <div>
          <div class="ab-feat-title">IPO Tracker</div>
          <div class="ab-feat-desc">Open, upcoming, and recently listed IPOs — with allotment timelines and a plain-English guide for first-timers.</div>
        </div>
      </div>

      <div class="ab-feat">
        <div class="ab-feat-icon">📈</div>
        <div>
          <div class="ab-feat-title">Day-over-Day Compare</div>
          <div class="ab-feat-desc">See which stocks flipped sentiment overnight, with charts and a sortable table.</div>
        </div>
      </div>

      <div class="ab-feat">
        <div class="ab-feat-icon">🌍</div>
        <div>
          <div class="ab-feat-title">Global Context</div>
          <div class="ab-feat-desc">Fed decisions, US earnings, and commodity moves — because India doesn't trade in a vacuum.</div>
        </div>
      </div>

    </div>
  </div>

  <!-- ── Author ─────────────────────────────────────────── -->
  <div class="ab-section">
    <div class="ab-section-label">THE PERSON BEHIND IT</div>
    <div class="ab-author">
      <div class="ab-author-avatar">AG</div>
      <div class="ab-author-body">
        <div class="ab-author-name">Apurva Gupta</div>
        <div class="ab-author-role">Product &amp; Business · Bangalore, India</div>
        <p class="ab-author-bio">
          I built BullSignal because I was tired of switching between five tabs just to understand
          what happened in the market today and why. The goal was simple: one clean dashboard,
          India-first, that explains the story behind the numbers — not just the numbers themselves.
        </p>
        <div class="ab-author-links">
          <a href="mailto:apurvagupta1991@gmail.com" class="ab-link">✉️ Email</a>
          <a href="https://x.com/Apurvagupta1991" target="_blank" rel="noopener" class="ab-link">𝕏 Twitter</a>
          <a href="https://www.linkedin.com/in/apurva-gupta-6632b7219/" target="_blank" rel="noopener" class="ab-link">🔗 LinkedIn</a>
          <a href="https://theapurva.com/" target="_blank" rel="noopener" class="ab-link">🌐 theapurva.com</a>
        </div>
      </div>
    </div>
  </div>


</div>

</BaseLayout>

<style is:global>
.ab-wrap {
  max-width:820px; margin:48px auto 80px; padding:0 20px;
}

/* Hero */
.ab-hero {
  text-align:center; padding:60px 20px 52px; margin-bottom:16px;
}
.ab-hero-badge {
  display:inline-block; font-size:10px; font-weight:800; letter-spacing:2px;
  color:var(--gold); border:1px solid rgba(212,169,64,0.3);
  padding:5px 14px; border-radius:20px; margin-bottom:24px;
  background:rgba(212,169,64,0.08);
}
.ab-hero-title {
  font-size:clamp(32px,5vw,52px); font-weight:800; color:#fff;
  line-height:1.15; margin-bottom:20px; letter-spacing:-0.5px;
}
.ab-hero-sub {
  font-size:16px; color:var(--text-muted); line-height:1.75;
  max-width:560px; margin:0 auto 36px;
}
.ab-hero-stats {
  display:flex; justify-content:center; align-items:center;
  gap:0; flex-wrap:wrap;
}
.ab-stat {
  display:flex; flex-direction:column; align-items:center; padding:0 28px;
}
.ab-stat-num {
  font-size:28px; font-weight:800; color:var(--gold); line-height:1;
}
.ab-stat-lbl {
  font-size:11px; color:var(--text-muted); margin-top:4px; font-weight:500;
}
.ab-stat-div {
  width:1px; height:36px; background:rgba(255,255,255,0.1);
}

/* Section wrapper */
.ab-section { margin-bottom:48px; }
.ab-section-label {
  font-size:10px; font-weight:800; letter-spacing:2px;
  color:var(--gold); margin-bottom:20px;
  padding-bottom:10px; border-bottom:1px solid rgba(212,169,64,0.15);
}

/* Feature grid */
.ab-features {
  display:grid; grid-template-columns:1fr 1fr; gap:12px;
}
.ab-feat--wide { grid-column:1 / -1; }
.ab-feat {
  background:linear-gradient(135deg, rgba(212,169,64,0.12) 0%, rgba(184,134,11,0.06) 100%); border:1px solid rgba(212,169,64,0.25);
  border-radius:12px; padding:20px 22px;
  display:flex; gap:16px; align-items:flex-start;
  transition:border-color 0.2s;
}
.ab-feat:hover { border-color:rgba(212,169,64,0.3); }
.ab-feat-icon {
  font-size:22px; flex-shrink:0; margin-top:2px;
}
.ab-feat-title {
  font-size:14px; font-weight:700; color:#fff; margin-bottom:5px;
}
.ab-feat-desc {
  font-size:12px; color:var(--text-muted); line-height:1.7;
}

/* Author */
.ab-author {
  background:linear-gradient(135deg, rgba(212,169,64,0.12) 0%, rgba(184,134,11,0.06) 100%); border:1px solid rgba(212,169,64,0.25);
  border-radius:14px; padding:28px 30px;
  display:flex; gap:24px; align-items:flex-start;
}
.ab-author-avatar {
  width:60px; height:60px; border-radius:50%; flex-shrink:0;
  background:rgba(212,169,64,0.12); border:2px solid rgba(212,169,64,0.35);
  display:flex; align-items:center; justify-content:center;
  font-size:16px; font-weight:800; color:var(--gold); letter-spacing:0.5px;
}
.ab-author-name {
  font-size:17px; font-weight:800; color:#fff; margin-bottom:3px;
}
.ab-author-role {
  font-size:11px; color:var(--gold); font-weight:600;
  letter-spacing:0.5px; margin-bottom:14px;
}
.ab-author-bio {
  font-size:13px; color:var(--text-muted); line-height:1.8;
  margin:0 0 10px;
}
.ab-author-links {
  display:flex; flex-wrap:wrap; gap:8px; margin-top:16px;
}
.ab-link {
  font-size:11px; font-weight:600; color:var(--text-muted);
  text-decoration:none; background:rgba(255,255,255,0.05);
  border:1px solid var(--border); padding:6px 14px;
  border-radius:20px; transition:all 0.2s;
}
.ab-link:hover {
  background:rgba(212,169,64,0.1); border-color:rgba(212,169,64,0.4);
  color:var(--gold);
}

/* Philosophy pillars */
.ab-pillars {
  display:grid; grid-template-columns:repeat(3,1fr); gap:12px;
}
.ab-pillar {
  background:linear-gradient(135deg, rgba(212,169,64,0.12) 0%, rgba(184,134,11,0.06) 100%); border:1px solid rgba(212,169,64,0.25);
  border-radius:12px; padding:24px 22px;
  border-top:2px solid var(--gold);
}
.ab-pillar-num {
  font-size:28px; font-weight:800; color:rgba(212,169,64,0.2);
  line-height:1; margin-bottom:10px;
}
.ab-pillar-title {
  font-size:14px; font-weight:700; color:#fff; margin-bottom:8px;
}
.ab-pillar-desc {
  font-size:12px; color:var(--text-muted); line-height:1.7;
}

@media (max-width:640px) {
  .ab-features { grid-template-columns:1fr; }
  .ab-feat--wide { grid-column:auto; }
  .ab-pillars { grid-template-columns:1fr; }
  .ab-author { flex-direction:column; }
  .ab-hero-title { font-size:28px; }
  .ab-stat { padding:0 16px; }
}
</style>
