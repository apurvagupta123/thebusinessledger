---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | The Business Ledger</title>
    <meta name="description" content="Track markets, discover company insights, and stay ahead with curated financial news — all in one place." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Open Graph / Social Sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Business Ledger" />
    <meta property="og:title" content={`${title} | The Business Ledger`} />
    <meta property="og:description" content="Track markets, discover company insights, and stay ahead with curated financial news — all in one place." />
    <meta property="og:image" content="https://thebusinessledger.theapurva.com/og-image.png" />
    <meta property="og:url" content="https://thebusinessledger.theapurva.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | The Business Ledger`} />
    <meta name="twitter:description" content="Track markets, discover company insights, and stay ahead with curated financial news." />
    <meta name="twitter:image" content="https://thebusinessledger.theapurva.com/og-image.png" />
    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>

    <!-- ── Ticker Bar ───────────────────────────── -->
    <div class="ticker-bar">
      <div class="ticker-track" id="tickerTrack">
        <span class="ticker-placeholder">Loading market data…</span>
      </div>
    </div>

    <!-- ── Navigation ──────────────────────────── -->
    <nav class="site-nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">
          <div class="nav-logo-box">BL</div>
          <div class="nav-brand-text">
            <span class="nav-brand-name">The Business Ledger</span>
            <span class="nav-brand-sub">BUSINESS INTELLIGENCE</span>
          </div>
        </a>
        <div class="nav-links">
          <a href="/" class="nav-link active">Home</a>
          <a href="/markets/tech" class="nav-link">Markets</a>
          <a href="/earnings-calendar" class="nav-link">Earnings</a>
          <a href="/economic-calendar" class="nav-link">Economy</a>
          <a href="/ipo-tracker" class="nav-link">IPOs</a>
          <a href="/tools" class="nav-link">Tools</a>
          <a href="/about" class="nav-link">About</a>
        </div>
        <div class="nav-search">
          <span class="nav-search-icon">🔍</span>
          <input type="text" class="nav-search-input" placeholder="Search companies, news…" />
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <div class="nav-logo-box">BL</div>
            <div class="nav-brand-text">
              <span class="nav-brand-name">The Business Ledger</span>
              <span class="nav-brand-sub">BUSINESS INTELLIGENCE</span>
            </div>
          </div>
          <p class="footer-desc">Track markets, discover company insights, and stay ahead with curated financial news — all in one place.</p>
        </div>
        <div class="footer-bottom">
          <p class="footer-copy">&copy; {new Date().getFullYear()} The Business Ledger. Market data for informational purposes only.</p>
          <div class="footer-links">
            <a href="/">Home</a>
            <a href="/about">About</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // ── Ticker ────────────────────────────────────────────────────────
      const TICKER_SYMS = ['NVDA','META','TSLA','JPM','AAPL','MSFT','GOOGL','AMZN','SPY','QQQ','GS','NFLX','AMD','INTC','BRK.B'];
      const POLY_KEY = 'qczUHLpgL7HeJGazAePXSrcYsoAIULbC';

      async function loadTicker() {
        const track = document.getElementById('tickerTrack');
        if (!track) return;
        try {
          const r = await fetch(`https://api.polygon.io/v2/snapshot/locale/us/markets/stocks/tickers?tickers=${TICKER_SYMS.join(',')}&apikey=${POLY_KEY}`);
          const d = await r.json();
          const quotes = d.tickers || [];
          if (!quotes.length) throw new Error('empty');

          const html = quotes.map(q => {
            const price = q.lastTrade?.p || q.day?.c || q.prevDay?.c || 0;
            const chg   = q.todaysChange || 0;
            const pct   = q.todaysChangePerc || 0;
            const up    = chg >= 0;
            const cls   = up ? 'up' : 'dn';
            return `<span class="ti ${cls}"><strong>${q.ticker}</strong> $${price.toFixed(2)} <em>${up?'▲':'▼'} ${Math.abs(pct).toFixed(2)}%</em></span>`;
          }).join('<span class="ti-sep">·</span>');

          track.innerHTML = html + '<span class="ti-sep" style="padding:0 20px"> </span>' + html;
        } catch {
          track.innerHTML = TICKER_SYMS.map(s => `<span class="ti"><strong>${s}</strong> —</span>`).join('');
        }
      }

      loadTicker();
      setInterval(loadTicker, 60000);
    </script>
  </body>
</html>
