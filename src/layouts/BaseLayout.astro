---
const { title } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | BullSignal</title>
    <meta name="description" content="NSE & BSE data updated twice daily, trending stocks, and investor-focused insights — all in one clean dashboard." />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <!-- Open Graph / Social Sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BullSignal" />
    <meta property="og:title" content={`${title} | BullSignal`} />
    <meta property="og:description" content="NSE & BSE data updated twice daily, trending stocks, and investor-focused insights — all in one clean dashboard." />
    <meta property="og:image" content="https://thebusinessledger.theapurva.com/og-image.png" />
    <meta property="og:url" content="https://thebusinessledger.theapurva.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | BullSignal`} />
    <meta name="twitter:description" content="NSE & BSE data updated twice daily, trending stocks, and investor-focused insights — all in one clean dashboard." />
    <meta name="twitter:image" content="https://thebusinessledger.theapurva.com/og-image.png" />
    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="/styles/global.css" />
    <style is:global>
      /* Ticker positioning — inline to avoid CDN cache delay */
      .news-bar {
        top: 0 !important;
        z-index: 999 !important;
        background: #060414 !important;
        border-bottom: 1px solid rgba(212,169,64,0.12) !important;
      }
      .ticker-bar:not(.news-bar) {
        top: 36px !important;
        z-index: 998 !important;
      }
      body { padding-top: 128px !important; }
      .site-nav { top: 72px !important; }
      body { background: #07061a !important; }
      body::before { display: none !important; }
      /* News ticker text — cyan to match new accent */
      .news-bar .ti { color: #d4a940 !important; }
      .news-bar .ti strong { color: #fde68a !important; }
      .news-bar .ti-sep { color: rgba(212,169,64,0.3) !important; }
    </style>
  </head>
  <body>

    <!-- ── News Ticker Bar ──────────────────────── -->
    <div class="ticker-bar news-bar">
      <div class="ticker-track" id="newsTickerTrack">
        <span class="ticker-placeholder">Loading headlines…</span>
      </div>
    </div>

    <!-- ── Market Ticker Bar ───────────────────── -->
    <div class="ticker-bar">
      <div class="ticker-track" id="tickerTrack">
        <span class="ticker-placeholder">Loading market data…</span>
      </div>
    </div>

    <!-- ── Navigation ──────────────────────────── -->
    <nav class="site-nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">
          <div class="nav-logo-box"><img src="/logo.svg" alt="BullSignal" style="width:100%;height:100%;object-fit:contain;display:block;border-radius:7px;" /></div>
          <div class="nav-brand-text">
            <span class="nav-brand-name">BullSignal</span>
            <span class="nav-brand-sub">MARKET INTELLIGENCE</span>
          </div>
        </a>
        <div class="nav-links">
          <a href="/" class={`nav-link${path === '/' ? ' active' : ''}`}>Home</a>
          <a href="/markets" class={`nav-link${path.startsWith('/markets') ? ' active' : ''}`}>Markets</a>
          <a href="/news" class={`nav-link${path.startsWith('/news') ? ' active' : ''}`}>News</a>
          <a href="/comparison" class={`nav-link${path.startsWith('/comparison') ? ' active' : ''}`}>Compare</a>
          <a href="/economic-calendar" class={`nav-link${path.startsWith('/economic') ? ' active' : ''}`}>Economy</a>
          <a href="/tools" class={`nav-link${path.startsWith('/tools') ? ' active' : ''}`}>Tools</a>
          <a href="/about" class={`nav-link${path.startsWith('/about') ? ' active' : ''}`}>About</a>
        </div>
        <div class="nav-search">
          <span class="nav-search-icon">🔍</span>
          <input type="text" class="nav-search-input" placeholder="Search companies, news…" />
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <div class="nav-logo-box"><img src="/logo.svg" alt="BullSignal" style="width:100%;height:100%;object-fit:contain;display:block;border-radius:7px;" /></div>
            <div class="nav-brand-text">
              <span class="nav-brand-name">BullSignal</span>
              <span class="nav-brand-sub">MARKET INTELLIGENCE</span>
            </div>
          </div>
          <p class="footer-desc">NSE & BSE data updated twice daily, trending stocks, and investor-focused insights — all in one clean dashboard.</p>
        </div>
        <div class="footer-bottom">
          <p class="footer-copy">&copy; {new Date().getFullYear()} BullSignal. Market data for informational purposes only.</p>
          <div class="footer-links">
            <a href="/">Home</a>
            <a href="/about">About</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // ── India Market Ticker — reads from local JSON (no external API) ──────
      async function loadTicker() {
        const track = document.getElementById('tickerTrack');
        if (!track) return;
        try {
          const r    = await fetch('/data/india-stocks.json');
          const data = await r.json();
          const stocks = (data.nse || []).slice(0, 20); // top 20 NSE stocks
          if (!stocks.length) throw new Error('empty');
          const html = stocks.map(q => {
            const sym  = q.symbol.replace('.NS','').replace('.BO','');
            const pct  = parseFloat(q.regularMarketChangePercent) || 0;
            const up   = pct >= 0;
            const color = up ? '#22c55e' : '#ef4444';
            return `<span class="ti"><strong style="color:var(--gold)">${sym}</strong> <span style="color:#fff">₹${Number(q.regularMarketPrice).toLocaleString('en-IN',{maximumFractionDigits:2})}</span> <em style="color:${color}">${up?'▲':'▼'} ${Math.abs(pct).toFixed(2)}%</em></span>`;
          }).join('<span class="ti-sep">·</span>');
          track.innerHTML = html + '<span class="ti-sep" style="padding:0 32px"> </span>' + html;
        } catch {
          // Silent fail — placeholder stays
        }
      }

      loadTicker();
      setInterval(loadTicker, 120000);

      // ── Scroll-reveal IntersectionObserver ──────────────────────
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

      // ── India News Ticker ─────────────────────────────────────────────────
      async function loadNewsTicker() {
        const track = document.getElementById('newsTickerTrack');
        if (!track) return;
        // India-focused RSS feeds
        const feeds = [
          'https://economictimes.indiatimes.com/markets/rss.cms',
          'https://www.business-standard.com/rss/markets-106.rss',
          'https://www.moneycontrol.com/rss/marketsnews.xml',
        ];
        for (const rss of feeds) {
          try {
            const r = await fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(rss)}&count=14`);
            const d = await r.json();
            const items = (d?.items || []).filter((i: any) => i.title && i.title.length > 10);
            if (!items.length) continue;
            const html = items.map((item: any) =>
              `<a class="ti" style="text-decoration:none;color:#f0c040;" href="${item.link}" target="_blank" rel="noopener noreferrer"><strong style="color:#fde68a;">◆</strong> ${item.title}</a>`
            ).join('<span class="ti-sep" style="color:rgba(212,169,64,0.35);">·</span>');
            track.innerHTML = html + '<span class="ti-sep" style="padding:0 20px"> </span>' + html;
            return;
          } catch { continue; }
        }
        // India fallback headlines
        const fallback = [
          ['Nifty 50 edges higher as RBI holds repo rate steady','https://economictimes.indiatimes.com/markets/'],
          ['Sensex gains 200 pts led by banking and IT stocks','https://www.moneycontrol.com/'],
          ['FII inflows strengthen as India macro outlook improves','https://www.business-standard.com/markets'],
          ['RBI MPC minutes signal cautious stance on inflation','https://economictimes.indiatimes.com/'],
          ['HDFC Bank, Reliance Industries lift index to new high','https://www.moneycontrol.com/'],
          ['Q1 FY27 earnings season begins — TCS reports first','https://www.business-standard.com/'],
          ['Rupee firms against dollar amid strong FII buying','https://economictimes.indiatimes.com/markets/'],
        ];
        const html = fallback.map(([t,u]) =>
          `<a class="ti" style="text-decoration:none;color:#f0c040;" href="${u}" target="_blank" rel="noopener noreferrer"><strong style="color:#fde68a;">◆</strong> ${t}</a>`
        ).join('<span class="ti-sep" style="color:rgba(212,169,64,0.35);">·</span>');
        track.innerHTML = html + '<span class="ti-sep" style="padding:0 20px"> </span>' + html;
      }

      loadNewsTicker();
      setInterval(loadNewsTicker, 300000);

      // ── Nav Search ────────────────────────────────────────────────────────
      (function() {
        const input = document.querySelector('.nav-search-input');
        if (!input) return;

        // Build search index from sector + india-stocks JSON
        let searchIndex = [];
        async function buildIndex() {
          try {
            const [sRes, iRes] = await Promise.all([
              fetch('/data/india-sectors.json'),
              fetch('/data/india-stocks.json'),
            ]);
            const sData = await sRes.json();
            const iData = await iRes.json();
            const seen = new Set();
            const add = (sym, name) => {
              if (!sym || seen.has(sym)) return;
              seen.add(sym);
              const code = sym.replace(/\.(NS|BO)$/, '');
              searchIndex.push({ sym, code, name: name || code, url: `/company/${sym.toLowerCase().replace(/\./g,'-')}` });
            };
            // From sectors
            Object.entries(sData.quotes || {}).forEach(([sym, q]) => add(sym, q.shortName || q.longName || ''));
            // From india-stocks
            [...(iData.nse || []), ...(iData.bse || [])].forEach(q => add(q.symbol, q.name));
          } catch {}
        }
        buildIndex();

        // Dropdown
        const wrap = input.closest('.nav-search');
        const dropdown = document.createElement('div');
        dropdown.className = 'nav-search-dd';
        wrap.appendChild(dropdown);

        function showResults(q) {
          if (!q || q.length < 1) { dropdown.style.display = 'none'; return; }
          const ql = q.toLowerCase();
          const hits = searchIndex.filter(s =>
            s.code.toLowerCase().startsWith(ql) ||
            s.name.toLowerCase().includes(ql)
          ).slice(0, 8);
          if (!hits.length) { dropdown.style.display = 'none'; return; }
          dropdown.innerHTML = hits.map(h =>
            `<a class="nsd-item" href="${h.url}">
              <span class="nsd-code">${h.code}</span>
              <span class="nsd-name">${h.name}</span>
            </a>`
          ).join('');
          dropdown.style.display = 'block';
        }

        input.addEventListener('input', (e) => showResults(e.target.value.trim()));
        input.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            const first = dropdown.querySelector('.nsd-item');
            if (first) window.location.href = first.getAttribute('href');
            else {
              const q = e.target.value.trim();
              if (q) window.location.href = `/company/${q.toLowerCase().replace(/\./g,'-')}.ns`;
            }
          }
          if (e.key === 'Escape') { dropdown.style.display = 'none'; input.blur(); }
        });
        document.addEventListener('click', (e) => {
          if (!wrap.contains(e.target)) dropdown.style.display = 'none';
        });
      })();
    </script>
  </body>
</html>
